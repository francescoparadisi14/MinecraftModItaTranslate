    "msg.create_more_features.item_tooltip_block_of_shades": "§7This block changes shade depending on the biome",
    "msg.create_more_features.item_tooltip_color_time_block": "§7This block changes color depending on the time",
    "msg.create_more_features.item_tooltip_cultural_sapling": "§7The seedling of the cultivated tree was bred specifically for industrial tree extraction, its leaves can be obtained simply by breaking them by hand, in addition, this type of tree grows up to only 3 blocks in height, which makes it very convenient for automation",
    "msg.create_more_features.item_tooltip_fluids_storages": "§7This is a reusable vessel for storing water or lava, to draw liquid, press §6[RС]§7 to set §6[RС + Shift]§7, these tanks cannot be filled from the pump for the sake of balance",
    "msg.create_more_features.item_tooltip_fluids_storages_lava_level": "§7Lava level:",
    "msg.create_more_features.item_tooltip_fluids_storages_water_level": "§7Water level:",
    "msg.create_more_features.item_tooltip_flying_block": "§7This block can be installed in the air, that is, without support, very useful in various situations",
    "msg.create_more_features.item_tooltip_graphite": "§7A very powerful fuel, but it burns (is a fuel) only if there is more than 10 graphite in the stack!",
    "msg.create_more_features.item_tooltip_gravitron": "§7This item allows you to fly in survival as in creative. In this case, the strength of the item will be wasted, I recommend enchanting the item. The item can be repaired with a shadow ingot!",
    "msg.create_more_features.item_tooltip_lamp": "§7The dimmable lamp gradually turns on and off, if you give a redstone signal several times, they begin to flash, the more pulses, the more flashes",
    "msg.create_more_features.item_tooltip_lava": "§7Liquid for creating netherrack, when interacting with water there is a 1\/3 chance of creating granite",
    "msg.create_more_features.item_tooltip_shadow_ingot": "§7To obtain this very rare material, you must descend into the depths of the void in the End, holding an exquisite radiance in your hand... This item is used in many valuable crafts",
    "msg.create_more_features.item_tooltip_signalling": "§7The alarm reacts to a redstone signal, is useful for auto farms and various mechanisms, emits light and particles",
    "msg.create_more_features.item_tooltip_signalling_tooltip": "",
    "msg.create_more_features.item_tooltip_summary": "§7Hold §6[Shift]§7 for summary",
    "msg.create_more_features.item_tooltip_velcro": "§7A block that slows down creatures very much and prevents them from jumping, suitable for some auto farms",
    "msg.create_more_features.item_tooltip_work_blocks": "§7This is a special block for creating a new profession for villagers",
