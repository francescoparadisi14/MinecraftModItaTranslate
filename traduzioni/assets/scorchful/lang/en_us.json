    "yacl3.config.scorchful:common\/temperature.enableEnvironmentHeating.desc": "Global toggle on all heating from the environment.",
    "yacl3.config.scorchful:common\/temperature.environmentHeatingTickInterval": "Environment heating tick interval",
    "yacl3.config.scorchful:common\/temperature.environmentHeatingTickInterval.desc": "How many ticks should occur between applying heat to a player from the environment. Setting this to large values can be used to slow heat down. This may not be set to a value less than 1.",
    "yacl3.config.scorchful:common\/temperature.environmentTemperatureMultiplier": "Environment temperature multiplier",
    "yacl3.config.scorchful:common\/temperature.environmentTemperatureMultiplier.desc": "Multiplies the final temperature point change of an environment temperature change.",
    "yacl3.config.scorchful:common\/temperature.extraHumidBiomeSweatEfficiencyMultiplier": "Extra Humid biome sweating efficiency multiplier",
    "yacl3.config.scorchful:common\/temperature.extraHumidBiomeSweatEfficiencyMultiplier.desc": "A multiplier for sweating efficiency when the relative humidity is at or above 80%. This applies to rainy climates like Jungles, Swamps during the Wet Season (if a seasons mod is installed); to cave biomes; and to all non-arid biomes when it rains.",
    "yacl3.config.scorchful:common\/temperature.fireballTemperatureMultiplier": "Fireball temperature multiplier",
    "yacl3.config.scorchful:common\/temperature.fireballTemperatureMultiplier.desc": "Multiplies the temperature point change applied to entities when struck by a Fire Charge.",
    "yacl3.config.scorchful:common\/temperature.heatingMultiplier": "Heating multiplier",
    "yacl3.config.scorchful:common\/temperature.heatingMultiplier.desc": "Multiplies the final temperature point change of all non-environment heating sources like fire and lava.",
    "yacl3.config.scorchful:common\/temperature.humidBiomeSweatEfficiencyMultiplier": "Humid biome sweating efficiency multiplier",
    "yacl3.config.scorchful:common\/temperature.humidBiomeSweatEfficiencyMultiplier.desc": "A multiplier for sweating efficiency when the relative humidity is between 65% and 80^. This applies to rainy climates like Jungles, Swamps, etc.",
    "yacl3.config.scorchful:common\/temperature.iceTemperatureMultiplier": "Ice temperature multiplier",
    "yacl3.config.scorchful:common\/temperature.iceTemperatureMultiplier.desc": "Multiplies the temperature point change applied each tick from entities standing on ice.",
    "yacl3.config.scorchful:common\/temperature.inLavaTemperatureMultiplier": "In lava warm rate temperature multiplier",
    "yacl3.config.scorchful:common\/temperature.inLavaTemperatureMultiplier.desc": "Multiplies the temperature point change applied to entities swimming in Lava each tick.",
    "yacl3.config.scorchful:common\/temperature.maxEnvironmentHeatingScale": "Max environment heating scale",
    "yacl3.config.scorchful:common\/temperature.maxEnvironmentHeatingScale.desc": "The maximum temperature scale that the environment can heat players to. Given as a percentage from 0 to 1 (0 = 0%, 1 = 100%)",
    "yacl3.config.scorchful:common\/temperature.minTemperatureForHeatC": "Minimum temperature for heat (in °C)",
    "yacl3.config.scorchful:common\/temperature.minTemperatureForHeatC.desc": "Cutoff temperature for overheating in Celsius. Biomes at or above this temperature will apply environment heating to players. May not be less than 25°C.",
    "yacl3.config.scorchful:common\/temperature.powderSnowTemperatureMultiplier": "Powder Snow temperature multiplier",
    "yacl3.config.scorchful:common\/temperature.powderSnowTemperatureMultiplier.desc": "Multiplies the temperature point change applied to entities in Powder Snow each tick. This only applies to entities that are currently warm.",
    "yacl3.config.scorchful:common\/temperature.soakedTemperatureMultiplier": "Soaked temperature multiplier",
    "yacl3.config.scorchful:common\/temperature.soakedTemperatureMultiplier.desc": "Multiplies the temperature point change applied entities that are wet, each tick.",
    "yacl3.config.scorchful:common\/temperature.striderCoolingTemperatureMultiplier": "Strider cooling temperature multiplier",
    "yacl3.config.scorchful:common\/temperature.striderCoolingTemperatureMultiplier.desc": "Multiplies the cooling to applied only to Striders each tick they are not in Lava.",
    "yacl3.config.scorchful:common\/temperature.sweatEfficiency": "Sweating efficiency",
    "yacl3.config.scorchful:common\/temperature.sweatEfficiency.desc": "A multiplier for overall sweating efficiency. Large values mean you will cool down faster from being wet.",
    "yacl3.config.scorchful:common\/weather.category.main": "Weather Settings",
    "yacl3.config.scorchful:common\/weather.desc": "Specific settings for Scorchful's weather-related effects.",
