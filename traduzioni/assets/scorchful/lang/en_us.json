    "yacl3.config.scorchful:common\/weather.doSandPileAccumulation.desc": "Enable\/disable sand piles accumulating on the ground during sandstorms.",
    "yacl3.config.scorchful:common\/weather.sandPileAccumulationHeight": "Sand Pile accumulation height",
    "yacl3.config.scorchful:common\/weather.sandPileAccumulationHeight.desc": "Sets the maximum height of sand piles that can accumulate during sand storms. Maximum value is 8.",
    "yacl3.config.scorchful:common\/weather.sandstormFollowRangeReductionPercent": "Sandstorm Follow Range reduction amount (percent from -1 to +1)",
    "yacl3.config.scorchful:common\/weather.sandstormFollowRangeReductionPercent.desc": "How much to multiply the total follow range of entities on the surface by during Sandstorms. Negative values decrease follow range, positive values increase it.",
    "yacl3.config.scorchful:common\/weather.sandstormSlownessAmountPercent": "Sandstorm Slowness amount (percent from -1 to +1)",
    "yacl3.config.scorchful:common\/weather.sandstormSlownessAmountPercent.desc": "How much to multiply the total speed of entities on the surface by during Sandstorms. Negative values provide slowness, positive values provide speed.",
