    "cobbreeding.config_screen.extra.compat.cobblemonSizeVariations.tip": "Attiva o disattiva la patch di compatibilità.",
    "cobbreeding.config_screen.extra.custom_eggs": "Colori personalizzati per le uova",
    "cobbreeding.config_screen.extra.custom_eggs.tip": "Sostituisce la texture predefinita delle uova con alternative specifiche per il tipo di uovo.",
    "cobbreeding.config_screen.extra.ditto_ditto": "Meccaniche di riproduzione di Ditto",
    "cobbreeding.config_screen.extra.ditto_ditto.allow_legendary": "La riproduzione con Ditto consente di ottenere Pokémon leggendari (e mitologici) tramite uova.",
    "cobbreeding.config_screen.extra.ditto_ditto.allow_legendary.tip": "Permette alle uova casuali di schiudersi e dare vita a Pokémon leggendari (e mitologici).",
    "cobbreeding.config_screen.extra.ditto_ditto.allow_paradox": "L'accoppiamento di Ditto con Ditto consente di ottenere Pokémon Paradox nelle uova.",
    "cobbreeding.config_screen.extra.ditto_ditto.allow_paradox.tip": "Permette alle uova casuali di schiudersi in Pokémon paradossali.",
    "cobbreeding.config_screen.extra.ditto_ditto.allow_ultra_beast": "La riproduzione di Ditto + Ditto consente di ottenere le Ultra Beast nelle uova.",
    "cobbreeding.config_screen.extra.ditto_ditto.allow_ultra_beast.tip": "Permette alle uova casuali di schiudersi in creature ultra.",
    "cobbreeding.config_screen.extra.ditto_ditto.allow_undiscovered": "L'utilizzo di Ditto per la riproduzione consente di ottenere Pokémon non riproducibili tramite la riproduzione tradizionale (cioè, quelli che non sono leggendari, mitologici, paradossi o creature ultra), attraverso le uova.",
    "cobbreeding.config_screen.extra.ditto_ditto.allow_undiscovered.tip": "Permette alle uova casuali di schiudersi in Pokémon appartenenti al gruppo di uova non ancora scoperto (ovvero, non leggendari, mitologici, paradossi o creature ultra),",
    "cobbreeding.config_screen.extra.ditto_ditto.random_egg": "La riproduzione con Ditto + Ditto produce uova casuali.",
    "cobbreeding.config_screen.extra.ditto_ditto.random_egg.tip": "Le uova casuali non contengono alcuna informazione relativa alla specie o alla forma, ma vengono identificate solo quando l'uovo si schiude.",
    "cobbreeding.config_screen.extra.encryption": "Crittografia delle uova",
    "cobbreeding.config_screen.extra.encryption.tip": "Permette di crittografare il contenuto delle uova per prevenire l'accesso alle informazioni.",
    "cobbreeding.config_screen.extra.encryption.tip2": "Disattiva se utilizzi mod che leggono il contenuto dell'uovo per visualizzare ulteriori informazioni. (solo per la modalità single player)",
    "cobbreeding.config_screen.extra.hoppers": "Estrazione di Hopper",
