    ],
    "quest.39796D8EE440F318.quest_subtitle": "Piramiadi del deserto",
    "quest.39796D8EE440F318.title": "Rettilatura per armature \"Dune\"",
    "quest.3A2047CC0F59C6CC.quest_desc": [
        "Armatura avanzata per \\&a\\&lRoots Classic"
    ],
    "quest.3A2047CC0F59C6CC.quest_subtitle": "17",
    "quest.3A2047CC0F59C6CC.title": "\\&aWildwood Gear",
    "quest.3AA836E8EDB52097.quest_desc": [
        "{image:atm:textures\/questpics\/basicarmor\/armor_lapis.png width:100 height:150 align:center}"
    ],
    "quest.3AA836E8EDB52097.title": "\\&9Lapis Lazuli\\&r",
    "quest.3ABE7074E500494D.quest_desc": [
        "\\&7Steel\\&r è utilizzato per la maggior parte delle macchine in \\&5\\&lMekanism\\&r... oltre all'armatura, che è molto utile!"
    ],
    "quest.3ABE7074E500494D.quest_subtitle": "20",
    "quest.3ABE7074E500494D.title": "\\&7Armatura in acciaio",
    "quest.3AE0198177A8E91B.quest_desc": [
