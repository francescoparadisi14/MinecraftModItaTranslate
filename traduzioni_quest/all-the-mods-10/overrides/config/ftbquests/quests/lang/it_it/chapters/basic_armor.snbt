    ],
    "quest.452DC5EB02D592B8.title": "\\&5Amethyst\\&r",
    "quest.459BB5B4CDB21773.quest_desc": [
        "\\&9Swamp Silver\\&r si trova nelle paludi fangose all'interno di \\&5\\&lEternal Starlight\\&r."
    ],
    "quest.459BB5B4CDB21773.quest_subtitle": "15",
    "quest.459BB5B4CDB21773.title": "\\&9Armatura d'argento delle paludi",
    "quest.4664AFCFB5618CEB.quest_desc": [
        "\\&bGlacite\\&r si trova negli ambienti freddi di \\&5\\&lEternal Starlight\\&r!"
    ],
    "quest.4664AFCFB5618CEB.quest_subtitle": "17",
    "quest.4664AFCFB5618CEB.title": "\\&Armatura di ghiaccio",
    "quest.497D222F74A52DF5.quest_desc": [
        "Questo è esattamente ciò che mi piace! Il ferro è molto comune e la sua armatura è fantastica per le prime fasi del gioco.\n\nZombi e scheletri hanno pochissime possibilità!"
    ],
    "quest.497D222F74A52DF5.quest_subtitle": "15",
    "quest.498483750C18FCD6.quest_desc": [
        "{image:atm:textures\/questpics\/basicarmor\/armor_regalium.png width:100 height:150 align:center}"
    ],
    "quest.498483750C18FCD6.title": "\\&eRegalium\\&r",
    "quest.4A9CB8778D37049F.quest_desc": [
        "Dovrete utilizzare un rituale di risveglio per far sì che gli oggetti possano eseguire un altro rituale di risveglio sull'armatura \\&4Supremium Armor\\&r.\n\nPenso che valga la pena; è l'armatura migliore che si possa ottenere dall'oggetto \\&2\\&lMystical\\&r!"
    ],
    "quest.4A9CB8778D37049F.quest_subtitle": "36",
    "quest.4A9CB8778D37049F.title": "\\&6Armatura Superiore Risvegliata",
    "quest.4B65100885AE762D.quest_desc": [
        "\\&e\\&lIncantesimi di Ferro\\&r \\&6Armatura Sacra\\&r!"
    ],
    "quest.4B65100885AE762D.quest_subtitle": "20",
    "quest.4B65100885AE762D.title": "\\&6 Abbigliamento per il clero",
    "quest.4B9C54DA5CB6D5C9.quest_desc": [
        "{image:atm:textures\/questpics\/basicarmor\/armor_host.png width:100 height:150 align:center}"
    ],
    "quest.4B9C54DA5CB6D5C9.quest_subtitle": "Resti di antichi sentieri",
    "quest.4B9C54DA5CB6D5C9.title": "Rafforzamento della carrozzeria",
    "quest.4DD66E31859EA593.quest_desc": [
        "\\&3Armatura in Vibranium\\&r, ma con potenziamenti per gli incantesimi di \\&e\\&l\"Incantesimi di Ferro\""
    ],
    "quest.4DD66E31859EA593.quest_subtitle": "32",
    "quest.4DD66E31859EA593.title": "\\& Abbigliamento da mago di Vibranium",
