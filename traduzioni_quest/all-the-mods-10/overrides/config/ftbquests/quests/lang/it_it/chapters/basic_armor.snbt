    "quest.1EABF2E7AE7B8F22.quest_desc": [
        "{image:atm:textures\/questpics\/basicarmor\/armor_netherite.png width:100 height:150 align:center}"
    ],
    "quest.1EABF2E7AE7B8F22.title": "\\&8Netherite\\&r",
    "quest.1EBF234015B26F15.quest_desc": [
        "Armatura di base fornita da \\&a\\&lRoots Classic\\&r, ma avrete bisogno di un rituale per ottenerla!"
    ],
    "quest.1EBF234015B26F15.quest_subtitle": "14",
    "quest.1EBF234015B26F15.title": "\\&2Sylvan Gear",
    "quest.1FC7ABEAB5018E79.quest_desc": [
