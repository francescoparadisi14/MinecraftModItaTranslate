{
    "quest.026C63594F813BCC.quest_desc": [
        "\\&Tipo di abilità: Attiva",
        "",
        "\\&Funzione:\\&",
        "",
        "Elimina tutti gli effetti negativi dal giocatore quando viene attivato, e ha un periodo di ricarica."
    ],
    "quest.0272E58516A0C284.quest_desc": [
        "Aggiornamenti validi:",
        "- Ore miner",
        "- Scanner Ore \\&4\\&disabilitato\\&r\\&f",
        "- Tagliaserrа",
        "- Sky Sweeper",
        "- Taglialegna",
        "- \"Leaf Breaker\" (traducibile come \"Rompi foglie\" o \"Distruttore di foglie\")",
        "- Fabbrica di fusione di metalli",
        "- Martello",
        "- Teletrasporto"
    ],
    "quest.02B0CCD5607FF3B5.quest_desc": [
        "L'accessor per il giocatore funge da interfaccia con l'inventario del giocatore. Utilizzando l'interfaccia grafica, l'accessor può essere configurato per interagire con gli slot dell'inventario, gli slot per gli oggetti tenuti in mano o per l'armatura."
    ],
    "quest.02B8F50721F12CFF.quest_desc": [
        "\\&lTipo di abilità:\\&r Passiva",
        "",
        "\\&Funzione:",
        "",
        "Impedisce al giocatore di subire danni a causa delle cadute."
    ],
    "quest.03ED9B0DFE8B4574.quest_desc": [
        "Aggiornamenti validi:",
        "- Confusione mentale",
        "- Incantare",
        "",
        "Abilità intrinseca:",
        "- Riparazione di Lava"
    ],
    "quest.04A1D582003A0D9A.quest_desc": [
        "Aggiornamenti validi:",
        "- Velocità",
        "- Velocità di camminata"
    ],
    "quest.05056CAA64E3971B.quest_desc": [
        "\\&lTipo di abilità:\\&r Passiva",
        "",
        "\\&Funzione:\\&",
        "",
        "Rende gli archi che sparano frecce applicano un effetto di una pozione, basato sul contenitore di pozioni che si utilizza."
    ],
    "quest.05D8C6EF8FCD6250.quest_desc": [
        "Primogel Goo è il primo tipo di \"goo\" creato da JDT e richiede materiali di base provenienti dal mondo reale per essere prodotto.",
        "",
        "Abilità sbloccate:",
        "- Ferricore",
        "- Carbone primario",
        "",
        "Esempio di Goo Spread:",
        "",
        "{image:atm:textures\/questpics\/justdirethings\/goo_spread_ferricore.png width:200 height:200 align:center}"
    ],
    "quest.07655CA904354E9E.quest_desc": [
        "\\&Tipo di abilità: Attiva",
        "",
        "\\&Funzione:",
        "",
        "Interrompe l'erba e i fiori nelle immediate vicinanze quando viene attivato."
    ],
    "quest.079A415488A32076.quest_desc": [
        "Blaze Ember è un nuovo materiale introdotto da JDT. Blaze Ember può essere ottenuto eseguendo l'operazione \"Goo Spread\" su blocchi di carbone primario utilizzando \"Goo\" di livello 2 o superiore. L'oro di Blaze Ember è influenzato dal fattore fortuna."
    ],
    "quest.09485B63483B7A15.quest_desc": [
        "\\&Tipo di abilità: Attiva",
        "",
        "\\&Funzione:",
        "",
        "Fa sì che le creature ostili nelle vicinanze diventino bersaglio del giocatore per un breve periodo, con un tempo di ricarica."
    ],
    "quest.09D2137B4F42006E.quest_desc": [
        "Eclipse Ember è un nuovo materiale introdotto da JDT. Eclipse Ember viene ottenuto tramite l'utilizzo di Goo Spread su blocchi di carbone Voidflame, utilizzando Goo di livello 4. Il minerale Eclipse Ember è influenzato dalla fortuna."
    ],
    "quest.0A02DBE226C3F44E.quest_desc": [
        "Aggiornamenti validi:",
        "- Confusione mentale",
        "- Incantare",
        "- Visione notturna",
        "- Rimozione di effetti negativi",
        "- Eliminazione mentale"
    ],
    "quest.0B485DB737A036E9.quest_desc": [
        "La funzione \"Impostazioni condivise\" consente ai giocatori di copiare le impostazioni tra diversi dispositivi."
    ],
    "quest.0B9BBE2A764631BF.quest_desc": [
        "Il semplice \"swapper\" può teletrasportare oggetti, blocchi, creature o giocatori sopra di esso a un altro \"swapper\" a cui è collegato. Per collegare i \"swapper\" utilizzare la chiave Ferricore."
    ],
    "quest.0C1D55AA9CC902BD.quest_desc": [
        "Aggiornamenti validi:",
        "- Tagliaserrа",
        "- Sky Sweeper",
        "- Fabbrica di fusione di metalli",
        "- Martello",
        "- Teletrasporto"
    ],
    "quest.0C2EC56133D3CC6C.quest_desc": [
        "\\&Tipo di abilità: Attiva",
        "",
        "\\&Funzione:\\&",
        "",
        "Rende temporaneamente il giocatore immune ai danni una volta attivato, con un periodo di ricarica."
    ],
    "quest.0C9DD8E53A1B92C0.quest_desc": [
        "Aggiornamenti validi:",
        "- Ore miner",
        "- Fabbrica di fusione di metalli",
        "- Martello",
