    ],
    "quest.2A3C64B6B9608791.quest_subtitle": "Recovery Items",
    "quest.2AB54006DEE3A098.quest_desc": [
        "                 In a battle,",
        "            Every detail counts.",
        "",
        "                &cBattle Items&f",
        "         Are your best friends",
        "              When you need",
        "               An advantage.",
        "",
