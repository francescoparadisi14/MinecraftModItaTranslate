    "quest.31AD12570B3A6955.quest_subtitle": "Fire Armor",
    "quest.31B51F63AB13498B.quest_subtitle": "Leaf Shovel",
    "quest.321A180A650B387F.quest_subtitle": "Capture your first legendary birds",
