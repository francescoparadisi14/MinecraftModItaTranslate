    "quest.0CECCC0AEEB7F9BC.quest_subtitle": "Your first Poké Ball",
    "quest.0CECCC0AEEB7F9BC.title": "Crafting",
    "quest.0CED28FABABEDD54.quest_subtitle": "Now stronger!",
    "quest.0D384C2C0ACEC429.quest_subtitle": "Mega Evolution Stone",
    "quest.0D59BE49CF7BE117.quest_desc": [
        "            The &dMetronome&f is a",
        "             Held &eItem&f of power.",
        "",
        "  It boosts moves used consecutively,",
        "      Growing stronger each turn.",
        "",
        "  Power increases by &e+20%&f per turn,",
        "   Up to a maximum of &e+100%&f in total.",
        "",
        "   The effect resets if the &aPokémon&f",
        "Uses a different move or switches out."
    ],
    "quest.0D59BE49CF7BE117.quest_subtitle": "Boosts moves used consecutively by 20% per turn, up to 100%",
    "quest.0D7E35C1A9CF3DE1.quest_subtitle": "Leaf Armor",
    "quest.0D8B1079489782A5.quest_desc": [
        "      A &5Power Band&f is a power item.",
        "  When held, &ePokémon&f gain normal EVs",
        "    Plus &a+8 Sp. Def EVs&f after battle.",
        "      The holder's &bSpeed&f is halved.",
        "",
