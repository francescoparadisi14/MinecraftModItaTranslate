    "quest.5060DC7728DCD2FE.quest_subtitle": "Kill some Pokemon",
    "quest.50922EC16511E269.quest_desc": [
        "              Get some fossils",
        "         Make some &ecombinations",
        "              Below I'll list all",
        "                   &cPossible&f."
    ],
    "quest.50922EC16511E269.quest_subtitle": "New Age (or Old?)",
    "quest.50B081CE5EA36414.quest_desc": [
        "    &dBreeding&f your &aPokémon&f is a very",
        "    Important part of getting strong",
        "                 Companions.",
        "",
        "  With it, you can achieve &ePerfect IVs&f,",
        "    The &dNature&f you want, and much",
        "     More control over the future.",
        "",
        "    But of course, it has its level of",
        "     &cDifficulty&f — it won’t be so easy.",
        "",
        "            Don’t worry, Trainer...",
        "          I’ll teach you a little bit!"
    ],
    "quest.50B081CE5EA36414.quest_subtitle": "Starting to breed our pokemons",
    "quest.50B081CE5EA36414.title": "Breeding",
    "quest.50B59E22E001E216.quest_subtitle": "Leaf Armor",
    "quest.50E70B1AD0B7E237.quest_desc": [
