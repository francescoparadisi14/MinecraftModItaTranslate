    "quest.2B86798C51F44554.quest_subtitle": "Arctovish",
    "quest.2BC819107FCB6DBE.quest_desc": [
        "             The &9Quick Ball&f is a",
        "          Special type of &bPoké Ball&f",
        "",
        "   It has a &e5× Catch Rate&f if used on",
        "     The first turn of a wild battle.",
        "",
        "    Otherwise, it has only a &e1× Rate&f",
        "   If the &aPokémon&f is already fought.",
        "",
        "   Throwing it outside of battle will",
        "      Always result in a &e1× Rate&f.",
        "",
        "    It can be obtained by &acrafting&f,",
        "   Buying from a &eShopkeeper&f, or as",
        "          A &6Tier 1 Special Drop&f."
    ],
    "quest.2BC819107FCB6DBE.quest_subtitle": "5x Catch rate in first round",
