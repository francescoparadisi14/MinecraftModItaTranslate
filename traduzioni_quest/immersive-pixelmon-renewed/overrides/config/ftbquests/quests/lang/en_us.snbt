    "quest.4B1843B644C9BF3A.quest_subtitle": "Dawn Shovel",
    "quest.4B4EC01FE09C5478.quest_desc": [
        "            These are items that, ",
        "         When used on a &6Pokémon, ",
        "        Make it evolve immediately. ",
        "      They're the most &lcommon &rand ",
        "               &bEasiest to use&f."
    ],
    "quest.4B4EC01FE09C5478.quest_subtitle": "Evolution stones",
    "quest.4B6351F6591908F9.quest_subtitle": "Craft mold",
    "quest.4B695AA37A3B1C30.quest_subtitle": "Sun Pickaxe",
    "quest.4B94DCF114A32E3E.quest_desc": [
        "             The &eSoft Sand&f is a",
        "             Held &eItem&f of power.",
        "",
        "      It boosts &6Ground-type&f moves",
        "             Of its holder by &e20%&f."
    ],
    "quest.4B94DCF114A32E3E.quest_subtitle": "Boosts Ground-type moves",
    "quest.4BC724E8196B4083.quest_desc": [
        "      The &bX Accuracy&f is a type of",
        "   Medicine that temporarily raises a",
        "   &ePokémon's&f &9accuracy&f by one stage",
        "            While in battle. It is a",
        "    Possible drop from common boss",
        "                    &ePokémon&f."
    ],
    "quest.4BC724E8196B4083.quest_subtitle": "Accuracy ",
    "quest.4C5BFE3D508B372E.quest_desc": [
        "            &dMax Moves&f Effects",
        "",
        " &fNormal   → &dMax Strike&f",
        "   ↓ Decreases &bSpeed&f of foes.",
        "",
        " &cFighting → &dMax Knuckle&f",
        "   ↑ Increases user &cAttack&f.",
        "",
        " &bFlying   → &dMax Airstream&f",
        "   ↑ Increases user &bSpeed&f.",
        "",
        " &5Poison   → &dMax Ooze&f",
        "   ↑ Increases user &dSp. Atk&f.",
        "",
        " &6Ground   → &dMax Quake&f",
        "   ↑ Increases user &dSp. Def&f.",
        "",
        " &7Rock     → &dMax Rockfall&f",
        "   → Summons &6Sandstorm&f (5 turns).",
        "",
        " &2Bug      → &dMax Flutterby&f",
        "   ↓ Lowers foe &dSp. Atk&f.",
        "",
        " &5Ghost    → &dMax Phantasm&f",
        "   ↓ Lowers foe &7Defense&f.",
        "",
        " &7Steel    → &dMax Steelspike&f",
        "   ↑ Increases user &7Defense&f.",
        "",
        " &cFire     → &dMax Flare&f",
        "   → Sets &6Harsh Sunlight&f (5 turns).",
        "",
        " &bWater    → &dMax Geyser&f",
        "   → Starts &bRain&f (5 turns).",
        "",
        " &aGrass    → &dMax Overgrowth&f",
        "   → Sets &aGrassy Terrain&f (5 turns).",
        "",
        " &eElectric → &dMax Lightning&f",
        "   → Sets &eElectric Terrain&f (5 turns).",
        "",
        " &dPsychic  → &dMax Mindstorm&f",
        "   → Sets &dPsychic Terrain&f (5 turns).",
        "",
        " &bIce      → &dMax Hailstorm&f",
        "   → Starts &bHail&f (5 turns).",
        "",
        " &5Dragon   → &dMax Wyrmwind&f",
        "   ↓ Lowers foe &cAttack&f.",
        "",
        " &8Dark     → &dMax Darkness&f",
        "   ↓ Lowers foe &dSp. Def&f.",
        "",
        " &dFairy    → &dMax Starfall&f",
        "   → Sets &dMisty Terrain&f (5 turns).",
        "",
        " &fStatus   → &dMax Guard&f",
        "   → Protects from &cAll Moves&f,",
        "     Even &dMax Moves&f."
    ],
    "quest.4C5BFE3D508B372E.quest_subtitle": "List Moves",
    "quest.4C5E3A10BD046E76.quest_desc": [
        "       In general, two &aPokémon&f of",
        "    Opposite &dGenders&f are required",
        "                  To breed.",
        "",
        "  They must also belong to the same",
        "                 &5Egg Group&f.",
        "",
        "   This produces an &eEgg&f containing a",
        "   Level &e1&f &aPokémon&f — the base form",
        "       Of the &dmother's species&f line.",
        "",
        "    Example: a &dVenusaur&f mother will",
        "   Produce an Egg with a &aBulbasaur&f."
    ],
    "quest.4C5E3A10BD046E76.quest_subtitle": "Egg Group",
    "quest.4C5E3A10BD046E76.title": "Pokemon Egg",
    "quest.4C9133CDBB18937B.quest_desc": [
        "              &fLet's cook a little"
    ],
