    "quest.374E37DB1EFE559B.quest_desc": [
        "        The &bX Speed&f is a type of",
        "   Medicine that temporarily raises a",
        "     &ePokémon's&f &bSpeed&f by one stage",
        "                 While in battle."
    ],
    "quest.374E37DB1EFE559B.quest_subtitle": "Speed",
    "quest.3764E5D64EDEDCE5.quest_desc": [
        "        The &cIncinium Z&f is a unique",
        "     &eZ-Crystal&f for &cIncineroar&f only.",
        "",
        "       Moves this &eZ-Crystal&f can",
        "                Transform:",
        "",
        "       &cDarkest Lariat&f becomes the",
        "       &dMalicious Moonsault&f attack.",
        "",
        "   &7Special:&f Only an &cIncineroar&f can",
        "                Use this move.",
        "",
        "     &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "  Make a &aPokémon&f drop the &eZ-Crystal&f",
        "                 It is holding."
    ],
    "quest.3764E5D64EDEDCE5.quest_subtitle": "Incineroar",
    "quest.3792FABBCACBDAFB.quest_subtitle": "Mega Evolution Pokemon",
    "quest.38001CEFDBA3CA40.quest_desc": [
        "                &bHello Trainer&f!",
        "    I'll help you on your journey to",
        "       Becoming a &aPokémon Master&f.",
        "",
        "       I'll teach you the &eEssentials&f,",
        "    And then... You can buy me a &6Beer&f."
    ],
    "quest.38001CEFDBA3CA40.quest_subtitle": "The beginning of everything",
    "quest.3851A8BEBB6C0432.quest_desc": [
        "   A &bKey Stone&f is an accessory that",
        " Is required for a player to use &dMega",
        "         Evolution&f or &6Z-Moves&f.            ",
        "",
        "   It is not a physical item; instead, it    ",
        "   Can be equipped directly from the",
        "                 Inventory.                   ",
        "",
        "     A &bKey Stone&f must be unlocked",
        "                  And worn",
        "      For a player to &dMega Evolve&f",
        "                 A &ePokémon&f.",
        "",
        "           If a player wears a",
        "          &bKey Stone&f, a &ePokémon&f ",
        "        Owned by the player can ",
        "           &dMega Evolve&f in battle",
        "   If holding its matching &aMega Stone&f.  ",
        "",
        "        If the &bKey Stone&f has not",
        "              Been unlocked",
        "    Or if unlocked but not equipped",
        " Then &dMega Evolution&f cannot be used.   ",
        "",
        "  By defeating a &9Mega Evolved boss&f",
        " For the first time, the player unlocks",
        "   The option to equip a &bKey Stone&f.   ",
        "               Alternatively..."
    ],
    "quest.3851A8BEBB6C0432.quest_subtitle": "Bracelet",
    "quest.3854B8DBC7739E9A.quest_desc": [
        "            The &9Blue Flute&f is an",
        "                   &eItem&f that",
        "",
        "        Awakens sleeping &aPokémon&f."
    ],
    "quest.3854B8DBC7739E9A.quest_subtitle": "\"is this for sleeping?\"",
    "quest.38608EDC8F839FF5.quest_desc": [
        "             The &6Heat Rock&f is a",
        "            Held &eItem&f that boosts",
        "",
        "        The duration of &6Sunny Day&f",
        "       And &cDrought&f to &e8 turns&f long."
    ],
    "quest.38608EDC8F839FF5.quest_subtitle": "Extends the duration of Sunny Day and Drought to 8 turns",
    "quest.388129BF7E2FAA0C.quest_subtitle": "Mega Evolution Stone",
    "quest.394256FAAF32FFBD.quest_desc": [
        "              &cEvolve 5 Pokémon ",
        "       To complete your daily quest."
    ],
    "quest.394256FAAF32FFBD.quest_subtitle": "Evolving species",
    "quest.395C0BA0ACDA8F72.quest_desc": [
        "             Capture a &eNecrozma"
    ],
    "quest.395C0BA0ACDA8F72.quest_subtitle": "Challange",
    "quest.395E3016FB1A071C.quest_desc": [
        "        An &eElectirizer&f is a held item",
        "     That can be held by &6Electabuzz&f",
        "In order for it to evolve into &6Electivire",
        "                 &fWhen traded."
    ],
    "quest.395E3016FB1A071C.quest_subtitle": "Electabuzz -> Electivire",
    "quest.399B8594C67D7745.quest_subtitle": "Moon Armor",
    "quest.39A750E345EA95D5.quest_desc": [
        "       The &cTimespace Altar&f is found     ",
        " Generated in a special structure,      ",
        "     Called the &6Spear Pillar&f, that      ",
        " Can rarely spawn in certain biomes.    ",
        "",
        "   It is used to spawn the &dLegendary     ",
        "   Creation Trio&f: &bPalkia&f, &9Dialga&f, and",
        "      &5Giratina&f, as well as &eArceus&f.       ",
        "",
        " The altar features &7Temple Pillars&f and  ",
        "  &7Temple Blocks&f in the main structure  ",
        "   And the &cTimespace Altar&f itself.      ",
        "",
        "The &cTimespace Altar&f is modelled after  ",
        "The &6golden&f cross-like wheel on &eArceus&f",
        " And contains three symbols for each     ",
        "   Of the Legendary Trio mentioned.     "
    ],
    "quest.39A750E345EA95D5.quest_subtitle": "Palkia, Dialga, Giratina, Arceus",
    "quest.39F40511C3F38B4E.quest_subtitle": "The basis of all",
    "quest.3A0548A3CD21A8F7.quest_desc": [
        "       The &dCloning Machine&f is used",
        "         To extract &aDNA&f from &dMew&f",
        "       To create the mighty &5Mewtwo&f.",
        "",
        "    However, the experiment may fail",
        "    And instead produce only a &dDitto&f.",
        "",
        "      It is built with a &aGreen Tank&f,",
        "  An &6Orange Tank&f, and a &eCloner Cord&f.",
        "",
        "  It can be broken by hand, but using",
        "    A &7Pickaxe&f will make it much faster."
    ],
    "quest.3A0548A3CD21A8F7.quest_subtitle": "Cloning time",
    "quest.3A10079170376868.quest_subtitle": "Craft",
    "quest.3A7C3B8AA89DF011.quest_desc": [
        "        The &eElectrium Z&f is a unique",
        " &eZ-Crystal&f for &eElectric-Type Pokémon&f.",
        "",
        "       Moves this &eZ-Crystal&f can",
        "                Transform:",
        "",
        "  Any &eElectric-Type&f move that isn't a",
        "   Status move becomes the fierce",
        "         &dGigavolt Havoc&f attack.",
        "",
        "     &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "  Make a &aPokémon&f drop the &eZ-Crystal&f",
        "                 It is holding."
    ],
    "quest.3A7C3B8AA89DF011.quest_subtitle": "Electric-Type",
    "quest.3AF05DF7F4EA44D4.quest_subtitle": "Hammer or Hammer",
    "quest.3B191A10E2994441.quest_subtitle": "Don't throw straws into the sea!",
    "quest.3B1B10E3DD92DF6D.quest_subtitle": "Sun Hoe",
    "quest.3B2E0EA2DED3E9E8.quest_desc": [
        "      A &6Choice Scarf&f is a held item.",
        "    It boosts &bSpeed&f by &a50%&f, but the",
        "     &ePokémon&f can only use the first",
        "           Move it selects in battle."
    ],
    "quest.3B2E0EA2DED3E9E8.quest_subtitle": "Boosts Speed by 50% , but restricts the Pokémon to one move",
    "quest.3B7D8AC57DB7063B.quest_subtitle": "Dawn Hoe",
    "quest.3B8A034277DC555E.quest_desc": [
        "     The &6Gold Bottle Cap&f is an item",
        "   That increases the stats of a max",
        "    Level &ePokémon&f to act as if it had",
        "                Perfect &aIVs&f.",
        "",
        "   When you right-click a max level",
        "  &ePokémon&f with this item, every stat",
        "   (HP, &cAttack&f, &9Defense&f, &dSp. Attack&f,",
        "    &dSp. Defense&f, and &bSpeed&f) which",
        "  Does not already have a perfect &aIV&f",
        "   Will be increased. Unlike the &7Silver",
        "  Bottle Cap&f, this increases all stats.",
        "",
        "  &6Gold Bottle Caps&f are obtainable via",
        "      Fishing and Max Raid Battles.",
        "",
        "   Bottle Caps only affect the &aIVs&f for",
        " Battling purposes. They do not affect",
        " The type of Hidden Power nor affect",
        "                   Breeding."
    ],
    "quest.3B8A034277DC555E.quest_subtitle": "Op, but golden",
    "quest.3B9B604368957226.quest_desc": [
        "         A &dMoon Stone&f is a type of",
        "     Evolution stone used to evolve",
        "        Certain species of &ePokémon&f.",
        "",
        "     &dMoon Stone&f can be used for the",
        "            Following evolutions:",
        "",
        "          &6Nidorina &f→ &6Nidoqueen",
        "          &6Nidorino &f→ &6Nidoking",
        "          &6Clefairy &f→ &6Clefable",
        "         &6Jigglypuff &f→ &6Wigglytuff",
        "          &6Skitty &f→ &6Delcatty",
        "          &6Munna &f→ &6Musharna."
    ],
    "quest.3B9B604368957226.quest_subtitle": "Sun and",
    "quest.3BC106C6BFDBEE23.quest_desc": [
        "           Aqua armor is based",
        "       On the outfits of Team Aqua",
        " From the Generation 3 Pokémon games."
    ],
    "quest.3BC106C6BFDBEE23.quest_subtitle": "Team armor",
    "quest.3BE288D1B4C81AFF.quest_subtitle": "Pickaxe",
    "quest.3BE7DC0733EC5165.quest_subtitle": "&aSpecial Attack &8\/ &cSpeed",
    "quest.3BEA93B6EB079C2B.quest_subtitle": "Challenge",
    "quest.3BEE90AAF14E33C5.quest_subtitle": "A new type of poke balls",
    "quest.3BEF985940715EEE.quest_subtitle": "Sun Armor",
    "quest.3C1FCCA8C95C0100.quest_subtitle": "Mantine → Mantyke",
    "quest.3C5DB791A8428478.quest_desc": [
        "          Capture all &elegendaries&f."
    ],
    "quest.3C5DB791A8428478.quest_subtitle": "Challange",
    "quest.3CA54CDBECCE8D7C.quest_desc": [
        "          In our beloved &bPixelmon&f,",
        "          There are many ways to",
        "              &6Evolve a &ePokémon&f.",
        "",
        "  And one of the most interesting ways",
        "          Is by using these &citems&f.",
        "",
        "      It may seem &dcomplex&f, and it is,",
        "            But I will teach you!"
    ],
    "quest.3CA54CDBECCE8D7C.quest_subtitle": "Evolutionary items",
    "quest.3D002E0C729F67C7.quest_desc": [
        "     A &cDeep Sea Tooth&f is a held item.",
        "     It doubles &eClamperl's&f &dSp. Attack&f.",
        "",
        "  If &eClamperl&f is traded while holding it,",
        "      It will evolve into &bHuntail&f and",
        "           The item is consumed."
    ],
    "quest.3D002E0C729F67C7.quest_subtitle": "Evolves Clamperl into Huntail when traded. It also doubles Clamperl's Sp. Attack",
    "quest.3D1CDC25BA8CF342.quest_subtitle": "&aSpeed &8\/ &cSpecial Defense",
    "quest.3D5B0F83466873C0.quest_desc": [
        "              After it's cleaned,",
        "          You'll have a fossil that",
        "                &cLooks like this&f."
    ],
    "quest.3D5B0F83466873C0.quest_subtitle": "Magic time",
    "quest.3E00A45CE4937FB7.quest_subtitle": "Team Rocket Armor",
    "quest.3E69620A9819CA8E.quest_subtitle": "Water Armor",
    "quest.3E7E754501AAC4C9.quest_desc": [
        "             An &5Elixir&f is used to",
        "         Restore &910 PP&f to all of a",
        "               &ePokémon's&f moves."
    ],
    "quest.3E7E754501AAC4C9.quest_subtitle": "PP",
    "quest.3E83864CFB7ECBD5.quest_subtitle": "Dracozolt",
    "quest.3EE4FB856453A455.quest_subtitle": "A new type of poke balls",
    "quest.3F00B53BEA3C59F0.quest_subtitle": "Fire Axe",
    "quest.3F2C4AFDAC2DE615.quest_desc": [
        "         The &6Weakness Policy&f is a",
        "             Held &eItem&f of power.",
        "",
        "      When hit by a &cSuper Effective&f",
        "        Move, it raises &cAttack&f and",
        "        &dSp. Atk&f by &e+2 Stages&f each.",
        "",
        "    The &6Weakness Policy&f is &cconsumed&f",
        "               After activation."
    ],
    "quest.3F2C4AFDAC2DE615.quest_subtitle": "Raises Attack and Sp. Atk by 2 stages when hit by a super effective move",
    "quest.3F4AA628BE06FBFC.quest_desc": [
        "            The &dSticky Barb&f is a",
        "               Held &eItem&f of risk.",
        "",
        "       It damages the holder by &c1\/8&f",
        "          Of its max &cHP&f each turn.",
        "",
        "       If hit by contact, it transfers",
        "         To the attacker without an",
        "                   Held item."
    ],
    "quest.3F4AA628BE06FBFC.quest_subtitle": "Damages the holder each turn and transfers upon contact",
    "quest.3F73017904525896.quest_desc": [
        "      An &eEject Button&f is a held item.",
        "   If the holder takes direct damage,",
        "  It switches out and the item breaks.",
        "",
        "The Trainer chooses the next &ePokémon&f.",
        "  No effect if none are left to switch."
    ],
    "quest.3F73017904525896.quest_subtitle": "Switches the Pokémon out after it takes direct damage",
    "quest.400BCF815433D47B.quest_subtitle": "Mega Evolution Stone",
    "quest.401F30F7A72EE78D.quest_desc": [
        "        The &eEevium Z&f is a unique",
        "        &eZ-Crystal&f for &eEevee&f only.",
        "",
        "       Moves this &eZ-Crystal&f can",
        "                Transform:",
        "",
        "        &eLast Resort&f becomes the",
        "        &dExtreme Evoboost&f attack.",
        "",
        "      &7Special:&f Only an &eEevee&f can",
        "                Use this move.",
        "",
        "     &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "  Make a &aPokémon&f drop the &eZ-Crystal&f",
        "                 It is holding."
    ],
    "quest.401F30F7A72EE78D.quest_subtitle": "Eevee",
    "quest.4033F10C70284410.quest_desc": [
        "        The &5Dragonium Z&f is a unique",
        " &eZ-Crystal&f for &5Dragon-Type Pokémon&f.",
        "",
        "       Moves this &eZ-Crystal&f can",
        "                Transform:",
        "",
        "   Any &5Dragon-Type&f move that isn't a",
        "    Status move becomes the fierce",
        "         &dDevastating Drake&f attack.",
        "",
        "     &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "   Make a &aPokémon&f drop the &eZ-Crystal&f",
        "                 It is holding."
    ],
    "quest.4033F10C70284410.quest_subtitle": "Dragon-Type",
    "quest.4086349E59847D8A.quest_desc": [
        "  The &6Gimmighoul Coin&f is a TM Material",
        "          That can be crafted or",
        "              Obtained in battle.",
        "  Having &a999&f &6Gimmighoul Coins&f causes",
        "  &6Gimmighoul&f to evolve into &6Gholdengo&f",
        "      When it levels up, after which",
        "         The coins are consumed."
    ],
    "quest.4086349E59847D8A.quest_subtitle": "Gimmighoul -> Gholdengo",
    "quest.40867A82728099D4.quest_subtitle": "Ugly and weak",
    "quest.40CAA988F6F76522.quest_desc": [
        "          &dGigantamax&f is similar to",
        "              &cDynamax&f, but the",
        "        &aPokémon&f also changes form!",
        "",
        "  Only certain &aSpecies&f can &dGigantamax&f,",
        "   And within them, only special ones",
        "             Have this rare trait.",
        "",
        "  Others of the same species may only",
        "                Use &cDynamax&f.",
        "",
        "    &dGigantamax&f not only alters looks,",
        "But also grants exclusive &dG-Max Moves",
        "        Unique and powerful attacks!"
    ],
    "quest.40CAA988F6F76522.quest_subtitle": "Bigger and Stronger",
    "quest.40CAA988F6F76522.title": "Gigantamax",
    "quest.413BBCA9C41EA6C9.quest_desc": [
        "      The &6Choice Band&f is a held item.",
        "     It boosts &cAttack&f by &a50%&f, but the",
        "      &ePokémon&f can only use the first",
        "           Move it selects in battle."
    ],
    "quest.413BBCA9C41EA6C9.quest_subtitle": "Boosts Attack by 50% , but restricts the Pokémon to one move in battle",
    "quest.417E24EA8830617B.quest_subtitle": "Fire Armor",
    "quest.41A5AA4CB48A2A5D.quest_desc": [
        "         Expanding Your Exploration",
        "          &cDefeat &fa Pokémon Trainer"
    ],
    "quest.41A5AA4CB48A2A5D.quest_subtitle": "Strong",
    "quest.41B8E7222684616F.quest_desc": [
        "            The &3Beast Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "    It has a &e5× Catch Rate&f on &5Ultra",
        "     Beasts&f, but only &e1×&f on &aCelebi&f.",
        "",
        "     On all other &aPokémon&f it has a",
        "                &c0.1× Rate&f.",
        "",
        "    Unlike other &bPoké Balls&f, it never",
        "    Breaks if thrown against a block.",
        "",
        "    It can be obtained in &5Ultra Space&f,",
        "   From &dBeast Chest&f loot, &6Structures&f",
        "            In Ultra Deserts, or ",
        "          &eLegendary PokéStops&f.",
        "",
        "  Works on the following &5Ultra Beasts&f:",
        "",
        "      &5Nihilego&f        &5Pheromosa&f",
        "      &5Buzzwole&f      &5Kartana&f",
        "      &5Xurkitree&f     &5Celesteela&f",
        "      &5Guzzlord&f      &5Poipole&f",
        "      &5Naganadel&f     &5Blacephalon&f",
        "      &5Stakataka&f."
    ],
    "quest.41B8E7222684616F.quest_subtitle": "Ultra Space",
    "quest.420D563DC40280A8.quest_desc": [
        "            The &7Razor Fang&f is a",
        "             Held &eItem&f of power.",
        "",
        "      It gives attacks a &e10% Chance&f",
        "       To make foes &cFlinch&f when hit.",
        "",
        "      This does not stack with moves",
        "       That already cause &cFlinching&f.",
        "",
        "         If &dGligar&f levels up at night",
        "       While holding it, it evolves into",
        "                    &5Gliscor&f.",
        "",
        "       The &7Razor Fang&f is &cconsumed&f",
        "               During evolution."
    ],
    "quest.420D563DC40280A8.quest_subtitle": "Gives attacks a 10% chance to make foes flinch",
    "quest.424DD3FF401A6373.quest_subtitle": "Mega Evolution Stone",
    "quest.42DAF8B04F12D574.quest_desc": [
        "       &dExp. Candies&f are items that",
        "     Were added into &bPixelmon&f. Each",
        "  Candy gives a set amount of &aEXP&f,",
        "    Unlike &dRare Candies&f, which always",
        "    Give enough &aEXP&f to level up once."
    ],
    "quest.42DAF8B04F12D574.quest_subtitle": "10000 exp",
    "quest.42E047628F1B8A1F.quest_desc": [
        "             We still need &cFood&f...",
        "                 Go ahead and",
        "                 Plant a &aCrop&f!"
    ],
    "quest.42E047628F1B8A1F.quest_subtitle": "I need food",
    "quest.42EB86E736D18D6D.quest_desc": [
        "    To obtain the &cRed Chain&f, you must",
        "   First capture one of each from the",
        "            &bLake Guardian Trio&f: ",
        "          &9Azelf&f, &eUxie&f and &dMesprit&f.      ",
        "",
        "     After each one is obtained, the",
        "  Player must raise happiness to 255",
        "           And the level to 60.    ",
        "",
        "   Once this is done, the player can",
        "   Left-click a &6Ruby&f on the Guardian,",
        "      Absorbing some of its power.",
        "",
        "   This will lower the Guardian’s level  ",
        "       And the &6Ruby&f will become a:         ",
        " &aRuby of Willpower&f, &3Ruby of Knowledge&f  ",
        "Or &5Ruby of Emotion&f, depending on which.",
        "",
        " These can then be combined to form   ",
        "               The &cRed Chain&f.              ",
        " By leveling the Lake Trio back to 60, ",
        " This process can be repeated, up to   ",
        "           3 Rubies per Guardian."
    ],
    "quest.42EB86E736D18D6D.quest_subtitle": "Azelf, Uxie and Mesprit",
    "quest.42EE998460D5D30A.quest_desc": [
        "               The &eMagnet&f is a",
        "             Held &eItem&f of power.",
        "",
        "       It boosts &eElectric-type&f moves",
        "            Of its holder by &e20%&f."
    ],
    "quest.42EE998460D5D30A.quest_subtitle": "Boosts Electric-type moves",
    "quest.42FB74F763696BDA.quest_desc": [
        "          Craft the pokeball base."
    ],
