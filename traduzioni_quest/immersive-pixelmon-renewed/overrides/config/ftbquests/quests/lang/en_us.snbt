        "&eClamperl &f(holding Deep Sea Tooth) → &bHuntail",
        "&eClamperl &f(holding Deep Sea Scale) → &bGorebyss",
        "&eBoldore &f→ &bGigalith",
        "&eGurdurr &f→ &bConkeldurr",
        "&eKarrablast &f(+ Shelmet in party) → &bEscavalier",
        "&eShelmet &f(+ Karrablast in party) → &bAccelgor",
        "&eSpritzee &f(holding Sachet) → &bAromatisse",
        "&eSwirlix &f(holding Whipped Dream) → &bSlurpuff",
