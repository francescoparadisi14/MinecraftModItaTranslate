    "quest.2D5FE09AC45AE368.quest_subtitle": "Normal-Type",
    "quest.2DC299CD92BA4748.quest_desc": [
        "         &dBerry Juice&f is a held item.",
        "    It heals &a20 HP&f when the holder's",
        "       HP drops below &a50%&f in battle."
    ],
    "quest.2DC299CD92BA4748.quest_subtitle": "Heals 20 HP in battle",
    "quest.2DF1FEC2CB0EEA53.quest_desc": [
        "    After claiming an &eEgg&f, the player",
        "     Must walk with it until it hatches.",
        "",
        "     After enough &esteps&f, the Egg will",
        "    Hatch. One “step” equals the time",
        "   To walk two blocks at normal speed.",
        "",
        "      Faster travel, like &aMounting&f a",
        "  &aPokémon&f, reduces Egg steps quicker.",
        "",
        "    If a &cFlame Body&f, &cMagma Armor&f, or",
        "  &cSteam Engine&f Pokémon is in the party,",
        "      All Eggs will hatch at &e2× Speed&f.",
        "",
        "     This effect does not stack with",
        "   Multiple &cFlame Body&f or &cMagma Armor&f."
    ],
    "quest.2DF1FEC2CB0EEA53.quest_subtitle": "Hatching",
    "quest.2E0B6E71329BB6AF.quest_subtitle": "Sudowoodo → Bonsly",
    "quest.2E22FF8222967C5B.quest_desc": [
