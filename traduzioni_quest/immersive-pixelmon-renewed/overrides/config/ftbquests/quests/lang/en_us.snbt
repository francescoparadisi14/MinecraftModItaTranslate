    "quest.2F8AA6FC39AD4190.quest_subtitle": "Cook Cook",
    "quest.2F8AA6FC39AD4190.title": "Getting started",
    "quest.2F8FB6B328478B2B.quest_desc": [
        "            The &fSoothe Bell&f is a",
