    "quest.7602636C25896C29.quest_desc": [
        "        A &dPrism Scale&f is a held item.",
        "   If &eFeebas&f is traded while holding it,",
        "           It will evolve into &bMilotic&f."
    ],
    "quest.7602636C25896C29.quest_subtitle": "Feebas -> Milotic",
    "quest.763C07811B365A9A.quest_desc": [
        "         The &fSnorlium Z&f is a unique",
        "        &eZ-Crystal&f for &fSnorlax&f only.",
        "",
        "         Moves this &eZ-Crystal&f can",
        "                Transform:",
        "",
        "        &fGiga Impact&f becomes the",
        "       &dPulverizing Pancake&f attack.",
        "",
        "      &7Special:&f Only a &fSnorlax&f can",
        "               Use this move.",
        "",
        "     &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "  Make a &aPokémon&f drop the &eZ-Crystal&f",
        "                 It is holding."
    ],
    "quest.763C07811B365A9A.quest_subtitle": "Snorlax",
    "quest.764D1DBB78DE1556.quest_desc": [
        "         A &bDamp Rock&f is a held item.",
        "    It extends &9Rain Dance&f and &9Drizzle",
        "            To &a8 turns&f when used."
    ],
    "quest.764D1DBB78DE1556.quest_subtitle": "Extends the duration of Rain Dance and Drizzle to 8 turns",
    "quest.76569EC75C9B07E0.quest_desc": [
        "        The &9Ancient Great Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "     Like &9Great Balls&f, it has a &e1.5×&f",
        "    Catch Rate on all &aPokémon&f caught.",
        "",
        "   They can be obtained by &acrafting&f",
        "       Or from &eCommon&f and &6Rare&f",
        "                  &bPokéStops&f."
    ],
    "quest.76569EC75C9B07E0.quest_subtitle": "1.5x Catch",
    "quest.768AC382FB1CE72F.quest_subtitle": "Hammer or Hammer",
    "quest.76BDF51F72547D03.quest_subtitle": "Mega Evolution Stone",
    "quest.773C140D3CF463DC.quest_desc": [
        "           The &6Muscle Band&f is a",
        "             Held &eItem&f of power.",
        "",
        "       It boosts &cPhysical Moves&f of",
        "          Its holder by &e10%&f total."
    ],
    "quest.773C140D3CF463DC.quest_subtitle": "Boosts physical moves by 10%",
    "quest.7740319F4F65AF1F.quest_subtitle": "Mega Evolution Pokemon",
    "quest.77451348D7805900.quest_desc": [
        "          A &7Grip Claw&f is a held item.",
        "     It extends trapping moves to last",
        "               &a7 turns&f in battle."
    ],
    "quest.77451348D7805900.quest_subtitle": "Extends the duration of trapping moves to 7 turns",
    "quest.775609F4B9C42FE4.quest_desc": [
        "      When used in battle, it raises",
        "  The &cAttack&f, &9Defense&f, &dSpecial Attack&f,",
        "    &dSpecial Defense&f, and &bSpeed&f of a",
        "       &ePokémon&f currently in battle",
        "              By one stage each."
    ],
    "quest.775609F4B9C42FE4.quest_subtitle": "Gigantamax",
    "quest.77AD5D730308FF65.quest_desc": [
        "            To be able to craft",
        "             &6Ancient Poké Balls&f",
        "     You need to find these &dStones&f",
        "",
        "         They can be obtained by",
        "   Mining &eTumblestone Crystals&f",
        "              With a hammer.",
        "",
        "      Found in &aMountainous&f biomes,",
        "      But most abundant within the",
        "    &dUltra Plant&f biome in &5Ultra Space&f",
        "",
        "                      Or",
        "",
        "             By killing &aPokémon&f",
        "             The chance is &e10%&f",
        "",
        "           &dChimecho&f      &eChingling&f",
        "           &bGyarados&f      &bMantine&f",
        "           &bMantyke&f."
    ],
    "quest.77AD5D730308FF65.quest_subtitle": "Kill some Pokemon",
    "quest.77AF0C864FBDB200.quest_desc": [
        "            The &fZoom Lens&f is a",
        "           Held &eItem&f of support.",
        "",
        "      It boosts &bAccuracy&f of moves",
        "          By &e+20%&f, but only if the",
        "        Holder moves &clast&f in turn."
    ],
    "quest.77AF0C864FBDB200.quest_subtitle": "Boosts accuracy by 20% if the holder moves last",
    "quest.77C70E266679ACEB.quest_subtitle": "Mega Evolution Pokemon",
    "quest.77E7055CE1E7723D.quest_desc": [
        "   It is possible to skip &e1 Requirement&f",
