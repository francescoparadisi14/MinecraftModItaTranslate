    "quest.6E9547D3C1B62436.quest_subtitle": "Ready for combat?",
    "quest.6EBC0970FB193A7A.quest_subtitle": "Mega Evolution Stone",
    "quest.6F0EBD7B73B785D1.quest_desc": [
        "          &dDitto&f can breed with any",
        "       &aPokémon&f except those in the",
        "          &5Undiscovered Egg Group&f.",
        "",
        "     Compatibility ignores gender —",
        "      &bMale&f, &dFemale&f, and &7Genderless&f",
        "      Pokémon can all breed with it.",
        "",
        "   This is the only way for &7Genderless",
        "           Pokémon&f to reproduce.",
        "",
        "       If two &dDitto&f breed together,",
        "  The Egg will hatch a random &aPokémon&f.",
        "     Some evolved forms may appear,",
        " But &6Legendary Pokémon&f cannot hatch.",
        "",
        "               Pokémon in the",
        "        &5Undiscovered Egg Group&f",
        " Cannot breed with any other Pokémon,",
        "      Including &dDitto&f or themselves.",
        "",
        "  Certain species need &eIncense&f items:",
        "   For example, &cSnorlax&f requires a",
        "  &eFull Incense&f to produce &aMunchlax&f.",
        " Without it, the Egg hatches as Snorlax.",
        "",
        "           Special cases include:",
        "&dNidoran♀&f breeding, or &dNidoran♂&f,",
        "&dNidorino&f, or &dNidoking&f with Ditto",
        "→ Egg may contain &dNidoran♀&f or &dNidoran♂&f.",
        "&dIllumise&f breeding, or &dVolbeat&f with Ditto",
        "→ Egg may contain &dIllumise&f or &dVolbeat&f."
    ],
    "quest.6F0EBD7B73B785D1.quest_subtitle": "Power of the ditto",
    "quest.6F0EBD7B73B785D1.title": "Ditto",
    "quest.6F207D775B43CF05.quest_desc": [
        "             The &7Light Clay&f is a",
        "            Held &eItem&f of support.",
        "",
        "         It extends the duration of",
        "         &eReflect&f, &bLight Screen&f, and",
        "           &bAurora Veil&f to a total",
        "                  Of &e8 turns&f."
