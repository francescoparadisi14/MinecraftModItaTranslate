    "quest.1FCA90013A2920E9.quest_subtitle": "Mega Evolution Pokemon",
    "quest.204F954C2AB2D815.quest_desc": [
        "              The &8Iron Ball&f is a",
        "            Held &eItem&f that alters",
        "",
        "       It halves the holder's &bSpeed&f",
        "     And removes immunity to &6Ground&f",
        "                 Type attacks."
    ],
    "quest.204F954C2AB2D815.quest_subtitle": "Halves the holder's Speed and removes immunity to Ground attacks",
    "quest.20C5F4922209B44D.quest_desc": [
        "             The &cRepeat Ball&f is a",
        "          Special type of &bPoké Ball&f",
        "",
        "   It has a &e3.5× Catch Rate&f when used",
        "      On &aPokémon&f species already",
        "          Owned by the Trainer.",
        "",
        "     It can be obtained by &acrafting&f,",
        "   Buying from a &eShopkeeper&f, or as",
        "            A &6Tier 1 Special Drop&f."
    ],
    "quest.20C5F4922209B44D.quest_subtitle": "Increases the chance by 3.5x for Pokémon you already have",
    "quest.21112D2CAF44CEB8.quest_subtitle": "Mega Evolution Pokemon",
    "quest.213819886D5B12BB.quest_subtitle": "&aSpecial Defense &8\/ &cAttack",
    "quest.217FF6F24F0DE91D.quest_subtitle": "Magma Armor",
    "quest.21D3CD7B659BF953.quest_subtitle": "Dawn Hammer",
    "quest.22455220087AEBC9.quest_subtitle": "Mega Evolution Pokemon",
    "quest.228696739F9DCD9F.quest_subtitle": "&a+ Attack &8\/ &cSpecial Attack",
    "quest.22963FEEC8E116AE.quest_desc": [
        "       You must be asking yourself",
        "        \"&eWhy&f do I have to eliminate",
        "                 A &bMagikarp&f?\"",
        "",
        "     I don't know either... I'm just not",
        "            Much of a fan of it. &c:)&f."
    ],
    "quest.22963FEEC8E116AE.quest_subtitle": "Magikarp?",
    "quest.22B8A2068409F3CD.quest_subtitle": "Protection IV + Projectile Protection IV",
    "quest.22BB32FA90FD95DD.quest_desc": [
        "          &ePoké Balls&f are the most",
        "        &6Important&f part of Pixelmon",
        "",
        "         With them we can capture",
        "                &aNew Pokémon&f.",
        "",
        "      There are several &bPoké Balls&f",
        "      Each with a brief description",
        "         Of their unique bonuses",
        "",
        "            &dWe will also&f teach",
        "          How to automate this."
    ],
    "quest.22BB32FA90FD95DD.quest_subtitle": "Behind the poke balls",
    "quest.22BB32FA90FD95DD.title": "Poké Balls",
    "quest.22BD86C7BCD1023D.quest_desc": [
        "            The &5Poison Barb&f is a",
        "             Held &eItem&f of power.",
        "",
        "       It boosts &5Poison-type&f moves",
        "            Of its holder by &e20%&f."
    ],
    "quest.22BD86C7BCD1023D.quest_subtitle": "Boosts Poison-type moves",
    "quest.2326B61FA7FCB66C.quest_subtitle": "Hammer or Hammer",
    "quest.233A02E3F0ED51DA.quest_desc": [
        "       &dExp. Candies&f are items that",
        "     Were added into &bPixelmon&f. Each",
        "  Candy gives a set amount of &aEXP&f,",
        "    Unlike &dRare Candies&f, which always",
        "    Give enough &aEXP&f to level up once."
    ],
    "quest.233A02E3F0ED51DA.quest_subtitle": "100 exp",
    "quest.2385AF0FD354E90B.quest_subtitle": "Mega Evolution Pokemon",
    "quest.24455FFC4A539139.quest_desc": [
        "              The &6GS Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "    It has a &e1× Catch Rate&f, the same",
        "           As a normal &bPoké Ball&f.",
        "",
        "    Unlike others, the &6GS Ball&f never",
        "   Breaks if thrown against a block.",
        "",
        "   It can be used on an &2Ilex Shrine&f",
        "     To summon the Mythical &aCelebi&f.",
        "",
        "   It can be obtained as desert loot,",
        "   From a &ePyramid&f (not Ultra Desert),",
        "  As a quest reward: &dForest Guardian&f,",
        "   Or as a rare drop from wild &aCelebi&f."
    ],
    "quest.24455FFC4A539139.quest_subtitle": "Celebi",
    "quest.2446990AE14CF249.quest_subtitle": "Mega Evolution Pokemon",
    "quest.24640E359F1E97BD.quest_subtitle": "&aSpecial Defense &8\/ &cDefense",
    "quest.24C8B7ED9FFF085F.quest_desc": [
        "              These items need",
        "         To be held by a &6Pokémon, ",
        "   And it usually needs to be &etraded",
        "        &bFor the evolution to occur&f.",
        "",
        "        If you don't have a friend",
        "               Use &b\/tradesim&f."
    ],
    "quest.24C8B7ED9FFF085F.quest_subtitle": "Evolution Trades",
    "quest.24F721513991435C.quest_subtitle": "Strengthening your team",
    "quest.2515FD0BE0475685.quest_subtitle": "Leaf Hoe",
    "quest.2521E00276B37586.quest_desc": [
        "     The &8Marshadium Z&f is a unique",
        "    &eZ-Crystal&f for &8Marshadow&f only.",
        "",
        "       Moves this &eZ-Crystal&f can",
        "                Transform:",
        "",
        "   &8Spectral Thief&f becomes the",
        " &dSoul-Stealing 7-Star Strike&f attack.",
        "",
        "    &7Special:&f Only a &8Marshadow&f can",
        "                Use this move.",
        "",
        "     &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "  Make a &aPokémon&f drop the &eZ-Crystal&f",
        "                 It is holding."
    ],
    "quest.2521E00276B37586.quest_subtitle": "Marshadow",
    "quest.2531BAACA19B8E5B.quest_subtitle": "Dusk Sword",
    "quest.2531C5820A1F0ED5.quest_subtitle": "&aSpecial Attack &8\/ &cDefense",
    "quest.253B12D158447212.quest_desc": [
        "             The &fShed Shell&f is a",
        "             Held &eItem&f of escape.",
        "",
        "        It lets a &aPokémon&f switch out",
        "       Even when trapped by &cmoves&f",
        "                 Or by &dAbilities&f."
    ],
    "quest.253B12D158447212.quest_subtitle": "Allows the Pokémon to switch out even when trapped",
    "quest.257D045F26C41606.quest_desc": [
        "  The &dLinking Cord&f is an evolutionary",
        "    Item that allows the evolution of ",
        "                  &ePokémon&f",
        "That normally evolve when traded. It is",
        "          Consumed when used. ",
        "            It can be obtained",
        " As a &aTier 2 special drop&f or from rare",
        "           Tier boss &ePokémon&f.",
        "",
        "    The following evolutions can be",
        "      Achieved with a &dLinking Cord&f:",
        "",
        "&ePoliwhirl &f(holding King's Rock) → &bPolitoed",
        "&eKadabra &f→ &bAlakazam",
        "&eMachoke &f→ &bMachamp",
        "&eGraveler &f→ &bGolem",
        "&eAlolan Graveler &f→ &bAlolan Golem",
        "&eSlowpoke &f(holding King's Rock) → &bSlowking",
        "&eHaunter &f→ &bGengar",
        "&eOnix &f(holding Metal Coat) → &bSteelix",
        "&eRhydon &f(holding Protector) → &bRhyperior",
        "&eSeadra &f(holding Dragon Scale) → &bKingdra",
        "&eScyther &f(holding Metal Coat) → &bScizor",
        "&eElectabuzz &f(holding Electirizer) → &bElectivire",
        "&eMagmar &f(holding Magmarizer) → &bMagmortar",
        "&ePorygon &f(holding Upgrade) → &bPorygon2",
        "&ePorygon2 &f(holding Dubious Disc) → &bPorygon-Z",
        "&eFeebas &f(holding Prism Scale) → &bMilotic",
