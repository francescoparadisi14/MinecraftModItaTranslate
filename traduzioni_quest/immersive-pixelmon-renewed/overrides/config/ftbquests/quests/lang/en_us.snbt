    ],
    "quest.32396FCE65518A3C.quest_subtitle": "HP",
    "quest.323FD870865BC2D1.quest_subtitle": "&aSpecial Defense &8\/ &cSpeed",
    "quest.32A32FDBFF9E5A69.quest_desc": [
        "    The &bResist Feather&f is a type of",
        "  Medicine that increases the &9Defense",
        "     EV&f of a &ePokémon&f by &a1&f if you",
        "    Right-click it, consuming the item",
        "                   Upon use."
    ],
    "quest.32A32FDBFF9E5A69.quest_subtitle": "Defence EV",
    "quest.32C37C95065F6EB8.quest_desc": [
        "       A &6Focus Sash&f is a held item.",
