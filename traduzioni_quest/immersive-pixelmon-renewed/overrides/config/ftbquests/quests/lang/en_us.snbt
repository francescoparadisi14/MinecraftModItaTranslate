    "quest.51CF9951BF0BC90A.quest_subtitle": "Raises Sp. Defense when hit by a Water-type move",
    "quest.51D475023A8389F9.quest_subtitle": "Moon Armor",
    "quest.51EB52D315EEAF7B.quest_desc": [
