    "quest.2823A69EA3F7909A.quest_subtitle": "Fire Hoe",
    "quest.2846D8B7B787023D.quest_desc": [
        "         A &6Full Heal&f is a type of",
        "   Medicine used to &cremove all status",
        "    &fAilments from a &ePokémon&f. This",
        "   Includes sleep, paralysis, poison,",
        "      Burn, freeze, and confusion."
    ],
    "quest.2846D8B7B787023D.quest_subtitle": "&eGOD",
    "quest.28EF0B9767F4E3D7.quest_desc": [
        "         The &aOrb&f of &bStatic Souls&f is      ",
        "   An item that can be used to spawn   ",
        "                   &eZapdos&f.              ",
        "",
        "To do so, the &aorb&f needs to be charged",
        "  By defeating &6375&f &dPokémon&f while the  ",
        "  &aOrb&f is in the player's inventory and   ",
        "      Then used on a &cStatic Shrine&f.    ",
        "",
        "   The &dPokémon&f defeated do not have",
        "       To be &9Electric&f-type &dPokémon&f. ",
        "             ",
        " The remaining number of &dPokémon&f to",
        "  Defeat can be displayed by using the",
        "                      &aOrb&f."
    ],
    "quest.28EF0B9767F4E3D7.quest_subtitle": "Zapdos",
    "quest.28F9B1F2FE7D789F.quest_desc": [
        "         The &cFirium Z&f is a unique",
        "  &eZ-Crystal&f for &cFire-Type Pokémon&f.",
        "",
        "       Moves this &eZ-Crystal&f can",
        "                Transform:",
        "",
        "    Any &cFire-Type&f move that isn't a",
        "   Status move becomes the fierce",
        "        &dInferno Overdrive&f attack.",
        "",
        "     &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "  Make a &aPokémon&f drop the &eZ-Crystal&f",
        "                 It is holding."
    ],
    "quest.28F9B1F2FE7D789F.quest_subtitle": "Fire-Type",
    "quest.296FDD1D86D44FEE.quest_desc": [
        "       &6Choice Specs&f are a held item.",
        "   They boost &dSp. Atk&f by &a50%&f, but the",
        "      &ePokémon&f can only use the first",
        "          Move it selects in battle.",
        "",
        "If the move runs out of PP or can't be",
        "     Used, the &ePokémon&f will Struggle."
    ],
    "quest.296FDD1D86D44FEE.quest_subtitle": "Boosts Sp. Atk by 50% , but restricts the Pokémon to one move",
    "quest.29835424E0F77013.quest_subtitle": "Arctozolt",
    "quest.2A170C3184EB1AAE.quest_subtitle": "Leaf Armor",
    "quest.2A3C64B6B9608791.quest_desc": [
        "                In long battles,",
        "            Your best ally is the",
        "               &bRecovery item&f.",
        "",
