    "quest.2F594DCCA545F9BD.quest_desc": [
        "   Held items are things that &ePokémon&f",
        " Can hold for battle use or to evolve",
        "              Specific &ePokémon&f.",
        "",
        " Some &ePokémon&f can be caught already",
        "                Holding an item."
