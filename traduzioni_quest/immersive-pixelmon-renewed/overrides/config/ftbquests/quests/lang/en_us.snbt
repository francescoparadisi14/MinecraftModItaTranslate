    "quest.15346ADE09609A6E.quest_subtitle": "Boosts Defense when entering Electric Terrain",
    "quest.153E0999D7751AB4.quest_desc": [
        "           &cUnfortunately&f, we are",
        "            Still inside &aMinecraft&f...",
        "",
        "          Gather &e4 Wood&f to begin",
        "                Your journey."
    ],
    "quest.153E0999D7751AB4.quest_subtitle": "It's still Minecraft",
    "quest.1587D2929B7786F9.quest_desc": [
        "            The &7Hard Stone&f is a",
        "            Held &eItem&f that boosts",
        "",
        "      The power of &8Rock-type&f moves",
        "            Of its holder by &e20%&f."
    ],
    "quest.1587D2929B7786F9.quest_subtitle": "Boosts Rock-type moves",
    "quest.15ED81273E91F4BF.quest_desc": [
        "        The &bAzure Flute&f is an item      ",
        " That is received when completing the  ",
        "         &aArc Chalice&f requirements.        ",
        "",
        "  After obtaining the &bAzure Flute&f, the  ",
        "   Player can, when within range of a    ",
        "     &cTimespace Altar&f, right click with  ",
        "        The flute in-hand to play it.      ",
        "",
        "  However, if you right-click the &cAltar&f  ",
        " While holding the flute, it will not work.",
        "",
        "    Once this is completed, a short",
        "   Animation will play and &eArceus&f will  ",
        "         Rise from the ground.             ",
        "",
        "   Once fully risen, it will attack the  ",
        " Player immediately unless the player  ",
        " Has no &dPokémon&f able to battle, where  ",
        "    &eArceus&f will instead roam around."
    ],
    "quest.15ED81273E91F4BF.quest_subtitle": "Arceus",
    "quest.16072D9D43A16A88.quest_desc": [
        "              An orb is an item",
        "         That is used to craft the",
        "               Three different",
        "          Orbs needed to spawn ",
        "      &bArticuno&f, &eZapdos&f, and &cMoltres ",
        "      From their respective shrines."
    ],
    "quest.16072D9D43A16A88.quest_subtitle": "Legendary",
    "quest.161531631E3EE761.quest_subtitle": "The God of everything",
    "quest.161FA7A9E502C0A1.quest_desc": [
        "      The &dAbility Patch&f is a type of",
        "   Medicine that changes a &ePokémon's&f",
        "     Ability from one of its standard",
        "        Abilities to its &dHidden Ability&f.",
        "",
        "     It cannot be used to change a",
        "    &ePokémon's&f Ability from its &dHidden",
        "   Ability&f to one of its standard ones."
    ],
    "quest.161FA7A9E502C0A1.quest_subtitle": "Hidden Ability",
    "quest.1644332B20629256.quest_desc": [
        "          The &aEnergy Powder&f is a",
        "          Special type of &2Medicine&f.",
        "",
        "     It restores &c50 HP&f to a &aPokémon&f,",
        "          Just like a &9Super Potion&f.",
        "",
        "     However, it lowers the &dHappiness&f",
        "       By &e5&f or &e10&f depending on how",
        "             Much it had initially."
    ],
    "quest.1644332B20629256.quest_subtitle": "HP \/ Happiness",
    "quest.16C6F0764A897F2B.quest_desc": [
        "         The &bFlyinium Z&f is a unique",
        "  &eZ-Crystal&f for &bFlying-Type Pokémon&f.",
        "",
        "       Moves this &eZ-Crystal&f can",
        "                Transform:",
        "",
        "    Any &bFlying-Type&f move that isn't a",
        "   Status move becomes the fierce",
        "       &dSupersonic Skystrike&f attack.",
        "",
        "     &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "  Make a &aPokémon&f drop the &eZ-Crystal&f",
        "                 It is holding."
    ],
    "quest.16C6F0764A897F2B.quest_subtitle": "Flying-Type",
    "quest.17099396C382FCA1.quest_desc": [
        "       A &dSweet Apple&f is an item that",
        "     Can evolve &6Applin&f into &6Appletun&f.",
        "       It can be held by wild &6Applin&f.",
        "  It can also be obtained by using the",
        "    External move &aHeadbutt&f against a",
        "                     Tree."
    ],
    "quest.17099396C382FCA1.quest_subtitle": "Applin -> Appletun",
    "quest.1711D2D366414EC3.quest_subtitle": "Mega Evolution Pokemon",
    "quest.172A74BDEEEAE445.quest_desc": [
        "    Now that we’ve crafted our first",
        "                  &bPoké Balls&f...",
        "",
        "       It’s time to go after our very",
        "                First &aPokémon&f!"
    ],
    "quest.172A74BDEEEAE445.quest_subtitle": "Ready to capture",
    "quest.1773B85255A9F3EB.quest_subtitle": "Mega Evolution Pokemon",
    "quest.178148BB01A9F7F4.quest_subtitle": "Mega Evolution Pokemon",
    "quest.17E7E841878570A1.quest_desc": [
        "     A &cMacho Brace&f is a held item for",
        "      &ePokémon&f. It doubles gained &aEVs&f",
        "   From defeated &ePokémon&f, but halves",
        "          The holder's &bSpeed&f stat."
    ],
    "quest.17E7E841878570A1.quest_subtitle": "+ EV",
    "quest.1819088AA7AFA219.quest_subtitle": "New equipment",
    "quest.181CBFD6E8E611F5.quest_subtitle": "Shovel",
    "quest.1830CD8AE4D6BD7E.quest_subtitle": "Thunder Armor",
    "quest.18475AB2584DF4AE.quest_subtitle": "Team armor",
    "quest.191B2A99EBAE96BC.quest_subtitle": "Sun Armor",
    "quest.1920059C67237168.quest_desc": [
        "       For two compatible &aPokémon&f to",
        "           Successfully &dBreed&f, they",
        "        Must be given the right &eItems&f.",
        "",
        "     There are &e3 Item Requirements&f",
        "  For each type by default. A &aPokémon&f",
        "  Only needs items of its &dPrimary Type&f.",
        "",
        "    Example: &5Gastly&f requires only the",
        "      &5Ghost-type&f items for breeding.",
        "",
        "     If you breed two pairs of &5Gastly&f,",
        "     You will need &etwice&f the amount of",
        "            Items compared to one.",
        "",
        "",
        "{image:lupin:textures\/quests\/daycare_requirements.png width:160 height:100 align:center}",
        "",
        "",
        "      Once both &aPokémon&f have the",
        "     Necessary &eItems&f supplied, the",
        "   Breeding starts with a &aGreen Tick&f.",
        "",
        "    By default, the process takes a",
        "             Total of &e1.5 Hours&f.",
        "",
        "   You may leave the &eDay Care&f while",
        "      It runs. Meanwhile, open your",
        "                  &bInventory&f",
        "     To check how your &dBreedings",
        "                  &fAre going."
    ],
    "quest.1920059C67237168.quest_subtitle": "Blocks",
    "quest.1920059C67237168.title": "Breeding process",
    "quest.1928328F0ADCAFB1.quest_subtitle": "Special Defense",
    "quest.1960544741EA1D09.quest_subtitle": "Mega Evolution Pokemon",
    "quest.196399206D8855B2.quest_subtitle": "Mega Evolution Stone",
    "quest.1A828EB3DAC0DB2A.quest_subtitle": "&aDefense &8\/ &cSpeed",
    "quest.1A854E14575323D8.quest_desc": [
        "          The &aArc Chalice&f is found     ",
        "     In a special structure that can     ",
        "     Rarely generate in &2Extreme Hills&f  ",
        " (Forge) biomes in the ruined villages  ",
        "   And in &3Ocean&f (Forge) biomes in the   ",
        "                Ocean temple.              ",
        "",
        "   It is used to obtain the &bAzure Flute&f,  ",
        "     Which is used in obtaining \"&dThe",
        "           Original One&f\", &eArceus&f.         ",
        "",
        "   N order for the &aArc Chalice&f to be",
        "  Utilized, the player must first obtain",
        "       A &6Plate&f for each &dPokémon&f",
        "            Typing, 18 in total.  ",
        "",
        " After each &6Plate&f has been obtained,    ",
        "    You can right-click on the &aCálice&f",
        "    With one of each &6Plate&f, which will     ",
        " Result in a special particle effect and  ",
        "A chat message showing plates needed.",
        "    After each &6Plate&f is added to the ",
        "   &aChalice&f, the floating orbs will spin    ",
        "   And move toward the middle of the         ",
        " &aChalice&f. Once this is done, there will  ",
        " Be an explosion sound and a glowing      ",
        "      &bAzure Flute&f will appear atop      ",
        "              The &aArc Chalice&f."
    ],
    "quest.1A854E14575323D8.quest_subtitle": "Arceus",
    "quest.1AA0948C9E3B08B3.quest_desc": [
        "       A &6Focus Band&f is a held item.",
        " It has a &a10%&f chance to let the holder",
        "  Survive with &c1 HP&f instead of fainting.",
        "          Does not prevent self-KO",
        "                Moves such as",
        "    Explosion, Healing Wish, Memento, or",
        "                 Selfdestruct."
    ],
    "quest.1AA0948C9E3B08B3.quest_subtitle": "Gives a 10% chance to survive a fatal hit with 1 HP",
    "quest.1AB1B847574691C1.quest_desc": [
        "              The &eFast Ball&f is a",
        "          Special type of &bPoké Ball&f",
        "",
        "   It has a &e4× Catch Rate&f when used",
        "   On &aPokémon&f with base Speed ≥ &e100&f.",
        "",
        "     It can be obtained by &acrafting&f,",
        "   Buying from a &eShopkeeper&f, or as",
        "            A &6Tier 1 Special Drop&f."
    ],
    "quest.1AB1B847574691C1.quest_subtitle": "Increases the capture rate according to the speed of the pokemon",
    "quest.1AF1B78FA61692EC.quest_subtitle": "New Poke balls",
    "quest.1AFBB68957894DFB.quest_desc": [
        "   A \"&dNature&f\" Of a &bPokémon&f is a trait    ",
        "  That increases one stat by 10% and",
        "       Decreases another by 10%.       ",
        "",
        "   For example, the &dNature&f \"&6Adamant&f\"    ",
        " Increases &cAttack&f and lowers &aSpecial     ",
        "    &aAttack&f, great for &bPokémon&f using",
        "              Physical moves.               ",
        "",
        "     The &dNature&f \"&9Modest&f\" Increases",
        "    &aSpecial Attack&f and lowers &cAttack&f,     ",
        "Ideal for those that use special moves."
    ],
    "quest.1AFBB68957894DFB.quest_subtitle": "What is nature?",
    "quest.1B0495E73149B7D5.quest_desc": [
        "                    &eTrainer&f",
        "         These &6items&f are &eessential&f",
        "             For your &djourney&f.",
        "",
        "          They don't just serve",
        "              To heal your &cHP&f,",
        "        But also to modify &eStatus&f",
        "    That can turn the tide of a &6battle&f."
    ],
    "quest.1B0495E73149B7D5.quest_subtitle": "Healing items",
    "quest.1B677563F3F51EC3.quest_desc": [
        "        The &aGreen Flute&f is an item",
        "           That restores &a20 HP&f."
    ],
    "quest.1B677563F3F51EC3.quest_subtitle": "HP",
    "quest.1B89302B547954FF.quest_subtitle": "Many Pokémon",
    "quest.1BADD20E0340628B.quest_subtitle": "Use 500 attacks during all your Pokémon battles",
    "quest.1BDB52F70BF2182B.quest_subtitle": "Mega Evolution Stone",
    "quest.1BE2F2F6A992C6F1.quest_subtitle": "Archen",
    "quest.1C1A9DE565CA0E64.quest_desc": [
        "       A &9Dragon Scale&f is a held item.",
