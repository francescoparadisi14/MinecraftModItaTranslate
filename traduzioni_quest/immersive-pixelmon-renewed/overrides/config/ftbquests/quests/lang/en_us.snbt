    "quest.369607026C329054.quest_desc": [
        "               This is the guy,",
        "           The &6Stephen Curry&f of",
        "                   Machines.",
        "",
        "            Let's take our &9fossil",
        "         And put it in this &9machine&f.",
        "",
        "    You're probably asking yourself,",
        "             \"Is that all?\" Yes.",
        "          Lol... Pixelmon is really",
        "            \"simple\" (for now).",
        "",
