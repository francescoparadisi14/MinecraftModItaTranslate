    "quest.15303F8F529FE576.quest_subtitle": "Break eggs",
    "quest.15346ADE09609A6E.quest_desc": [
        "      An &eElectric Seed&f is a held item.",
        "      It boosts the holder's &9Defense&f",
        "      When entering &eElectric Terrain&f.",
        "      The item is consumed on entry,",
        "     Unless &9Defense&f is already maxed."
