    "quest.34AECC53232F1BCB.quest_subtitle": "Ghost-Type",
    "quest.35831F48222CCABE.quest_subtitle": "Sword",
    "quest.358A487CDC989A96.quest_subtitle": "The time controller",
    "quest.35C3EB1686DDBDA6.quest_desc": [
        "      A &eShiny Stone&f is an evolution",
