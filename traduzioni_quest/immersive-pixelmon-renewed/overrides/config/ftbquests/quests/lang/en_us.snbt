    "file.0000000000000001.title": " Immersive Pixelmon",
    "quest.0012C37A9B88EB79.quest_subtitle": "Fire Resistance + Fire Protection II",
    "quest.00266F394D62D47B.quest_desc": [
        "           &cRelease some Pokémon ",
        "                 Into the wild",
        "     And complete your daily quest."
    ],
    "quest.00266F394D62D47B.quest_subtitle": "Let your Pokémon roam free.",
    "quest.0051855954EEFDD2.quest_subtitle": "Chimecho → Chingling",
    "quest.0058240B6EE18F91.quest_desc": [
        "        A &2Leaf Stone&f is a type of",
        "    Evolution stone used to evolve",
        "      Certain species of &ePokémon&f.",
        "",
        "    &2Leaf Stone&f can be used for the",
        "            Following evolutions:",
        "",
        "          &6Gloom &f→ &6Vileplume",
        "          &6Weepinbell &f→ &6Victreebel",
        "          &6Exeggcute &f→ &6Exeggutor ",
        "          &fOr &6Alolan Exeggutor",
        "          &6Eevee &f→ &6Leafeon",
        "          &6Nuzleaf &f→ &6Shiftry",
        "          &6Pansage &f→ &6Simisage."
    ],
    "quest.0058240B6EE18F91.quest_subtitle": "Plant type",
    "quest.006BBAEE75BB40D3.quest_subtitle": "Mega Evolution Pokemon",
    "quest.00C6359C983B2F76.quest_desc": [
        "              The &dLove Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "   It has an &e8× Catch Rate&f when used",
        "    On the same species &aPokémon&f of",
        "    Opposite gender to the player's.",
        "",
        "     It can be obtained by &acrafting&f,",
        "   Buying from a &eShopkeeper&f, or as",
        "            A &6Tier 1 Special Drop&f.",
        "",
        "         It is also dropped by wild",
        "                   &dGranbull&f."
    ],
    "quest.00C6359C983B2F76.quest_subtitle": "Increases the capture rate for Pokémon of the same type by 8.0",
    "quest.00E597B174FE8343.quest_subtitle": "Magma Armor",
    "quest.01263A96A5538740.quest_desc": [
        "       A &8Griseous Orb&f is a held item.",
        "      It boosts &6Giratina's&f Ghost- and",
        "    Dragon-type moves by &a20%&f power.",
        "      If &6Giratina&f holds it, it changes",
        "        Into Origin Forme in battle.",
        "     Has no effect on other &ePokémon&f.",
        "",
        "    Used on a &cTimespace Altar&f with a",
        "      &cRed Chain&f, it summons &6Giratina&f."
    ],
    "quest.01263A96A5538740.quest_subtitle": "Boosts Giratina's Ghost- and Dragon-type moves. It also changes Giratina to Origin Forme in battle",
    "quest.015DB3993598C4D4.quest_desc": [
        "          A &fCalcium&f is a type of",
        "   Medicine that adds &a10 Sp. Atk EVs&f",
        "    To a &ePokémon&f if possible. It also",
        "   Raises a &ePokémon's&f happiness by",
        "      &a5&f, &a3&f, or &a2&f depending on how",
        "     Much happiness it initially has."
    ],
    "quest.015DB3993598C4D4.quest_subtitle": "Sp. Attack EVs \/ Happiness",
    "quest.017991E54E435197.quest_subtitle": "Fire Hammer",
    "quest.017D9EDE8B28F90F.quest_desc": [
        "         The &6Ancient Ultra Ball&f is a",
        "          Special type of &bPoké Ball&f",
        "",
        "       Like &eUltra Balls&f, it provides a",
        "      &e2.0× Catch Rate&f on all &aPokémon&f."
    ],
    "quest.017D9EDE8B28F90F.quest_subtitle": "A different Ultra Ball",
    "quest.01CBF28DD8C7872E.quest_desc": [
        "             The &7Metal Coat&f is a",
        "             Held &eItem&f of power.",
        "",
        "      It boosts &7Steel-type&f moves by",
        "                      &e1.2×&f.",
        "",
        "      If &aScyther&f or &7Onix&f hold it while",
        "    Being traded, they will evolve into",
        "              &cScizor&f and &7Steelix&f.",
        "",
        "        The &7Metal Coat&f is &cconsumed&f",
        "               During the trade."
    ],
    "quest.01CBF28DD8C7872E.quest_subtitle": "Boosts Steel-type moves and evolves Scyther or Onix when traded",
    "quest.01F7A8552F22030F.quest_subtitle": "Base of our poke ball",
    "quest.0219E17F8A9B55C0.quest_desc": [
        "            The &dDream Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "       It has a &e4× Catch Rate&f when",
        "         Used on sleeping &aPokémon&f.",
        "",
        "   Unlike other &bPoké Balls&f, the &dDream",
        "  Ball&f never breaks if thrown against",
        "                   Any block."
    ],
    "quest.0219E17F8A9B55C0.quest_subtitle": "4x Catch rate for pokemon in sleep",
    "quest.0221AB25927FCDC8.quest_subtitle": "Neo Plasma Armor",
    "quest.02302D297D15003C.quest_subtitle": "Amaura",
    "quest.02CB1AEA017FBC6B.quest_subtitle": "Omanyte",
    "quest.02DCC2340EBB02A5.quest_subtitle": "Mega Evolution Pokemon",
    "quest.02E272EDA2797B75.quest_subtitle": "Pokemon of the future",
    "quest.0306EE2235FDEBAE.quest_desc": [
        "      Place &e3 Blocks&f into the &dCloning",
        "    Machine&f and after a few seconds,",
        "       A &5Mewtwo&f or a &dDitto&f appears.",
        "",
        "       If a &5Mewtwo&f is created, it will",
        "    Destroy the &6Orange Tank&f, leaving",
        "   The machine unusable. It then acts",
        "      As a wild &5Mewtwo&f to be battled.",
        "",
        "    If a &dDitto&f is created, the machine",
        "     Remains intact. Right-click it to",
        "   Battle. If destroyed before battle,",
        "      The &dDitto&f will be lost forever.",
        "",
        "     In either case, &dMew&f returns to",
        "  The player’s party once the clone",
        "            Leaves the machine.",
        "",
        "  Each &dMew&f may be used only &e3 Times&f",
        "          With the &dCloning Machine&f."
    ],
    "quest.0306EE2235FDEBAE.quest_subtitle": "Machine",
    "quest.030E0D3AA4B7DE4D.quest_desc": [
        "        It's a &bRevive&f, but it restores",
        "    All of the &ePokémon's&f HP. That's why",
        "                   The &dmax&f."
    ],
    "quest.030E0D3AA4B7DE4D.quest_subtitle": "MAX REVIVE",
    "quest.034CBF2BB2428D4A.quest_desc": [
        "          &cDynamax&f allows &aPokémon&f",
        "          To grow into giant forms!",
        "",
        "      While &cDynamaxed&f, they can use",
        "      &dMax Moves&f — powerful attacks",
        "      With extra secondary effects.",
        "",
        "     Every &eStatus Move&f becomes the",
        "               &eMax Guard&f move."
    ],
    "quest.034CBF2BB2428D4A.quest_subtitle": "Time to become a Giant",
    "quest.0355B467CFBF5269.quest_desc": [
        "     A &eThunder Stone&f is an evolution",
        "   Stone that can be obtained through",
        "        Crafting, fishing, and more.",
        "",
        "  &eThunder Stone&f can be used for the",
        "            Following evolutions:",
        "",
        "       &6Pikachu &f→ &6Raichu &for &6Alolan Raichu",
        "       &6Magneton &f→ &6Magnezone",
        "       &6Eevee &f→ &6Jolteon",
        "       &6Eelektrik &f→ &6Eelektross",
        "       &6Charjabug &f→ &6Vikavolt."
    ],
    "quest.0355B467CFBF5269.quest_subtitle": "Thunder type",
    "quest.038252FD4B697DFE.quest_subtitle": "Mega Evolution Stone",
    "quest.03826599210F6AEB.quest_desc": [
        "        A &6Binding Band&f is a held item.",
        " It boosts damage from trapping moves.",
        "",
        "     Bind, Clamp, Fire Spin, Infestation,",
        "      Sand Tomb, Whirlpool, and Wrap.",
        "",
        "     The residual damage goes from &a⅛&f."
    ],
    "quest.03826599210F6AEB.quest_subtitle": "Increases damage from trapping moves",
    "quest.03C47F371DF532DE.quest_desc": [
        "           &bLevel up your &ePokémon",
        "                  By &d15 levels&f."
    ],
    "quest.03C47F371DF532DE.quest_subtitle": "Time to put it into practice",
    "quest.03C47F371DF532DE.title": "Level Up",
    "quest.03C9D280FF1EFB88.quest_desc": [
        "       An &fOval Stone&f is a held item",
        "        For &6Happiny&f. If a &6Happiny&f",
        " Levels up in the daytime while holding",
        "    An &fOval Stone&f, it will evolve into",
        "  &6Chansey&f, consuming the item in the",
        "                   Process."
    ],
    "quest.03C9D280FF1EFB88.quest_subtitle": "Happiny -> Chansey",
    "quest.04055BFFF6CCD552.quest_desc": [
        "       A &dHyper Potion&f is a type of",
        "     Medicine used to heal a &ePokémon&f",
        "         By &a120 HP&f. It can be used",
        "      By sending out a &ePokémon&f and",
        "     Using the &dHyper Potion&f on the",
        "                   &ePokémon&f."
    ],
    "quest.04055BFFF6CCD552.quest_subtitle": "HP",
    "quest.04099236CB6A4729.quest_desc": [
        "                The &aLeek&f is a",
        "             Held &eItem&f of power.",
        "",
        "       It raises &aFarfetch'd&f's critical",
        "        Hit ratio by &e+2 Stages&f total.",
        "",
        "         A wild &aFarfetch'd&f has a &e5%&f",
        "        Chance to be holding a &aLeek&f",
        "               When captured."
    ],
    "quest.04099236CB6A4729.quest_subtitle": "Raises Farfetch'd's critical hit ratio",
    "quest.04499526B78D81B5.quest_subtitle": "Team armor",
    "quest.04598B4679AA7989.quest_subtitle": "Improving our tools",
    "quest.04598B4679AA7989.title": "Tools",
    "quest.04C0767FAA6213B9.quest_desc": [
        "          A &6Dire Hit&f is an item that",
        "       Can be used on a &ePokémon&f to",
        "       Increase its &ccritical hit ratio&f",
        "                By two stages."
    ],
    "quest.04C0767FAA6213B9.quest_subtitle": "Critical",
    "quest.050D3CABE6B2DAC3.quest_desc": [
        "          The &9Good Rod&f is an item",
        "      Used to fish &aPokémon&f found in",
        "                &bWater&f or &6Lava&f.",
        "",
        "  It has a &e1\/100 Chance&f to drop from",
        "    A &bFisherman&f when defeated, and",
        "               Can be crafted.",
        "",
        " The &9Good Rod&f catches rarer Pokémon",
        "     Than the &7Old Rod&f, depending on",
        "             The player’s biome.",
        "",
        "     It can also drop from &bRare&f and",
        "              &dEpic&f &cBoss Pokémon&f."
    ],
    "quest.050D3CABE6B2DAC3.quest_subtitle": "It's actually pretty good",
    "quest.0520E582AB1926B5.quest_desc": [
        "      A &dPower Lens&f is a power item.",
        "  When held, &ePokémon&f gain normal EVs",
        "    Plus &a+8 Sp. Atk EVs&f after battle.",
        "      The holder's &bSpeed&f is halved.",
        "",
        "  If held while breeding, the &dSp. Atk IV&f",
        "        Is passed to the offspring."
    ],
    "quest.0520E582AB1926B5.quest_subtitle": "SP. ATK",
    "quest.053D6B5FB594D308.quest_desc": [
        "           An &7Iron&f is a type of",
        "    Medicine that adds &a10 Defense EVs&f",
        "     To a &ePokémon&f if possible. It also",
        "     Raises a &ePokémon's&f happiness by",
        "       &a5&f, &a3&f, or &a2&f depending on how",
        "      Much happiness it initially has."
    ],
    "quest.053D6B5FB594D308.quest_subtitle": "Defense EVs \/ Happiness",
    "quest.0547175BC9839431.quest_desc": [
        "      An &bAbility Capsule&f is an item",
        "  That can be used on a &ePokémon&f to",
        " Switch between its two normal Abilities.",
        "",
        "    It cannot be used if the &ePokémon&f",
        "    Has its &dHidden Ability&f or only one",
        "  Normal Ability. It also cannot change",
        "    A &ePokémon's&f Ability into its Hidden",
        " Ability — use an &dAbility Patch&f for that.",
        "",
        "     An &bAbility Capsule&f will disappear",
        "      Upon being used successfully."
    ],
    "quest.0547175BC9839431.quest_subtitle": "Switch Abilities",
    "quest.056AA44B6FCA6BCA.quest_desc": [
        "      A &cMagmarizer&f can be held by",
        "     &6Magmar&f so that it evolves into",
        "&6Magmortar&f when traded. It is consumed",
        "        Once the evolution occurs."
    ],
    "quest.056AA44B6FCA6BCA.quest_subtitle": "Magmar -> Magmortar",
    "quest.05A28520F6C50AB4.quest_subtitle": "Water Hammer",
    "quest.05B9DC11603C2DB9.quest_desc": [
        "        A &dSachet&f is a held item for",
        "         &eSpritzee&f. If traded while",
        "       Holding it, &eSpritzee&f evolves",
        "       Into &bAromatisse&f, consuming",
        "                  The &dSachet&f."
    ],
    "quest.05B9DC11603C2DB9.quest_subtitle": "Spritzee -> Aromatisse",
    "quest.05E24521F79A902A.quest_desc": [
        "   The &7Isi's Silver Hourglass&f lets you",
        "     Skip &e25%&f of the breeding timer",
        "           For a chosen &aPokémon&f."
    ],
    "quest.05E24521F79A902A.quest_subtitle": "Skip 25%",
    "quest.05E24521F79A902A.title": "Silver hourglass",
    "quest.05F0A15F66F8062A.quest_desc": [
        "    The &eUltranecrozium Z&f is a unique",
        "     &eZ-Crystal&f for &eNecrozma&f forms.",
        "",
        "       Moves this &eZ-Crystal&f can",
        "               Transform:",
        "",
        "      &ePhoton Geyser&f becomes the",
        "    &dLight that Burns the Sky&f attack.",
        "",
        "   &7Special:&f Only &eUltra Necrozma&f can",
        "    Use it. &eDusk Mane&f or &eDawn Wings&f",
        "   Must &eUltra Burst&f before using it.",
        "",
        "     &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "  Make a &aPokémon&f drop the &eZ-Crystal&f",
        "                 It is holding."
    ],
    "quest.05F0A15F66F8062A.quest_subtitle": "Necrozma-Dusk Mane and Necrozma-Dawn Wings",
    "quest.0601C78299027C71.quest_desc": [
        "       The &dTapunium Z&f is a unique",
        "     &eZ-Crystal&f for the four &dTapus&f.",
        "",
        "        Moves this &eZ-Crystal&f can",
        "               Transform:",
        "",
        "    &dNature's Madness&f becomes the",
        "        &dGuardian of Alola&f attack.",
        "",
        "     &7Special:&f Only &dTapu Koko, Lele,",
        "    Bulu&f and &dFini&f can use this move.",
        "",
        "     &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "  Make a &aPokémon&f drop the &eZ-Crystal&f",
        "                 It is holding."
    ],
    "quest.0601C78299027C71.quest_subtitle": "Tapu Koko, Tapu Lele, Tapu Bulu and Tapu Fini",
    "quest.0610CD8757A8DCC8.quest_subtitle": "Mega Evolution Stone",
    "quest.06F9555171BA34B4.quest_subtitle": "Special Attack",
    "quest.06FF96425CB0D89C.quest_desc": [
        "     An &cAssault Vest&f is a held item.",
        "   It boosts &dSp. Defense&f by &a50%&f, but",
        " Blocks the use of status moves. If the",
        " Holder cannot act, it will use Struggle."
    ],
    "quest.06FF96425CB0D89C.quest_subtitle": "Boosts Sp. Defense by 50% , but prevents the use of status moves",
    "quest.07A495A2137F7088.quest_subtitle": "Dracovish",
    "quest.07C97DF1346B72D3.quest_subtitle": "King of the distorted world",
    "quest.07E1E7ABFA7B8848.quest_desc": [
        "     The &dGenius Feather&f is a type of",
        "   Medicine that increases the &dSp. Atk",
        "       EV&f of a &ePokémon&f by &a1&f if you",
        "     Right-click it, consuming the item",
        "                   Upon use."
    ],
    "quest.07E1E7ABFA7B8848.quest_subtitle": "Special Attack EV",
    "quest.07E3DDF73E27F2AF.quest_subtitle": "Mega Evolution Stone",
    "quest.07EB3DCF01CF91D2.quest_desc": [
        "         A &cFiery Shrine&f is a shrine      ",
        "   That can be found rarely in &6Mesa&f     ",
        "                    Biomes.",
        "",
        " If a fully-charged &aOrb of Fiery Souls&f  ",
        "     Is placed in its centerpiece, the ",
        "      &dLegendary&f &cMoltres&f will appear.   ."
    ],
    "quest.07EB3DCF01CF91D2.quest_subtitle": "Fire bird",
    "quest.0816C00C6F755ED8.quest_desc": [
        "     There is a &e1\/512 Chance&f that a",
        "     &aPokémon&f with a &dGigantamax Form&f",
        "        Will have the &dG-Max Factor&f.",
        "",
        "  This allows it to &dGigantamax&f in battle,",
        " But it cannot be found in &5Ultra Space&f.",
        "",
        " You can check the &dSummary&f screen to",
        "   See if your &aPokémon&f has the factor.",
        "",
        " The &dG-Max Factor&f cannot be inherited",
        "   Through &dBreeding&f between parents.",
        "",
        "  However, you may grant it by feeding",
        "     The &eMax Soup&f to your &aPokémon&f."
    ],
    "quest.0816C00C6F755ED8.quest_subtitle": "Winning the Big One :)",
    "quest.0816C00C6F755ED8.title": "Gigantamax Form",
    "quest.08171C1AD6C74D23.quest_desc": [
        "           An &5Ether&f is a type of",
        "     Medicine used to restore &910 PP&f",
        "      To one of a &ePokémon's&f moves."
    ],
    "quest.08171C1AD6C74D23.quest_subtitle": "PP",
    "quest.08207A69FF8F5058.quest_subtitle": "&aSpecial Attack &8\/ &cAttack",
    "quest.0859FDCF195EFD53.quest_desc": [
        "       To become a &cPokémon Master&f,",
        "            You need more than",
        "             Just skill in &cbattle&f.",
        "",
        "            Items can help you",
        "        &aEvolve &fyour Pokémon or",
        "            Improve their &6EVs&f,",
        "               &e Their stats&f.",
        "",
        "             Be smart and build",
        "               &bA galactic team",
        "      Just like the 2005 Real Madrid."
    ],
    "quest.0859FDCF195EFD53.quest_subtitle": "Boosts Items",
    "quest.085B4665F7E1759A.quest_desc": [
        "         A &7Protector&f is a held item",
        "  That evolves &eRhydon&f into &bRhyperior&f.",
        "   If &eRhydon&f is traded while holding it,",
        "     The &7Protector&f is consumed and",
        "               &eRhydon&f evolves.",
        "",
        "    It can be found as a &aTier 2&f drop,",
        "   From legendary Pokéstops or as a",
        "             Drop from &bRhyperior&f."
    ],
    "quest.085B4665F7E1759A.quest_subtitle": "Rhydon -> Rhyperior",
    "quest.090A4964704D3149.quest_subtitle": "Chansey, Blissey → Happiny",
    "quest.091C9811D37DF04B.quest_subtitle": "A deity",
    "quest.0922B37AC6361295.quest_desc": [
        "     We need to &eincrease&f and &aimprove&f",
        "                   Our &aTeam&f...",
        "",
        "      Let’s craft some &bPoké Balls&f to",
        "       Capture &anew Pokémon&f for us!"
    ],
    "quest.0922B37AC6361295.quest_subtitle": "We need pokemons",
    "quest.09A393448DF8928E.quest_desc": [
        "         The &8Darkinium Z&f is a unique",
        "   &eZ-Crystal&f for &0Dark-Type Pokémon&f.",
        "",
        "        Moves this &eZ-Crystal&f can",
        "                Transform:",
        "",
        "    Any &0Dark-Type&f move that isn't a",
        "    Status move becomes the fierce",
        "        &dBlack Hole Eclipse&f attack.",
        "",
