    "quest.783226BDDCE192B0.quest_subtitle": "Hoe",
    "quest.7832CECE61732E43.quest_desc": [
        "              The &bLure Ball&f is a",
        "          Special type of &bPoké Ball&f",
        "",
        "   It has a &e5× Catch Rate&f when used",
        "       On &aPokémon&f found by fishing.",
        "",
        "     It can be obtained by &acrafting&f,",
        "   Buying from a &eShopkeeper&f, or as",
        "            A &6Tier 1 Special Drop&f."
    ],
    "quest.7832CECE61732E43.quest_subtitle": "5x Catch rate by fishing",
    "quest.78FB384A03CE07B6.quest_desc": [
        "            The &dPixie Plate&f is a",
        "            Held &eItem&f of power.",
        "",
        "      It boosts &dFairy-type&f moves of",
        "          Its holder by &e20%&f total.",
        "",
        "     When held by &dArceus&f, its typing",
        "    And &dJudgment&f become &dFairy-type&f,",
        "        Also gaining the same boost."
    ],
    "quest.78FB384A03CE07B6.quest_subtitle": "Boosts Fairy-type moves",
    "quest.7922B0016A5B7E7F.quest_desc": [
        "       A &8Reaper Cloth&f is a held item",
        "       For &eDusclops&f. If a &eDusclops&f",
        " Is traded while holding a &8Reaper Cloth&f,",
        "The &eDusclops&f will evolve into &bDusknoir&f,",
        "    Consuming the &8Reaper Cloth&f in the",
        "                   Process."
    ],
    "quest.7922B0016A5B7E7F.quest_subtitle": "Dusclops -> Dusknoir",
    "quest.793AB8824B77757B.quest_subtitle": "New Pokémon",
    "quest.7967051A4B513CE2.quest_subtitle": "Mega Evolution Stone",
    "quest.7992F81B4718F49B.quest_subtitle": "Thunder Hammer",
    "quest.79B1837CCA017F04.quest_desc": [
        "       A &eBright Powder&f is a held item.",
        "     It boosts the holder's &bEvasion&f by",
        "                 &a10%&f in battle."
    ],
    "quest.79B1837CCA017F04.quest_subtitle": "Boosts evasion by 10%",
    "quest.79B903B259F631AF.quest_subtitle": "Mega Evolution Stone",
    "quest.79F552EEE877E8DC.quest_subtitle": "Sun Axe",
    "quest.7A142417978BE889.quest_subtitle": "Mega Evolution Pokemon",
    "quest.7A2799782A3E9FF1.quest_desc": [
        "             The &dMoon Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "   It has a &e4× Catch Rate&f on &aPokémon&f",
        "      That evolve with a &dMoon Stone&f.",
        "",
        "     It can be obtained by &acrafting&f,",
        "   Buying from a &eShopkeeper&f, or as",
        "            A &6Tier 1 Special Drop&f.",
        "",
        "   Works on the following &aPokémon&f:",
        "",
        "   &dNidoran♀&f      &dNidorina&f",
        "   &dNidoqueen&f    &dNidoran♂&f",
        "   &dNidorino&f      &dNidoking&f",
        "   &dClefairy&f      &dClefable&f",
        "   &dIgglybuff&f    &dJigglypuff&f",
        "   &dWigglytuff&f    &dSkitty&f",
        "   &dDelcatty&f      &dMunna&f",
        "   &dMusharna&f."
    ],
    "quest.7A2799782A3E9FF1.quest_subtitle": "Best in specific pokemons",
    "quest.7A70766587740DDC.quest_subtitle": "Too many Pokemon!",
    "quest.7B4D72DC155C530A.quest_desc": [
        "        The &aX Defense&f is a type of",
        "    Medicine that temporarily raises a",
        "     &ePokémon's&f &9Defense&f by one stage",
        "                While in battle."
    ],
    "quest.7B4D72DC155C530A.quest_subtitle": "Defense",
    "quest.7B8D9569D85E6860.quest_subtitle": "Wobbuffet → Wynaut",
    "quest.7BA27FD08A4D77D9.quest_desc": [
        "              The &bNet Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "     It has a &e3.5× Catch Rate&f when",
        "  Used on &bWater&f or &aBug-type Pokémon&f.",
        "",
        "      It can be obtained by &acrafting&f",
        "       Or buying from a &eShopkeeper&f."
    ],
    "quest.7BA27FD08A4D77D9.quest_subtitle": "Increased chance with Water or Bug-type",
    "quest.7BAAA0839BCF7D8A.quest_subtitle": "Place in the furnace",
    "quest.7BAAA0839BCF7D8A.title": "Cooking..",
    "quest.7BC59BB08B4B7F11.quest_desc": [
        "         A &8Dusk Stone&f is a type of",
        "    Evolution stone used to evolve",
        "       Certain species of &ePokémon&f.",
        "",
        "    &8Dusk Stone&f can be used for the",
        "            Following evolutions:",
        "",
        "          &6Lampent &f→ &6Chandelure",
        "          &6Misdreavus &f→ &6Mismagius",
        "          &6Murkrow &f→ &6Honchkrow",
        "          &6Doublade &f→ &6Aegislash."
    ],
    "quest.7BC59BB08B4B7F11.quest_subtitle": "Dark type",
    "quest.7BF7DB6F12B067F4.quest_desc": [
        "          A &0Black Belt&f is a held item.",
        "     It boosts &cFighting&f moves' power",
        "              By &a20%&f when held."
    ],
    "quest.7BF7DB6F12B067F4.quest_subtitle": "Boosts Fighting-type moves",
    "quest.7C382A3C74B10F65.quest_subtitle": "Water Armor",
    "quest.7C5EDDB1ADF348FB.quest_desc": [
        "       A &fFloat Stone&f is a held item.",
        "      It halves the holder's &7weight&f."
    ],
    "quest.7C5EDDB1ADF348FB.quest_subtitle": "Halves the holder's weight",
    "quest.7C7A742E47E21060.quest_subtitle": "Leaf Sword",
    "quest.7C8D0103C2943905.quest_desc": [
        "        &eZ-Crystals&f are a type of",
        "     Held item that allow &aPokémon&f",
        " To unleash powerful &dZ-Moves&f once",
        "                Per battle.",
        "",
        "  Physical\/Special moves gain great",
        "   Power, while Status moves cause",
        "        Stat changes or boosts.",
        "",
        "   &cEmbargo&f, &cKlutz&f or &cTrick&f cannot",
        "    Remove a &eZ-Crystal&f from its",
        "             Holder &aPokémon&f.",
        "",
        "   There are &635 types&f of &eZ-Crystals&f,",
        "   Some exclusive to certain &aPokémon&f.",
        "",
        "     They can be obtained as loot",
        "   In Beast Chests of &dUltra Space&f,",
        " From rare &6Boss Pokémon&f or specific",
        "                Encounters.",
        "",
        "   &eZ-Crystals&f can also change the",
        "         Type of &dArceus&f itself.",
        "",
        "   To unleash a &dZ-Move&f, a player",
        " Must also wear a shining &9Key Stone&f."
    ],
    "quest.7C8D0103C2943905.quest_subtitle": "Pixelmon is in the details",
    "quest.7C8D0103C2943905.title": "Z-Crystals",
    "quest.7C94072573D94435.quest_subtitle": "Water Shovel",
    "quest.7C9DE48B528B28E7.quest_subtitle": "What should this be?",
    "quest.7CDC9FA28B759711.quest_desc": [
        "             The &aNest Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "     It works especially well when",
        "     Catching weaker wild &aPokémon&f."
    ],
    "quest.7CDC9FA28B759711.quest_subtitle": "Bléh",
    "quest.7CE474DB7B9DA18A.quest_desc": [
        "                 &cFind trainers",
        "             And defeat them to",
        "        Complete your daily quest."
    ],
    "quest.7CE474DB7B9DA18A.quest_subtitle": "Defeating NPCs",
    "quest.7D30CD2A8354F673.quest_desc": [
        "           The &bMystic Water&f is a",
        "             Held &eItem&f of power.",
        "",
        "        It boosts &bWater-type&f moves",
        "             Of its holder by &e20%&f."
    ],
    "quest.7D30CD2A8354F673.quest_subtitle": "Boosts Water-type moves",
    "quest.7D57632F699B125F.quest_subtitle": "Galatic Armor",
    "quest.7DAC026E8AEB90F4.quest_subtitle": "This is good",
    "quest.7DAE77A9FE864E26.quest_desc": [
        "          The &6Luxury Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "   It makes caught &aPokémon&f quickly",
        "        Become more friendly.",
        "",
        "    It can be obtained by &acrafting&f",
        "     Or buying from a &eShopkeeper&f.",
        "",
        "  A &6Luxury Ball&f grants &a+1 Happiness&f",
        "      To the many ways of gaining",
        "                 &aHappiness.",
        "",
        "   It does not affect events that may",
        "      Lower happiness, but its effect",
        "         Stacks with a &dSoothe Bell&f."
    ],
    "quest.7DAE77A9FE864E26.quest_subtitle": "+1 Happiness",
    "quest.7DC273E96E9C6D09.quest_subtitle": "&aDefense &8\/ &cSpecial Defense",
    "quest.7DDB1072B020C7DC.quest_subtitle": "Thunder Hoe",
    "quest.7DE20A310022AB7A.quest_subtitle": "Jump Boost IV + Fall Damage Immunity",
    "quest.7DF8CDB8E2783F35.quest_desc": [
        "             The &aFriend Ball&f is a",
        "          Special type of &bPoké Ball&f",
        "",
        "     It sets a caught &aPokémon&f base",
        "         Happiness to &e200&f points.",
        "",
        "   This effect does not occur when",
        "    Inherited by breeding offspring.",
        "",
        "   It has the same &e1× Catch Rate&f as",
        "           A normal &bPoké Ball&f.",
        "",
        "    It can be obtained by &acrafting&f,",
        "   Buying from a &eShopkeeper&f, or as",
        "            A &6Tier 1 Special Drop&f."
    ],
    "quest.7DF8CDB8E2783F35.quest_subtitle": "200 Happiness",
    "quest.7E07AD241E27AA25.quest_desc": [
        "       A &eCell Battery&f is a held item.",
        "      If hit by an &eElectric&f move, the",
        "    Holder's &cAttack&f rises by &a+1&f stage.",
        "  The item is consumed on trigger and",
        "      Does not give Electric immunity."
    ],
    "quest.7E07AD241E27AA25.quest_subtitle": "Raises the holder's Attack by one stage when hit by an Electric-type move",
    "quest.7E08AE2E0D620950.quest_subtitle": "Mega Evolution Stone",
    "quest.7E5BCFD3979CA905.quest_desc": [
        "        &bEvolve &f5 different &ePokémon&f."
    ],
    "quest.7E5BCFD3979CA905.quest_subtitle": "It's time to become a hero!",
    "quest.7E5BCFD3979CA905.title": "Evolve",
    "quest.7E7A91DDE18DECD7.quest_desc": [
        "       A &cTart Apple&f is an item that",
        "     Can evolve &6Applin&f into &6Flapple&f.",
        "       It can be held by wild &6Applin&f.",
        "  It can also be obtained by using the",
        " External move &aHeadbutt&f against a tree",
        "                  In &2Forests&f."
    ],
    "quest.7E7A91DDE18DECD7.quest_subtitle": "Applin -> Flapple",
    "quest.7E7CC307082CC6E4.quest_desc": [
        "             The &8Heavy Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "      Used for catching very &8Heavy&f",
        "                  &aPokémon&f.",
        "",
        "     It can be obtained by &acrafting&f,",
        "   Buying from a &eShopkeeper&f, or as",
        "         A &6Tier 1 Special Drop&f.",
        "",
        "    Unlike most &bPoké Balls&f, its catch",
        "    Rate modifier is &eAdditive&f instead",
        "               Of multiplicative.",
        "",
        "   Catch Rate modifier by weight:",
        "",
        "   &7•&f ≤ 199.9kg → &c-20",
        "   &7•&f 200–299.9kg → &a+20",
        "   &7•&f 300–409.5kg → &a+30",
        "   &7•&f ≥ 409.5kg → &a+40."
    ],
    "quest.7E7CC307082CC6E4.quest_subtitle": "Heavyweights",
    "quest.7ED141D0A0C2BA10.quest_desc": [
        "       &dExp. Candies&f are items that",
        "     Were added into &bPixelmon&f. Each",
        "  Candy gives a set amount of &aEXP&f,",
        "    Unlike &dRare Candies&f, which always",
        "    Give enough &aEXP&f to level up once."
    ],
    "quest.7ED141D0A0C2BA10.quest_subtitle": "3000 exp",
    "quest.7EF93C3795389A7A.quest_desc": [
        "        &0Black Glasses&f is a held item.",
        "    It boosts &8Dark&f moves' power by",
        "               &a20%&f when held."
    ],
    "quest.7EF93C3795389A7A.quest_subtitle": "Boosts Dark-type moves",
    "quest.7F0A32200D301EAE.quest_desc": [
        "             &aBerries&f in Pixelmon,         ",
        "     Especially those that lower &bEVs&f,  ",
        "       Work in a very useful way for",
        "         Training your &ePokémon&f.          ",
        "",
        "      There are six &aBerries&f that,      ",
        " When given to a &ePokémon&f, reduce &bEVs&f ",
        "                   By &610&f.                 ",
        "",
        "        If the &ePokémon&f has more ",
        "              Than &c100&f &bEVs&f,  ",
        "   The first &aBerry&f will lower it to &c100&f.  ",
        "     After that, each &aBerry&f reduces          ",
        "            The &bEV&f by &610&f points.          ",
        "",
        "     These &aBerries&f are great to fix      ",
        "      Training mistakes or to \"&dreset&f\" ",
        "        The &bEVs&f of a &ePokémon&f and       ",
        "      Redistribute them in a new way."
    ],
    "quest.7F0A32200D301EAE.quest_subtitle": "Berry",
    "quest.7F579418063F3199.quest_desc": [
        "       &0Black Sludge&f is a held item.",
        "     Heals &5Poison&f types by &a1\/16 HP&f",
        "      Each turn while held in battle.",
        "",
        "    Non-&5Poison&f types take damage of",
        "              &c1\/8 HP&f each turn."
    ],
    "quest.7F579418063F3199.quest_subtitle": "Heals Poison-type Pokémon and damages non-Poison types",
    "quest.7F6CECAE425244F7.quest_desc": [
        "         The &dDynamax Candy&f is a",
        "         Special type of &eMedicine&f.",
        "",
        "  It raises a &aPokémon’s&f &dDynamax Level&f",
        "         By &e+1&f, up to a max of &e10&f.",
        "",
        " Each level boosts &cHP&f during Dynamax",
        "      By &e+5%&f of its maximum base HP."
    ],
