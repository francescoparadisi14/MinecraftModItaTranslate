    ],
    "quest.4D930F8432681276.quest_subtitle": "Restores HP to the holder based on the damage it deals",
    "quest.4DA0C27D0F6D0A41.quest_desc": [
        "         The &aBig Root&f is a held item.",
        "    It boosts HP gained from draining",
        "     Moves, but not the damage dealt.",
        "",
        "     When held by a &ePokémon&f, these",
        "        Moves are affected by it:",
        "",
        " Absorb, Aqua Ring, Drain Punch,",
        " Draining Kiss, Dream Eater, Giga Drain,",
        " Ingrain, Leech Life, Leech Seed,",
        " Mega Drain."
