    "quest.6C1EBE20B28340F7.quest_desc": [
        "    &eTrainer&f, want to go beyond &aTime&f?",
        "         Well, &ctoo bad&f... This isn't",
        "     The right &6tutorial&f for that, but...",
        "",
        "             &eTrainer&f, don't worry.",
