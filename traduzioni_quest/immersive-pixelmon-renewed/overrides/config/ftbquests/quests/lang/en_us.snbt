    "quest.66487C4082B8C07D.quest_desc": [
        "          The &aIlex Shrine&f is found      ",
        "  Generated rarely in Forest biomes,    ",
        "  It is used to spawn &dCelebi&f and &5Alien   ",
        "                    Celebi&f.                ",
