    "quest.2C08E4C3D930427D.quest_subtitle": "Magma Armor",
    "quest.2D1C6EDE53586681.quest_subtitle": "Great idea to be colorful in nature",
    "quest.2D5FE09AC45AE368.quest_desc": [
        "        The &fNormalium Z&f is a unique",
