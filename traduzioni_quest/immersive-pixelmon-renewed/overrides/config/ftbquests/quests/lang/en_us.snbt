    ],
    "quest.48202B980E17EBBF.quest_subtitle": "Frozen",
    "quest.4821A871BEFBE313.quest_subtitle": "Mega Evolution Stone",
    "quest.48305F27ED8B365D.quest_desc": [
        "        The &7Ancient Poké Ball&f is the",
        "        Most basic type of &bPoké Ball&f",
        "",
        "    Like regular &bPoké Balls&f, it has a",
        "      &e1× Catch Rate&f on all &aPokémon&f.",
        "",
        "   They can be obtained by &acrafting&f,",
        "   As drops from some wild &aPokémon&f,",
        "        Or from &eCommon PokéStops&f."
    ],
    "quest.48305F27ED8B365D.quest_subtitle": "I still don't understand this pokeball...",
    "quest.483439ED7217F259.quest_desc": [
        "            A &bZinc&f is a type of",
        "    Medicine that adds &a10 Sp. Def EVs&f",
        "     To a &ePokémon&f if possible. It also",
        "     Raises a &ePokémon's&f happiness by",
        "       &a5&f, &a3&f, or &a2&f depending on how",
        "      Much happiness it initially has."
    ],
    "quest.483439ED7217F259.quest_subtitle": "Sp. Defense EVs \/ Happiness",
    "quest.483C44D6D4594FEA.quest_subtitle": "Moon Armor",
    "quest.48979843EF2E20AD.quest_desc": [
        "            The &6Thick Club&f is a",
        "            Held &eItem&f of power.",
        "",
        "       It doubles &cAttack&f of &fCubone&f",
        "           And &fMarowak&f in battle.",
        "",
        "      It has no effect when held by",
        "               Other &aPokémon&f."
    ],
    "quest.48979843EF2E20AD.quest_subtitle": "Doubles the Attack of Cubone and Marowak",
    "quest.48E8DE7442009840.quest_subtitle": "Dusk Armor",
    "quest.48FD9F5EA36D07EA.quest_subtitle": "Team Rocket Armor",
    "quest.490CA2E11E88EFB8.quest_subtitle": "Dusk Pickaxe",
    "quest.491128FD33B8F713.quest_desc": [
        "        An &7Everstone&f is a held item",
        "   That can be given to a &ePokémon&f to",
        " Prevent it from evolving. When held by",
        "     A breeding &ePokémon&f, its &dNature&f",
        "  And &dRegional Forms&f are guaranteed",
        "    To be passed on to its offspring."
    ],
    "quest.491128FD33B8F713.quest_subtitle": "No Evolution",
    "quest.49194B4D1D545AD1.quest_desc": [
        "            The &dLucky Punch&f is a",
        "              Held &eItem&f of power.",
        "",
        "       It raises &dChansey&f's critical hit",
        "           Ratio by &e+2 Stages&f total.",
        "",
        "        It has no effect on &dBlissey&f",
        "            Or any other &aPokémon&f."
    ],
    "quest.49194B4D1D545AD1.quest_subtitle": "Raises Chansey's critical hit ratio",
    "quest.4933459F363E5013.quest_desc": [
        "             The &dHeal Ball&f is a",
        "         Special type of &bPoké Ball&f",
        "",
        "    It restores a caught &aPokémon&f's",
        "    &cHP&f and removes all status upon",
        "              Being captured.",
        "",
        "     It can be obtained by &acrafting&f,",
        "   Buying from a &eShopkeeper&f, or as",
        "           A &6Tier 1 Special Drop&f."
    ],
    "quest.4933459F363E5013.quest_subtitle": "Remove all statuses from Pokémon",
    "quest.4976C40882C4B193.quest_subtitle": "Improving our team",
    "quest.4976C40882C4B193.title": "Evolve your pokemon",
    "quest.498DC724FB427DBB.quest_subtitle": "Mega Evolution Stone",
    "quest.49FA417099FA211D.quest_desc": [
        "            To be able to craft",
        "             &6Ancient Poké Balls&f",
        "      You need to find these &dStones&f",
        "",
        "         They can be obtained by",
        "      Mining &eTumblestone Crystals&f",
        "               With a hammer.",
        "",
        "      Found in &aMountainous&f biomes,",
        "      But most abundant within the",
        "    &dUltra Plant&f biome in &5Ultra Space&f",
        "",
        "                      Or",
        "",
        "             By killing &aPokémon&f",
        "             The chance is &e10%&f",
        "",
        "           &2Croagunk&f     &7Geodude&f",
        "           &7Golem&f          &7Graveler&f",
        "           &cMachamp&f      &cMachoke&f",
        "           &cMachop&f       &bMagikarp&f",
        "           &2Toxicroak&f."
    ],
    "quest.49FA417099FA211D.quest_subtitle": "Kill some Pokemon",
    "quest.4A023D00FC18D37A.quest_subtitle": "Shieldon",
    "quest.4A07BB68365B23B8.quest_desc": [
        "            The &fSharp Beak&f is a",
        "             Held &eItem&f of power.",
        "",
        "        It boosts &bFlying-type&f moves",
        "            Of its holder by &e20%&f."
    ],
    "quest.4A07BB68365B23B8.quest_subtitle": "Boosts Flying-type moves",
    "quest.4A0F555E688111BC.quest_desc": [
        "            &bMining&f is a great way",
        "       To get some &eCovered Fossils&f.",
        "",
        "     This ore is the basis for getting",
        "         Several &cAncient Pokémon&f.",
        "",
        "        You can find this &6Fossil&f in",
        "    The &aOverworld&f, inside &7Gravel&f or",
        "   &8Deepslate&f areas at heights between",
        "        &e-64 &fand &e100&f, with the best",
        "     Concentration at around &eY = 18&f."
    ],
    "quest.4A0F555E688111BC.quest_subtitle": "This is still Minecraft",
    "quest.4A16A96D3A8CCDD5.quest_desc": [
        "          The &dTwisted Spoon&f is a",
        "             Held &eItem&f of power.",
        "",
        "      It boosts &dPsychic-type&f moves",
        "            Of its holder by &e20%&f."
