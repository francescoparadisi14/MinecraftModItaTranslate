    ],
    "quest.47AE58ADE0C19760.quest_subtitle": "Make new puppies",
    "quest.47AEE3B93192571C.quest_subtitle": "Mega Evolution Stone",
    "quest.481B6A141F079856.quest_desc": [
        "         To breed any &aPokémon&f, a",
        "            &eDay Care&f is required.",
        "",
        "      By default, each player has &e3&f",
        "       &eDay Care Boxes&f, but this can",
        "    Be changed via &6Config&f or sidemod.",
        "",
        "      After placing a &eDay Care&f, two",
        "     &aPokémon&f from the party can be",
        "    Moved into its interface to start.",
        "",
        "",
        "{image:lupin:textures\/quests\/daycare.png width:140 height:100 align:center}."
    ],
    "quest.481B6A141F079856.quest_subtitle": "Early",
    "quest.481B6A141F079856.title": "Getting started",
    "quest.48202B980E17EBBF.quest_desc": [
        "         An &bIce Heal&f is a type of",
