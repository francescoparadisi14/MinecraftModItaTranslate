    "quest.4DA0C27D0F6D0A41.quest_subtitle": "Boosts HP gained from draining moves",
    "quest.4DB25D8AB44AA191.quest_subtitle": "Plasma Armor",
    "quest.4DBD5177EE954507.quest_desc": [
        "     A &aPower Weight&f is a power item.",
        "  When held, &ePokémon&f gain normal EVs",
        "    Plus &a+8 HP EVs&f after each battle.",
        "       The holder's &bSpeed&f is halved.",
        "",
        "     If held while breeding, the &cHP IV&f",
        "       Is passed to the offspring."
    ],
    "quest.4DBD5177EE954507.quest_subtitle": "HP",
    "quest.4DFA57B5C4D0A37E.quest_desc": [
        "     An &dAbsorb Bulb&f is a held item.",
        " If hit by a Water-type move, it boosts",
        "             The holder's Sp. Atk."
    ],
    "quest.4DFA57B5C4D0A37E.quest_subtitle": "Boosts Sp. Atk",
