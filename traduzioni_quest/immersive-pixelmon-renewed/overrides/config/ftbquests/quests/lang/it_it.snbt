    ],
    "quest.51CF9951BF0BC90A.quest_subtitle": "Attiva la difesa speciale quando viene colpito da un attacco di tipo Acqua.",
    "quest.51D475023A8389F9.quest_subtitle": "Armatura lunare",
    "quest.51EB52D315EEAF7B.quest_desc": [
        "Esistono diversi tipi di basi.",
        "Sono la base.",
        "Per diversi Poké Ball",
        "",
        "Ricordate sempre di raccogliere i materiali.",
        "Ci sono molti Pokémon che hanno bisogno di aiuto.",
