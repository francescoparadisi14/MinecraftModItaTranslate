    "quest.0A8D34E2E151DE8F.quest_subtitle": "Armatura Neo Plasma",
    "quest.0A94D12BA3B84B9A.quest_desc": [
        "            \\&fMoomoo Milk\\&f è un",
        "Tipo di farmaco: \\&2",
        "",
        "Riparazione e ripristino di 100 punti HP quando viene utilizzato su",
        "                  A \\&Pokémon\\&f."
    ],
    "quest.0A94D12BA3B84B9A.quest_subtitle": "HP",
    "quest.0AA359609B2FE786.quest_subtitle": "Martello Lunare",
    "quest.0AB1777B683480F9.quest_desc": [
        "\\&bAcqua fresca\\&f è un tipo di",
        "Farmaco che cura e fornisce 50 punti salute",
        "Utilizzato con Pokémon."
    ],
    "quest.0AB1777B683480F9.quest_subtitle": "HP",
    "quest.0AB833DF7CE714DA.quest_desc": [
        "       Possiamo utilizzare la funzione \"\\&bPC\\&f\" per visualizzare tutto.",
        "Le nostre attività e la gestione",
        "Il nostro team."
    ],
    "quest.0AB833DF7CE714DA.quest_subtitle": "Gestire i tuoi Pokémon",
    "quest.0AF8B26D1C6DA048.quest_desc": [
        "Un pallone ad aria è un oggetto che può essere tenuto in mano.",
        "Questo lo rende immune agli effetti del \"Ground\".",
        "Annunciato all'inizio della battaglia.",
        "Se il titolare subisce danni diretti, allora…",
        "La festa con i palloncini termina quando questi scoppiano."
    ],
    "quest.0AF8B26D1C6DA048.quest_subtitle": "Conferisce immunità agli attacchi di tipo Terra.",
    "quest.0B11E45CCABB568A.quest_desc": [
        "\\&c Attacchi",
        "Durante le vostre battaglie",
        "E completa la tua missione quotidiana."
    ],
    "quest.0B11E45CCABB568A.quest_subtitle": "Strategia per utilizzare i TM (Termini Master)",
    "quest.0B403CEF3773B11D.quest_desc": [
        "\\&c Cattura Pokémon",
        "Per completare la tua missione quotidiana."
    ],
    "quest.0B403CEF3773B11D.quest_subtitle": "Catturare sempre più",
    "quest.0BA1DB3689D4F86B.quest_desc": [
        "Il \\&6Quick Claw\\&f è un",
        "Supporto fornito.",
        "",
        "Offre al titolare una probabilità del 20%.",
        "Indipendentemente da",
        "Qualsiasi differenza in termini di \\&bSpeed\\&f.",
        "",
        "Questo si applica solo a determinate azioni.",
        "Stesso o inferiore, con priorità inferiore."
    ],
    "quest.0BA1DB3689D4F86B.quest_subtitle": "Offre una probabilità del 20% di muoversi per primo.",
    "quest.0C11D6CB5CD332E1.quest_desc": [
        "             \\&aLeftovers\\&f è un",
        "Rientro in forma.",
        "",
        "Restituisce e\/o attribuisce 1\/16 e\/o f di ciò che appartiene al titolare.",
        "\\&cHP\\&f alla fine di ogni",
        "\\&eTurn\\&f."
    ],
    "quest.0C11D6CB5CD332E1.quest_subtitle": "Ripristina 1\/16 della salute (HP) del personaggio alla fine di ogni turno.",
    "quest.0C31676E97206128.quest_desc": [
        "         Il Decidium Z\\&f è un prodotto unico",
        "\\&eZ-Crystal\\&f solo per \\&2Decidueye\\&f.",
        "",
        "Sposta questo e lo schermo eZ-Crystal.",
        "Trasformare:",
        "",
        "\\&2Spirit Shackle\\&f diventa il",
        "\\&dAttacco con l'arma \"Sinister Arrow\"\\&f.",
        "",
        "\\&7Speciale:\\&f Solo un \\&2Decidueye\\&f può",
        "Utilizza questa mossa.",
        "",
        "\\&cEmbargo\\&f, \\&cKlutz\\&f o \\&cTrick\\&f non sono",
        "Fai in modo che il Pokémon perda il cristallo Z.",
        "Sta resistendo."
    ],
    "quest.0C31676E97206128.quest_subtitle": "Decidueye",
    "quest.0C3F303CD90042F0.quest_subtitle": "Ho catturato un Pokémon per una battaglia di raid.",
    "quest.0C3F303CD90042F0.title": "Rapine",
    "quest.0C6E6B331A06AEF1.quest_subtitle": "Tyrunt",
    "quest.0CA3C916C2F95757.quest_subtitle": "Pietra dell'Evoluzione Mega",
    "quest.0CCED40DD745BDFD.quest_subtitle": "Pietra dell'Evoluzione Mega",
    "quest.0CECCC0AEEB7F9BC.quest_desc": [
        "Tutte le Poké Ball",
        "Seguono lo stesso modello di produzione.",
        "",
        "{image:lupin:textures\/quests\/craft_pokebola.png width:30 height:30 align:center}."
    ],
    "quest.0CECCC0AEEB7F9BC.quest_subtitle": "La tua prima Poké Ball",
    "quest.0CECCC0AEEB7F9BC.title": "Creazione; realizzazione",
    "quest.0CED28FABABEDD54.quest_subtitle": "Ora, ancora più forte!",
    "quest.0D384C2C0ACEC429.quest_subtitle": "Pietra dell'Evoluzione Mega",
    "quest.0D59BE49CF7BE117.quest_desc": [
        "            Il metronomo è un",
        "Possesso di un'arma.",
        "",
        "Aumenta l'efficacia dei movimenti eseguiti in sequenza.",
        "Diventa sempre più forte ad ogni tentativo.",
        "",
        "La potenza aumenta del 20% ogni turno.",
        "Fino a un massimo del \\&e+100%\\&f in totale.",
        "",
        "L'effetto viene ripristinato se l'elemento \"\\&aPokémon\\&f\" viene rimosso.",
        "Utilizza un'altra mossa o la sostituisce."
    ],
    "quest.0D59BE49CF7BE117.quest_subtitle": "Aumenta del 20% l'efficacia dei movimenti utilizzati consecutivamente, fino al 100%.",
    "quest.0D7E35C1A9CF3DE1.quest_subtitle": "Armatura foglia",
    "quest.0D8B1079489782A5.quest_desc": [
        "A \\&5Power Band\\&f è un oggetto di potenza.",
        "Quando un Pokémon viene catturato, ottiene automaticamente 51 punti EV (Effort Value) in tutte le categorie.",
        "Inoltre, i veicoli elettrici (EV) con capacità di 8 e superiori, dopo la battaglia.",
        "Il valore di \\&bSpeed\\&f viene dimezzato.",
        "",
        "Se viene tenuto durante la stagione riproduttiva, il \\&dSp. Def IV\\&f",
        "Viene trasmesso alla prole."
    ],
    "quest.0D8B1079489782A5.quest_subtitle": "Definizione",
    "quest.0D93842A83F0F91E.quest_desc": [
        "     Il \\&bSwift Feather\\&f è un tipo di",
        "Farmaci che aumentano la velocità del battito cardiaco.",
        "       Valore e caratteristiche di un Pokémon, se",
        "Fai clic con il tasto destro. L'oggetto viene consumato.",
        "Dopo l'uso."
    ],
    "quest.0D93842A83F0F91E.quest_subtitle": "Speed EV",
    "quest.0E0CB3B3FF94B180.quest_desc": [
        "A \\&cBurn Heal\\&f è un tipo di",
        "Farmaci utilizzati per curare le ustioni",
        "Stato di un Pokémon di tipo Acqua."
    ],
    "quest.0E0CB3B3FF94B180.quest_subtitle": "Bruciare",
    "quest.0E1E4DD2581225AC.quest_desc": [
        "              \\&bIcy Rock\\&f è un",
        "            Hanno stabilito che questo prodotto\/servizio\/elemento ha i seguenti vantaggi:",
        "",
        "La durata del tempo a \\&bHail\\&f",
        "Totale di 88 giri."
    ],
    "quest.0E1E4DD2581225AC.quest_subtitle": "Prolunga la durata di Hail a 8 turni.",
    "quest.0E429E02C6EA28B8.quest_subtitle": "Armatura in materiale plastico",
    "quest.0EAA6D03C1954519.quest_subtitle": "Anorith",
    "quest.0EEA18BB01524FBE.quest_desc": [
        "A \\&bMega Stone\\&f è un tipo di oggetto da tenere in mano.",
        "Oggetto che permette a un Pokémon di effettuare la Mega Evoluzione.",
        "In battaglia.",
        "",
        "Ogni evoluzione Mega richiede",
        "Utilizzare materiali diversi e di grandi dimensioni.",
        "",
        "A \\& bMega Stone\\&f può essere ottenuta tramite:",
        "Sconfiggere un",
        "\\&6Mega Evoluzione del boss\\&f \\&ePokémon\\&f.",
        "Quale di questi farà sparire il corrispondente?",
        "",
        "\\&Mega Stone\\&",
        "Se la \\&bMega Stone\\&f non è già stata",
        "È stato ottenuto in precedenza, quindi lo sarà sempre.",
        "Altrimenti, la probabilità è di 1 su 40.",
        "",
        "Un Pokémon può evolvere in Mega Pokémon solo se",
        "Mantiene la sua pietra corrispondente e la pietra Mega, e se...",
        "La persona che indossa il bracciale è vista con un bracciale \"Mega\".",
        "",
        "In combattimento, la Pietra Mega non ha alcun effetto.",
        "Attraverso l'utilizzo di strumenti che rimuovono gli oggetti bloccati, come ad esempio",
        "Come \"Trick\", \"Knock Off\", \"Embargo\"",
        "Stanza Magica."
    ],
    "quest.0EEA18BB01524FBE.quest_subtitle": "Come funzionano le mega pietre?",
    "quest.0F2D359C0433887B.quest_subtitle": "\\&Velocità \\&8\/ \\&Attacco",
    "quest.0F8700B15331C2E5.quest_desc": [
        "Negli appunti che seguiranno, troverete",
        "Diversi sfide e altre difficoltà da affrontare.",
        "\\& Ricompense incredibili \\&"
    ],
    "quest.0F8700B15331C2E5.quest_subtitle": "Strano, vero?",
    "quest.0F8700B15331C2E5.title": "Antichi e sfide",
    "quest.0F902230A58D6473.quest_subtitle": "\\&aDifesa \\&8\/ \\&cAttacco speciale",
    "quest.0F9A512A88224942.quest_subtitle": "Armatura Team Rocket",
    "quest.0FA36659944018A0.quest_subtitle": "IFood",
    "quest.0FF21C60D5CB7D05.quest_desc": [
        "Utilizzare il modello \\&6GS Ball\\&f presso \\&aCelebi’s\\&f",
        "Luogo sacro e santuario per la nascita",
        "E cercare di catturarlo!"
    ],
    "quest.0FF21C60D5CB7D05.quest_subtitle": "La casa di Celebi",
    "quest.1006DBA2DC0D35BC.quest_desc": [
        "              Il \\&fSnowball\\&f è un",
        "Possesso di un'arma.",
        "",
        "Aumenta l'attacco del possessore e di tutti gli altri",
        "Quando colpito da un",
        "\\&Tipo di attacco di tipo ghiaccio.",
        "",
        "         Il \\&fSnowball\\&f viene \\&cconsumato\\&f",
        "Dopo l'attivazione."
    ],
    "quest.1006DBA2DC0D35BC.quest_subtitle": "Aumenta l'attacco del possessore quando viene colpito da un attacco di tipo Ghiaccio.",
    "quest.101A4BA2B383C2B1.quest_desc": [
        "        Il \\&aGrassium Z\\&f è un prodotto unico.",
        "\\&eZ-Cristallo\\&f per Pokémon di tipo erba.",
        "",
        "Sposta questo eZ-Crystal e f.",
        "Trasformare:",
        "",
        "Qualsiasi mossa di tipo Erba che non sia",
        "Lo status cambia, diventando più deciso\/affermato.",
        "\\&dAttacco di Bloom Doom\\&f",
        "",
        "\\&cEmbargo\\&f, \\&cKlutz\\&f o \\&cTrick\\&f non sono",
        "Fai in modo che il Pokémon perda il cristallo Z.",
        "Sta resistendo."
    ],
    "quest.101A4BA2B383C2B1.quest_subtitle": "Tipo erba",
    "quest.109931C025CB9494.quest_desc": [
        "              \\&9Soda Pop\\&f è un",
        "Tipo di farmaco: \\&2",
        "",
        "Riparazione e ripristino di 60 HP quando utilizzato su",
        "                  A \\&Pokémon\\&f."
    ],
    "quest.109931C025CB9494.quest_subtitle": "HP",
    "quest.10C8226AE7E8EDDE.quest_subtitle": "HP",
    "quest.110D90B64DFF7B17.quest_subtitle": "Ascia",
    "quest.1145B4274729072A.quest_desc": [
        "          Il \\&9Quick Powder\\&f è un",
        "Velocità massima raggiungibile.",
        "",
        "raddoppia le statistiche di \\&bSpeed\\&f.",
        "Ma solo quando non è stato trasformato, ecc.",
        "",
        "Non ha alcun effetto quando viene tenuto in mano.",
        "Altre informazioni su Pokémon."
    ],
    "quest.1145B4274729072A.quest_subtitle": "Aumenta la velocità di Ditto quando non è trasformato.",
    "quest.117FE67C2963EF93.quest_desc": [
        "Il prodotto \\&aHeal Powder\\&f è un",
        "          Tipo speciale di \\&2Farmaci\\&f.",
        "",
        "Cura tutte le condizioni patologiche presenti in un Pokémon.",
        "Proprio come \"Full Heal\".",
        "",
        "Tuttavia, ciò riduce il livello di felicità.",
        "In base a \\&e5\\&f o \\&e10\\&f, a seconda di",
        "Inizialmente, ne aveva avuto molto."
    ],
    "quest.117FE67C2963EF93.quest_subtitle": "HP \/ - Felicità",
    "quest.11A30167D830479C.quest_subtitle": "Ascia per l'acqua",
    "quest.11B84239BE238567.quest_desc": [
        "             Il \"Dusk Ball\" è un",
        "Tipo speciale di Poké Ball",
        "",
        "Ha un tasso di cattura di \\&e3× in condizioni di scarsa illuminazione o",
        "Luoghi adatti per la notte.",
        "",
        "Nelle dimensioni \\&dNether\\&f e \\&5End\\&f, ciò",
        "   Viene sempre considerato come \"ora notturna\".",
        "",
        "Condizioni per ottenere un effetto potenziato:",
        "\\&7•\\&f Pokémon con altezza inferiore a quella richiesta \\&e64\\&f",
        "• Livello di illuminazione ≤ 14",
        "•\\&7•\\&f La pioggia sotto la luce del sole innesca l'effetto",
        "",
        "\\&7La neve al sole non provoca",
        "L'effetto potenziato di Dusk Ball.",
        "",
        "Contro gli \"Ultra Beast\" se sono presenti solo",
        "A \\&c0.1× Tasso di cattura\\&f."
    ],
    "quest.11B84239BE238567.quest_subtitle": "Più efficace di notte",
    "quest.1240B622298E2FD0.quest_desc": [
        "Ora puoi ottenere",
        "\\&dMewtwo\\&f!",
        "",
        "È possibile trovare molte Poké Ball.",
        "              In \\&6Drops Special\\&f",
        "Tramite \\&ePoké Loots\\&f e \\&aPickup\\&f."
    ],
    "quest.1240B622298E2FD0.quest_subtitle": "Punti (a pois)",
    "quest.1244F4EC0F6EB895.quest_subtitle": "Snorlax → Munchlax",
    "quest.12622F1F133E54F8.quest_subtitle": "Piccone",
    "quest.1264EAFBA09447E0.quest_subtitle": "Nessun effetto",
    "quest.1302FA63259DB0CD.quest_desc": [
        "         Il \\&dMimikium Z\\&f è un prodotto unico.",
        "\\&eZ-Crystal\\&f solo per \\&dMimikyu\\&f.",
        "",
        "Sposta questo e lo \\&eZ-Crystal\\&f.",
        "Trasformare:",
        "",
        "\\&dPlay Rough\\&f diventa il",
        "\\&d\"Abbracciamo per sempre\" - Attacco.",
        "",
        "\\&7Speciale:\\&f Solo un \\&dMimikyu\\&f può",
        "Utilizza questa mossa.",
        "",
        "\\&cEmbargo\\&f, \\&cKlutz\\&f o \\&cTrick\\&f non sono",
        "Fai in modo che il Pokémon perda il cristallo Z.",
        "Sta resistendo."
    ],
    "quest.1302FA63259DB0CD.quest_subtitle": "Mimikyu",
    "quest.1326B45A944AF3A5.quest_subtitle": "Evoluzioni Mega di Pokémon",
    "quest.13560B0CB5903DC8.quest_desc": [
        "Ottieni la tua ricompensa",
        "Congratulazioni, allenatore!"
    ],
    "quest.13560B0CB5903DC8.quest_subtitle": "È ora di fare qualcosa di buono.",
    "quest.135AB8A1CF56912B.quest_desc": [
        "Un insieme di anime imprigionate.",
        "Un oggetto che può essere utilizzato per generare\/creare",
        "\\&bArticuno\\&f.",
        "",
        "Per farlo, è necessario caricare il dispositivo.",
        "Sconfiggendo il Pokémon \\&6375\\&f con il",
        "e l'oggetto \"\\&aOrb\\&f\" nel inventario del giocatore, quindi",
        "Utilizzato su superfici ghiacciate e su altari.",
        "",
        "I Pokémon non devono essere di tipo ghiaccio.",
        "\\&9Acqua\\&f-tipo \\&Pokémon\\&f.",
        "",
        "Il numero rimanente di Pokémon.",
        "La sconfitta può essere visualizzata utilizzando",
        "\\&aOrb\\&f."
    ],
    "quest.135AB8A1CF56912B.quest_subtitle": "Articuno",
    "quest.1384BB3848B5DF98.quest_subtitle": "Spada del Sole",
    "quest.13CF3A3C861E5068.quest_desc": [
        "A \\&bWater Stone\\&f rappresenta un'evoluzione.",
        "Pietra che può essere ottenuta tramite",
        "Artigianato, pesca e molto altro.",
        "",
        "\\&bWater Stone\\&f può essere utilizzato per",
        "Evoluzioni successive:",
        "",
        "\\&6Poliwhirl → \\&6Poliwrath",
        "\\&6Shellder → \\&6Cloyster",
        "\\&6Staryu → \\&6Starmie",
        "\\&6Eevee \\&f→ \\&6Vaporeon",
        "\\&6Lombre \\&f→ \\&6Ludicolo",
        "\\&6Panpour \\&f→ \\&6Simipour",
        "\\&6Pesce Qwilfish \\&6Pesce Qwilfish"
    ],
    "quest.13CF3A3C861E5068.quest_subtitle": "Tipo di acqua",
    "quest.13D06B46B09AADBE.quest_desc": [
        "Per contare la missione",
        "         Clicca su \"poke dollaro\""
    ],
