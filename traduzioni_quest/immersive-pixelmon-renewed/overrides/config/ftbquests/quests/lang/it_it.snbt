    "quest.51EB52D315EEAF7B.quest_subtitle": "Tipi di base",
    "quest.51EB52D315EEAF7B.title": "Base",
    "quest.5212D954A71BDC3A.quest_subtitle": "Protezione IV + Protezione contro le esplosioni IV",
