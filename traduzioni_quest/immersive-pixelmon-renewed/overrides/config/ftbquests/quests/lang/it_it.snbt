    "file.0000000000000001.title": "Pixelmon coinvolgente",
    "quest.0012C37A9B88EB79.quest_subtitle": "Resistenza al fuoco + Protezione antincendio II",
    "quest.00266F394D62D47B.quest_desc": [
        "\\&cRilascia alcuni Pokémon",
        "Nel selvaggio",
        "E completa la tua missione quotidiana."
    ],
    "quest.00266F394D62D47B.quest_subtitle": "Lascia che i tuoi Pokémon vaghino liberamente.",
    "quest.0051855954EEFDD2.quest_subtitle": "Chimecho → Chingling",
    "quest.0058240B6EE18F91.quest_desc": [
        "A \\&2Leaf Stone\\&f è un tipo di",
        "Pietra evolutiva utilizzata per l'evoluzione.",
        "Alcune specie di Pokémon.",
        "",
        "\\&2Leaf Stone\\&f può essere utilizzato per",
        "Evoluzioni successive:",
        "",
        "\\&6Ombra \\&f→ \\&6Vileplume",
        "\\&6Weepinbell → \\&6Victreebel",
        "\\&6Exeggcute → \\&6Exeggutor",
        "\\&fOr \\&6Exeggutor di Alola",
        "\\&6Eevee → \\&6Leafeon",
        "\\&6Nuzleaf \\&f→ \\&6Shiftry",
        "\\&6Pansage → \\&6Simisage."
    ],
    "quest.0058240B6EE18F91.quest_subtitle": "Tipo di pianta",
    "quest.006BBAEE75BB40D3.quest_subtitle": "Evoluzioni Mega di Pokémon",
    "quest.00C6359C983B2F76.quest_desc": [
        "              Il \\&dLove Ball\\&f è un",
        "Tipo speciale di Poké Ball",
        "",
        "   Ha un tasso di cattura di \\&e8× quando viene utilizzato",
        "Riguarda la stessa specie di Pokémon.",
        "Opposto al genere del giocatore.",
        "",
        "Può essere ottenuto attraverso la creazione di \\&acrafting\\&f.",
        "Acquistare da un rivenditore online o da un negozio fisico.",
        "A \\& 6° livello, oggetto speciale.",
        "",
        "Inoltre, viene abbandonato anche dagli animali selvatici.",
        "\\&dGranbull\\&f."
    ],
    "quest.00C6359C983B2F76.quest_subtitle": "Aumenta il tasso di cattura per Pokémon dello stesso tipo del 8,0",
    "quest.00E597B174FE8343.quest_subtitle": "Armatura Magmatica",
    "quest.01263A96A5538740.quest_desc": [
        "\"A \\&8Griseous Orb\\&f è un oggetto da tenere in mano.",
        "Aumenta i poteri di Giratina, la forma Fantasma.",
        "Attacchi di tipo Drago con un aumento di potenza del 20%.",
        "Se il Pokémon Giratina lo tiene, cambia forma.",
        "Nella forma originale durante il combattimento.",
        "Non ha alcun effetto su altri Pokémon.",
        "",
        "Utilizzato su un altare \"\\&cTimespace\" con un",
        "\\&cCatena Rossa\\&f, chiama \\&6Giratina\\&f."
    ],
    "quest.01263A96A5538740.quest_subtitle": "Aumenta l'efficacia degli attacchi di tipo Spettro e Drago di Giratina. Inoltre, trasforma Giratina nella sua forma originale durante il combattimento.",
    "quest.015DB3993598C4D4.quest_desc": [
        "A \\&fCalcium\\&f è un tipo di",
        "Farmaco che aumenta i punti di Attacco (Sp. Attk) di 10.",
        "Se possibile, inviate anche le informazioni relative a Pokémon.",
        "Aumenta il livello di felicità del Pokémon.",
        "\\&a5\\&f, \\&a3\\&f, oppure \\&a2\\&f, a seconda di come",
        "Inizialmente, offre molta gioia."
    ],
    "quest.015DB3993598C4D4.quest_subtitle": "Sp. Attacchi \/ Felicità",
    "quest.017991E54E435197.quest_subtitle": "Martello del fuoco",
    "quest.017D9EDE8B28F90F.quest_desc": [
        "         La \\&6Ancient Ultra Ball\\&f è un",
        "          Tipo speciale di Poké Ball",
        "",
        "Come \"Ultra Balls\", offre anche",
        "\\&e2.0× Tasso di cattura\\&f per tutti i\\&aPokémon\\&f."
    ],
    "quest.017D9EDE8B28F90F.quest_subtitle": "Un altro Ultra Ball",
    "quest.01CBF28DD8C7872E.quest_desc": [
        "Il rivestimento in metallo \\&7Metal Coat\\&f è un",
        "Possesso di un'arma.",
        "",
        "Aumenta l'efficacia dei mosse di tipo Acciaio di",
        "\\&e1.2×\\&f.",
        "",
        "Se \\&aScyther\\&f o \\&7Onix\\&f lo tengono mentre",
        "Una volta scambiati, si evolveranno in",
        "\\&cScizor\\&f e \\&7Steelix\\&f.",
        "",
        "Lo strato protettivo in metallo è stato consumato.",
        "Durante lo scambio."
    ],
    "quest.01CBF28DD8C7872E.quest_subtitle": "Aumenta l'efficacia dei mosse di tipo Acciaio e fa evolvere Scyther o Onix quando vengono scambiati.",
    "quest.01F7A8552F22030F.quest_subtitle": "Base della nostra palla poke",
    "quest.0219E17F8A9B55C0.quest_desc": [
        "            Il \"Dream Ball\" è un",
        "Tipo speciale di Poké Ball",
        "",
        "Ha un tasso di cattura di \\&e4× quando",
        "Utilizzato per il sonno e per i Pokémon.",
        "",
        "A differenza delle altre Poké Ball, la Poké Ball del Sogno...",
        "Il pallone Ball\\&f non si rompe se viene lanciato contro qualcosa.",
        "Qualsiasi blocco."
    ],
    "quest.0219E17F8A9B55C0.quest_subtitle": "Tasso di cattura del 4x per i Pokémon durante il sonno.",
    "quest.0221AB25927FCDC8.quest_subtitle": "Armatura Neo Plasma",
    "quest.02302D297D15003C.quest_subtitle": "Amaura",
    "quest.02CB1AEA017FBC6B.quest_subtitle": "Omanyte",
    "quest.02DCC2340EBB02A5.quest_subtitle": "Evoluzioni Mega di Pokémon",
    "quest.02E272EDA2797B75.quest_subtitle": "Pokémon del futuro",
    "quest.0306EE2235FDEBAE.quest_desc": [
        "Posiziona i blocchi \"\\&e3\" all'interno di \"\\&dCloning\".",
        "\"Machine\\&f e, dopo alcuni secondi,",
        "Appare un A e un Ditto.",
        "",
        "Se viene creato un Pokémon Mewtwo di livello 5, allora…",
        "Distruggere il serbatoio \\&6Orange Tank\\&f, lasciando",
        "La macchina è inutilizzabile. Successivamente, si verifica un malfunzionamento.",
        "Come un Pokémon selvaggio di tipo \"Fuoco\" e \"Psico\" da affrontare.",
        "",
        "Se viene creato un \"\\&dDitto\\&f\", la macchina",
        "Resta intatto. Clicca con il tasto destro per",
        "Combattimento. Se distrutto prima del combattimento,",
        "Il termine \"\\&dDitto\\&f\" sarà perso per sempre.",
        "",
        "In entrambi i casi, \\&dMew\\&f ritorna a…",
        "Il gruppo del giocatore, una volta che il clone è stato creato",
        "Lascia la macchina.",
        "",
        "Ogni \"\\&dMew\\&f\" può essere utilizzato solo 3 volte.",
        "          Con la macchina di clonazione \\&dCloning Machine\\&f."
    ],
    "quest.0306EE2235FDEBAE.quest_subtitle": "Macchina",
    "quest.030E0D3AA4B7DE4D.quest_desc": [
        "È un \"revive\", ma lo ripristina.",
        "La salute (HP) di tutti i Pokémon. Ecco perché.",
        "\\&dmax\\&f."
    ],
    "quest.030E0D3AA4B7DE4D.quest_subtitle": "MAX REVIVE",
    "quest.034CBF2BB2428D4A.quest_desc": [
        "\\&cDynamax\\&f consente di utilizzare le funzionalità di \\&aPokémon\\&f.",
        "Per diventare di dimensioni colossali!",
        "",
        "«Mentre e così via, possono utilizzare»",
        "\\&dMax Moves\\&f — attacchi potenti",
        "Con effetti collaterali aggiuntivi.",
        "",
        "Ogni movimento di \\&eStatus diventa il",
        "\\&eMax Guard\\&f spostamento."
    ],
    "quest.034CBF2BB2428D4A.quest_subtitle": "È ora di diventare un gigante.",
    "quest.0355B467CFBF5269.quest_desc": [
        "A \\&eThunder Stone\\&f è un'evoluzione",
        "Pietra che può essere ottenuta tramite",
        "Artigianato, pesca e molto altro.",
        "",
        "\\&eThunder Stone\\&f può essere utilizzato per",
        "Evoluzioni successive:",
        "",
        "\\&6Pikachu \\&f→ \\&6Raichu \\&per \\&6Raichu di Alola",
        "\\&6Magneton → \\&6Magnezone",
        "\\&6Eevee → \\&6Jolteon",
        "\\&6E Elettrico → \\&6E Elettro",
        "\\&6Charjabug → \\&6Vikavolt."
    ],
    "quest.0355B467CFBF5269.quest_subtitle": "Tipo fulmine",
    "quest.038252FD4B697DFE.quest_subtitle": "Pietra dell'Evoluzione Mega",
    "quest.03826599210F6AEB.quest_desc": [
        "A \\&6Binding Band\\&f è un oggetto da tenere in mano.",
        "Aumenta i danni causati dagli attacchi che immobilizzano l'avversario.",
        "",
        "Fissare, agganciare, spruzzare, infestazione",
        "Tomba di sabbia, vortice e avvolgimento.",
        "",
        "Il danno residuo va da \\&a⅛\\&f."
    ],
    "quest.03826599210F6AEB.quest_subtitle": "Aumenta i danni causati dagli attacchi che immobilizzano l'avversario.",
    "quest.03C47F371DF532DE.quest_desc": [
        "           \\&bMigliora i tuoi Pokémon",
        "                  A livelli \\&d15."
    ],
    "quest.03C47F371DF532DE.quest_subtitle": "È ora di metterlo in pratica.",
    "quest.03C47F371DF532DE.title": "Avanzare di livello",
    "quest.03C9D280FF1EFB88.quest_desc": [
        "Un \"Oval Stone\" è un oggetto tenuto nel possesso del giocatore.",
        "Per \\&6Happiny\\&f. Se \\&6Happiny\\&f",
        "Avanzamento dei livelli durante il giorno, mantenendo una posizione.",
        "Una pietra ovale, che si trasformerà in…",
        "\\&6Chansey\\&f, consumando l'oggetto in",
        "Procedimento."
    ],
    "quest.03C9D280FF1EFB88.quest_subtitle": "Happiny -> Chansey",
    "quest.04055BFFF6CCD552.quest_desc": [
        "A \\&dHyper Potion\\&f è un tipo di",
        "Farmaci utilizzati per curare i Pokémon malati.",
        "         Di \\&a120 HP\\&f. Può essere utilizzato",
        "Inviando un'e-mail con il soggetto \"Pokémon\" e",
        "Utilizzare il prodotto \\&dHyper Potion\\&f su",
        "                   \\&ePokémon\\&f."
    ],
    "quest.04055BFFF6CCD552.quest_subtitle": "HP",
    "quest.04099236CB6A4729.quest_desc": [
        "                \\&aLeek\\&f è un",
        "Possesso di un'arma.",
        "",
        "Questo solleva questioni cruciali riguardo a Farfetch'd.",
        "        Tasso di successo per ogni fase (e+2).",
        "",
        "Un Pokémon selvatico di tipo Farfetch'd ha una probabilità del \\&e5%\\&f",
        "Opportunità di tenere un \"aLeek\\&f\"",
        "Quando è stato catturato."
    ],
    "quest.04099236CB6A4729.quest_subtitle": "Aumenta la probabilità di colpire con attacchi critici di Farfetch'd.",
    "quest.04499526B78D81B5.quest_subtitle": "Equipaggiamento protettivo per il team",
    "quest.04598B4679AA7989.quest_subtitle": "Migliorare i nostri strumenti",
    "quest.04598B4679AA7989.title": "Strumenti",
    "quest.04C0767FAA6213B9.quest_desc": [
        "A \\&6Dire Hit\\&f è un prodotto che",
        "Può essere utilizzato con Pokémon e",
        "       Aumentare la sua percentuale di successi critici",
        "In due fasi."
    ],
    "quest.04C0767FAA6213B9.quest_subtitle": "Critico",
    "quest.050D3CABE6B2DAC3.quest_desc": [
        "\"Good Rod\" è un articolo.",
        "Utilizzato per la pesca e per la raccolta di Pokémon.",
        "\\&bAcqua\\&f per \\&6Lava\\&f.",
        "",
        "Ha una probabilità di 1\/100 di scomparire da",
        "Quando A e B vengono sconfitti, e",
        "Può essere realizzato\/creato.",
        "",
        "Il \"Good Rod\" permette di catturare Pokémon più rari.",
        "Più vecchio del \"Vecchio Rod\", a seconda di...",
        "L'ambiente in cui il giocatore si trova.",
        "",
        "Può anche essere ottenuta da \\&bRare\\&f",
        "\\&dPokémon leggendario\\&f."
    ],
    "quest.050D3CABE6B2DAC3.quest_subtitle": "In realtà, è piuttosto buono.",
    "quest.0520E582AB1926B5.quest_desc": [
        "«A \\&dPower Lens\\&f è un oggetto che fornisce energia».",
        "Quando un Pokémon viene catturato, ottiene automaticamente 51 punti EV (Effort Value) in tutte le categorie.",
        "Inoltre, statistiche di Attacco e Difesa aumentano di +8 dopo la battaglia.",
        "Il valore di \\&bSpeed\\&f viene dimezzato.",
        "",
        "Se viene utilizzato durante la stagione riproduttiva, l'\\&dSp. Atk IV\\&f",
        "Viene trasmesso alla prole."
    ],
    "quest.0520E582AB1926B5.quest_subtitle": "SP. Attacco",
    "quest.053D6B5FB594D308.quest_desc": [
        "An \\&7Iron\\&f è un tipo di",
        "Farmaco che fornisce 10 punti di statistica \"Difesa\"",
        "   Se possibile, inviate anche le immagini dei Pokémon.",
        "Aumenta la felicità del Pokémon.",
        "\\&a5\\&f, \\&a3\\&f, oppure \\&a2\\&f, a seconda di come",
        "Inizialmente, offre molta gioia."
    ],
    "quest.053D6B5FB594D308.quest_subtitle": "Veicoli elettrici per la difesa \/ Felicità",
    "quest.0547175BC9839431.quest_desc": [
        "Un \"capsule di abilità\" è un elemento.",
        "Questo può essere utilizzato con i Pokémon.",
        "Passare da una delle sue due abilità principali.",
        "",
        "Non può essere utilizzato se il Pokémon indicato è presente.",
        "Ha solo una abilità nascosta o ne ha più di una?",
        "Capacità normale. Inoltre, non può essere modificata.",
        "    Trasformare l'abilità di un Pokémon nella sua forma nascosta.",
        "Capacità — utilizzare un patch specifico per migliorare questa caratteristica.",
        "",
        "La \"capsula di capacità\" scomparirà.",
        "Una volta utilizzato con successo."
    ],
    "quest.0547175BC9839431.quest_subtitle": "Abilità di cambio",
    "quest.056AA44B6FCA6BCA.quest_desc": [
        "A \\&cMagmarizer\\&f può essere tenuto da",
        "\\&6Magmar\\&, in modo che evolva in",
        "\\&6Magmortar\\&f quando viene scambiato. Viene consumato.",
        "Una volta che l'evoluzione si verifica."
    ],
    "quest.056AA44B6FCA6BCA.quest_subtitle": "Magmar -> Magmortar",
    "quest.05A28520F6C50AB4.quest_subtitle": "Colpo d'acqua",
    "quest.05B9DC11603C2DB9.quest_desc": [
        "\"A \\&dSachet\\&f\" è un oggetto di uso singolo per",
        "\\&eSpritzee\\&f. Se venduto durante",
        "Tenendolo, \\&eSpritzee\\&f si evolve.",
        "       Into \\&bAromatisse\\&f, consumando",
        "                  Il sacchetto \\&dSachet\\&f."
    ],
    "quest.05B9DC11603C2DB9.quest_subtitle": "Spritzee -> Aromatisse",
    "quest.05E24521F79A902A.quest_desc": [
        "   L'orologio da parete \"Silver Hourglass\" di \\&7Isi vi permette di",
        "Salta il 25% del tempo di riproduzione.",
        "Per un Pokémon specifico."
    ],
    "quest.05E24521F79A902A.quest_subtitle": "Salta il 25%",
    "quest.05E24521F79A902A.title": "Ouroboros d'argento",
    "quest.05F0A15F66F8062A.quest_desc": [
        "Il \\&eUltranecrozium Z\\&f è un prodotto unico.",
        "\\&eZ-Crystal\\&f per le forme di \\&eNecrozma\\&f.",
        "",
        "Sposta questo e lo schermo eZ-Crystal.",
        "Trasformare:",
        "",
        "\\&ePhoton Geyser\\&f diventa",
        "\\&dLight che brucia il cielo\\&f attacco.",
        "",
        "\\&7Speciale:\\&f Solo l'Ultra Necrozma è in grado di",
        "Usalo. \\&eDusk Mane\\&f o \\&eDawn Wings\\&f",
        "È necessario effettuare la manutenzione preventiva prima dell'uso.",
        "",
        "\\&cEmbargo\\&f, \\&cKlutz\\&f o \\&cTrick\\&f non sono",
        "Fai in modo che il Pokémon perda il cristallo Z.",
        "Sta resistendo."
    ],
    "quest.05F0A15F66F8062A.quest_subtitle": "Necrozma-Dusk Mane e Necrozma-Dawn Wings",
    "quest.0601C78299027C71.quest_desc": [
        "       Il \\&dTapunium Z\\&f è un prodotto unico.",
        "\\&eZ-Crystal\\&f per i quattro \\&dTapus\\&f.",
        "",
        "Sposta questo e lo schermo eZ-Crystal.",
        "Trasformare:",
        "",
        "«\\&dNature's Madness\\&f» diventa il",
        "Attacco di \\&dGuardiano di Alola\\&f.",
        "",
        "\\&7Speciale:\\&f Solo Tapu Koko, Lele,",
        "Bulu\\&f e \\&dFini\\&f possono utilizzare questa mossa.",
        "",
        "\\&cEmbargo\\&f, \\&cKlutz\\&f o \\&cTrick\\&f non sono",
        "Fai in modo che il Pokémon perda il cristallo Z.",
        "Sta resistendo."
    ],
    "quest.0601C78299027C71.quest_subtitle": "Tapu Koko, Tapu Lele, Tapu Bulu e Tapu Fini",
    "quest.0610CD8757A8DCC8.quest_subtitle": "Pietra dell'Evoluzione Mega",
    "quest.06F9555171BA34B4.quest_subtitle": "Attacco speciale",
    "quest.06FF96425CB0D89C.quest_desc": [
        "L'armatura \"Assault Vest\" è un oggetto da tenere in mano.",
        "Aumenta la difesa e la protezione del veicolo del 50%, ma",
        "Impedisce l'utilizzo di mosse di stato. Se",
        "Il soggetto non può agire; utilizzerà la strategia della resistenza."
    ],
    "quest.06FF96425CB0D89C.quest_subtitle": "Aumenta la difesa di Sp. del 50%, ma impedisce l'uso di mosse basate sullo stato (status).",
    "quest.07A495A2137F7088.quest_subtitle": "Dracovish",
    "quest.07C97DF1346B72D3.quest_subtitle": "Re del mondo distorto",
    "quest.07E1E7ABFA7B8848.quest_desc": [
        "     Il \"\\&dGenius Feather\\&f\" è un tipo di",
        "Farmaci che aumentano l'attacco (ATK).",
        "       Valore e caratteristiche di un Pokémon, se",
        "Fare clic con il tasto destro, per consumare l'oggetto.",
        "Dopo l'uso."
    ],
    "quest.07E1E7ABFA7B8848.quest_subtitle": "Attacco speciale EV",
    "quest.07E3DDF73E27F2AF.quest_subtitle": "Pietra dell'Evoluzione Mega",
    "quest.07EB3DCF01CF91D2.quest_desc": [
        "A \\&cFiery Shrine\\&f è un luogo di culto.",
        "Questo può essere trovato raramente in \\&6Mesa\\&f.",
        "                    Biomi.",
        "",
        "Se si possedesse una sfera di \"Anime Ardenti\" completamente carica.",
        "È collocata al centro, precisamente nel suo elemento principale, il",
        "\\&dMoltres\\&f apparirà."
    ],
    "quest.07EB3DCF01CF91D2.quest_subtitle": "Aquila di fuoco",
    "quest.0816C00C6F755ED8.quest_desc": [
        "Esiste una probabilità di circa 1\/512 che",
        "e un Pokémon nella sua forma Gigantamax",
        "Avrà le caratteristiche di \\&dG-Max Factor\\&f.",
        "",
        "Questo permette di utilizzare la forma Gigantamax in battaglia.",
        "Tuttavia, non è disponibile in \"Ultra Space\".",
        "",
        "Puoi consultare lo schermo \"\\&dSummary\\&f\" per",
        "Verificate se il vostro Pokémon ha questa caratteristica.",
        "",
        "Il fattore \"\\&dG-Max\" non può essere ereditato.",
        "Attraverso l'incrocio tra genitori.",
        "",
        "Tuttavia, è possibile concederlo nutrendo l'animale.",
        "     Aggiungi \\&eMax Soup\\&f alla tua squadra di \\&aPokémon\\&f."
    ],
    "quest.0816C00C6F755ED8.quest_subtitle": "Vincere il grande premio :)",
    "quest.0816C00C6F755ED8.title": "Forma Gigantamax",
    "quest.08171C1AD6C74D23.quest_desc": [
        "An \\&5Ether\\&f è un tipo di",
        "Farmaci utilizzati per ripristinare la funzionalità del PP\\&f",
        "A uno dei movimenti di un Pokémon di tipo E."
    ],
    "quest.08171C1AD6C74D23.quest_subtitle": "PP",
    "quest.08207A69FF8F5058.quest_subtitle": "\\&Attacco speciale \\&8\/ \\&Attacco",
    "quest.0859FDCF195EFD53.quest_desc": [
        "Per diventare un maestro di Pokémon,",
        "Avete bisogno di più di",
        "Semplicemente, abilità nel gioco \\&cbattle\\&f.",
        "",
        "Questi oggetti possono esserti utili.",
        "\\&aEvolvi i tuoi Pokémon o",
        "Migliorare le loro auto elettriche.",
        "               \\&e Le loro statistiche\\&f.",
        "",
        "Sii intelligente e costruisci.",
        "\\&Un team galattico",
        "Proprio come il Real Madrid del 2005."
    ],
    "quest.0859FDCF195EFD53.quest_subtitle": "Aumenta gli oggetti",
    "quest.085B4665F7E1759A.quest_desc": [
        "A \\&7Protector\\&f è un oggetto da tenere in mano.",
        "Questo si evolve in \\&bRhyperior\\&f.",
        "Se si detiene \\&eRhydon\\&f e si decide di scambiarlo,",
        "Il \\&7Protector\\&f viene consumato e",
        "\\&eRhydon\\&f si evolve.",
        "",
        "Può essere trovato come oggetto di livello 2.",
        "Da luoghi iconici come i \"Pokéstops\" o come",
        "Rimuovi da \\&bRhyperior\\&f."
    ],
    "quest.085B4665F7E1759A.quest_subtitle": "Rhydon -> Rhyperior",
    "quest.090A4964704D3149.quest_subtitle": "Chansey, Blissey → Happiny",
    "quest.091C9811D37DF04B.quest_subtitle": "Una divinità",
    "quest.0922B37AC6361295.quest_desc": [
        "Dobbiamo aumentare e migliorare.",
        "                   Il nostro team...",
        "",
        "Creiamo insieme delle Poké Ball",
        "       Catturate nuovi Pokémon per noi!"
    ],
    "quest.0922B37AC6361295.quest_subtitle": "Abbiamo bisogno di Pokémon.",
    "quest.09A393448DF8928E.quest_desc": [
        "         Il \\&8Darkinium Z\\&f è un prodotto unico",
        "\\&eZ-Crystal\\&f per i Pokémon di tipo Oscuro.",
        "",
        "Sposta questo e lo schermo eZ-Crystal.",
        "Trasformare:",
        "",
        "Qualsiasi mossa di tipo Oscurità che non sia una",
        "Lo status cambia, diventa aggressivo.",
        "\\& Attacco all'anomalia gravitazionale.",
        "",
        "\\&cEmbargo\\&f, \\&cKlutz\\&f o \\&cTrick\\&f non sono",
        "Fai in modo che il Pokémon rilasci il cristallo Z.",
        "Sta resistendo."
    ],
    "quest.09A393448DF8928E.quest_subtitle": "Tipo: Oscuro",
    "quest.0A64F97FA679758D.quest_subtitle": "Armatura del mattino",
    "quest.0A6D279BC9400095.quest_desc": [
        "\\&dExp. Candies\\&f sono articoli che…",
        "Sono state aggiunte a \\&bPixelmon\\&f.",
        "Candy fornisce una quantità fissa di \\&aEXP\\&f.",
