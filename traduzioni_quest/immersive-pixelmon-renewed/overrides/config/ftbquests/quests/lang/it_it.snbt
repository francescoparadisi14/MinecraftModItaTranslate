    "quest.4C5BFE3D508B372E.quest_desc": [
        "\\&dNumero massimo di mosse\\&f Effetti",
        "",
        "\\&fNormale → \\&dMassimo",
        "↓ Riduce la velocità di attacco dei nemici.",
        "",
        "\\&cFighting → \\&dMassetto\/Articolazione\\&f",
        "↑ Aumenta il numero di utenti e l'efficacia dell'attacco.",
        "",
        "\\&bVola\\&f → \\&dMax Airstream\\&f",
        "↑ Aumenta il numero di utenti e la velocità di accesso.",
        "",
        "\\&5Poison → \\&dMax Ooze\\&f",
        "↑ Aumenta l'esperienza e l'attacco del giocatore.",
        "",
        "\\&6Superficie → \\&dMassimo terremoto\\&f",
        "↑ Aumenta l'utilizzo e la soddisfazione dell'utente.",
        "",
        "\\&7Rock → \\&dFrana di rocce\\&f",
        "→ Invito a Sandstorm (5 turni).",
        "",
        "\\&2Bug → \\&dMax Flutterby\\&f",
        "↓ Riduce i valori di difesa e attacco nemico.",
        "",
        "\\&5Ghost → \\&dMax Phantasm\\&f",
        "↓ Riduce i costi di difesa e di sicurezza.",
        "",
        "\\&7Steel → \\&dMax Steelspike\\&f",
        "↑ Aumenta la difesa dell'utente.",
        "",
        "\\&cFuoco → \\&dMassima fiamma\\&f",
        "→ Imposta: 6 (Luce solare intensa) (5 turni).",
        "",
        "\\&bAcqua → \\&dGeyser più potente\\&f",
        "→ Inizio e fine (5 turni).",
        "",
        "\\&aErba → \\&dCrescita eccessiva\\&f",
        "→ Terreno erboso e aree verdi (5 turni).",
        "",
        "\\&eElettrico → \\&dMassima potenza\\&f",
        "→ Imposta le opzioni \"Terreno elettrico\" (5 giri).",
        "",
        "\\&dPsicologia → \\&dMassima Creatività Mentale\\&f",
        "→ Imposta i terreni e gli elementi psicici (5 turni).",
        "",
        "\\&bIce → \\&dGrandissima tempesta di neve\\&f",
        "→ Inizio e fine (5 turni).",
        "",
        "\\&5Dragon → \\&dMax Wyrmwind\\&f",
        "↓ Riduce i danni e l'attacco del nemico.",
        "",
        "\\&8Dark → \\&dMassima Oscurità\\&f",
        "↓ Riduce i valori di foe e dSp. Def\\&f.",
        "",
        "\\&dFairy → \\&dMax Starfall\\&f",
        "→ Imposta: Terreno nebbioso e 5 turni.",
        "",
        "\\&fStato → \\&dMassimo Guardia\\&f",
        "→ Protegge da tutti i movimenti e le azioni,",
        "Anche eMax Moves."
    ],
