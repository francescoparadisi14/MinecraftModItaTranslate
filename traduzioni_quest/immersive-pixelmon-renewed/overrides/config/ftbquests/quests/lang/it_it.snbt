    "quest.5268DED6DFFE743D.quest_subtitle": "Aumenta la difesa contro gli attacchi psichici quando si entra in un territorio psichico.",
    "quest.526AFD5D5D01A249.quest_subtitle": "Marill, Azumarill → Azurill",
    "quest.52F34CEBEAA3A658.quest_desc": [
