    "quest.6338282EBCD157DA.quest_subtitle": "Aumenta l'efficacia dei movimenti di tipo Normale.",
    "quest.6358B3870A3DF274.quest_subtitle": "La parte superiore della nostra palla poke.",
    "quest.638CBAD87356F58B.quest_desc": [
