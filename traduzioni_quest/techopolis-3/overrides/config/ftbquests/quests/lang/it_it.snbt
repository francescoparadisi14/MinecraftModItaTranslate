    ],
    "quest.5BD9A92ED3ED17A3.quest_desc": [
        "Permette a \\&lCloche\\&r di produrre una maggiore quantità del suo prodotto principale, fino a 3 unità. La coltivazione di \\&lSaplings Wood\\&r è il suo prodotto principale."
    ],
    "quest.5BE16EC567FBE306.quest_desc": [
