    "quest.73B1C328C3075F14.quest_desc": [
        "Realizzato con foglie verdi"
    ],
    "quest.73C264670B494FAC.quest_desc": [
        "So, so so, so so so so so so so so so so so so so so so so so so so so so so so so so so so so so so so"
    ],
    "quest.73E53E51D7957AF6.quest_desc": [
