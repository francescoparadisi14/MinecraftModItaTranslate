    "file.0000000000000001.title": "Techopolis 3",
    "quest.0053618E0271F957.quest_desc": [
        "Techopolis 3 può essere giocato utilizzando gli shader. Apri le impostazioni video e clicca su \"Pacchetti shader\" nell'angolo in alto a destra!"
    ],
    "quest.00CCDA4B2A03A02C.quest_desc": [
        "Incorpora elementi provenienti dai supporti espositivi. Esempio di configurazione nella pagina successiva.",
        "",
        "{@pagebreak}",
        "",
        "{image:techopolis:textures\/quests\/empowerer.png width:300 height:160 align:center}"
    ],
    "quest.00EF32F20DE35A98.quest_desc": [
        "Una parte di \\&lRocket\\&r"
    ],
    "quest.0166F6102DBEF6D6.quest_desc": [
        "I \"Mob drops\" possono essere fusi in \"Mob Essence\" utilizzando il \"Fluidizer\"."
    ],
    "quest.0166F6102DBEF6D6.quest_subtitle": "\\&l\\&a\\&oUltimate Technium Parte",
    "quest.0166F6102DBEF6D6.title": "Essenza di Mob",
    "quest.01690697BC82295D.quest_desc": [
        "Quando viene utilizzato in un sistema di fabbricazione, il \"Loot Fabricator\" produce gli oggetti di questi mostri."
    ],
    "quest.017C162A050D129F.quest_desc": [
        "Prodotto all'interno del compressore \\&lTechnium\\&r"
    ],
    "quest.0180950FFA87D3C7.quest_desc": [
        "Un bel blocco"
    ],
    "quest.0180950FFA87D3C7.quest_subtitle": "\\&l\\&0Hellish Technium Part\\&r\\&r",
    "quest.019BCC696C72050D.quest_desc": [
        "Permette di estrarre blocchi simili a \"\\&lStone\\&r\" all'interno di un'area di 3x3."
    ],
    "quest.01B3635697A7D3CA.quest_desc": [
        "Permette di collegare più cavi."
    ],
    "quest.01B5ABED3DA40D63.quest_desc": [
        "Canali"
    ],
    "quest.01BFDC0B1C4A894B.quest_desc": [
        "Scorie e polveri"
    ],
    "quest.01DF5373D68A8CAA.quest_desc": [
        "Il capitolo \"\\&lChallenges\\&r\" contiene sfide uniche da completare, e la ricetta del \"\\&lFinal Technium\\&r\" richiederà che tu abbia ottenuto l'ultimo oggetto presente nelle \"\\&lQuestlines\\&r\"."
    ],
    "quest.01DF5373D68A8CAA.title": "Sfide",
    "quest.01E8108CA111E542.quest_desc": [
        "Posiziona il dispositivo su un tubo collegato alla destinazione desiderata."
    ],
    "quest.02047C016E39B808.quest_desc": [
        "Il primo di molti"
    ],
    "quest.0204CA6DDAEA7423.quest_desc": [
        "Quando viene utilizzato in un sistema di fabbricazione, il \"Loot Fabricator\" produce gli oggetti di questi mostri."
    ],
    "quest.025B25994A61A108.quest_desc": [
        "Prodotto all'interno del compressore \\&lTechnium\\&r"
    ],
    "quest.026328E3C2FDA38E.quest_desc": [
        "Fusione di pietra"
    ],
    "quest.0265FA8CABA2C511.quest_desc": [
        "Una parte essenziale dell'equipamento spaziale, necessaria per realizzare il proprio sogno di esplorare lo spazio."
    ],
    "quest.026A04E8FB27154F.quest_desc": [
        "L'osmium è una risorsa molto utile."
    ],
    "quest.02C09BA6478727D0.quest_desc": [
        "Quando viene utilizzato in un sistema di fabbricazione, il \"Loot Fabricator\" produce gli oggetti di questi mostri."
    ],
    "quest.02D52E30F9E2D82E.quest_desc": [
        "Un bel piatto"
    ],
    "quest.02D52E30F9E2D82E.quest_subtitle": "\\&l\\&3Lunar Technium Part\\&r\\&r",
    "quest.02E8DF1B56173DBF.quest_desc": [
        "Legatura di \\&lBricks\\&r e \\&lNetherrack\\&r"
    ],
    "quest.02E90F7F56728D15.quest_desc": [
        "Prodotto nella \\&Chambra di arricchimento\\&"
    ],
    "quest.031A62A092B5CD45.quest_desc": [
        "Una struttura molto grande, composta da diversi blocchi, utilizzata per la produzione di lingotti di \"Tecnium Lunare\".",
        "",
        "Ora richiede l'uso di un sistema di riscaldamento per la lavorazione. Utilizza il sistema di riscaldamento \"Mekanism\"."
    ],
    "quest.032C6576D6D8F727.quest_desc": [
        "Questo è di \"\\&lMoon Stone Dust\\&r\""
    ],
    "quest.032C6576D6D8F727.quest_subtitle": "\\&l\\&3Lunar Technium Part\\&r\\&r",
    "quest.0378DC2310179750.quest_desc": [
        "Permette la creazione di reattori molto più grandi utilizzando i blocchi rinforzati."
    ],
    "quest.038576AD8DE4328B.quest_desc": [
        "I tronchesi possono essere utilizzati per tagliare i fili di rame dai fogli di rame."
    ],
    "quest.03BA21F0D2253622.quest_desc": [
        "Semplice, il migliore: Ender Ingot (e altri materiali simili)"
    ],
    "quest.03C87072DE7CF74D.quest_desc": [
        "Prodotto all'interno della \\&lRock Washer\\&r"
    ],
    "quest.03CB98BB60DD3FC4.quest_desc": [
        "Non rottami antichi"
    ],
    "quest.03D9221617907FC8.quest_desc": [
        "Grazie per aver giocato a \\&lTechopolis 3\\&r. Spero che vi sia piaciuto il pacchetto. Vi invito a lasciare qualsiasi feedback o suggerimento sul server Discord."
    ],
    "quest.03E6D3A4D7F8CE8F.quest_desc": [
        "Lo strumento di estrazione digitale può essere utilizzato per trovare minerali. Per trovare il Netherite, è necessario utilizzare il tag \"techopolis:netherite_ore\"."
    ],
    "quest.0400F719BCB991C1.quest_desc": [
        "È molto!"
    ],
    "quest.04B9780F7FDEA78C.quest_desc": [
        "Un bel blocco"
    ],
    "quest.04B9780F7FDEA78C.quest_subtitle": "\\&5\\&Parte finale di Technium\\&r\\&r",
    "quest.054406E766E69913.quest_desc": [
        "Permette di colorare i blocchi sia nel mondo, sia all'interno del tavolo da lavoro."
    ],
    "quest.054406E766E69913.title": "Bombo per spray",
    "quest.0561C57B9F1E095C.quest_desc": [
        "La prossima fase di \\&lTechnium\\&r. Grazie per aver giocato a \\&lTechopolis 3\\&r. Se desiderate continuare, ecco le prossime sfide..."
    ],
    "quest.0561C57B9F1E095C.quest_subtitle": "\\&l\\&0Hellish Technium Part\\&r\\&r",
    "quest.059999914CE99711.quest_desc": [
        "Sblocca cassetti compattabili"
    ],
    "quest.05C21693A27255DC.quest_desc": [
        "Inietta sostanze liquide"
    ],
    "quest.05D1D1200F5E4844.quest_desc": [
        "Un blocco di quarzo nero"
    ],
    "quest.05D1D1200F5E4844.quest_subtitle": "\\&l\\&e\\&o Elite Technium Part",
    "quest.05D479B9DDE194CF.quest_desc": [
        "Realizzato con gas di antimateria, che può essere prodotto in un reattore nucleare."
    ],
    "quest.063CD8B83507C100.quest_desc": [
        "Ottenuto tramite la pompa dell'olio."
    ],
    "quest.063CD8B83507C100.quest_subtitle": "\\&l\\&0Hellish Technium Part\\&r\\&r",
    "quest.06503659AE472AD3.quest_desc": [
        "Prodotto all'interno di un forno a fusione"
    ],
    "quest.065B9B9AF769DB4B.quest_desc": [
        "Utilizzando il dispositivo \\&lAtomic Reconstructor\\&r, il \\&lLapis\\&r può essere trasformato in \\&lPalis\\&r."
    ],
    "quest.065B9B9AF769DB4B.quest_subtitle": "\\&l\\&7\\&oTecnium Avanzato",
    "quest.06C5F60B8492E319.quest_desc": [
        "Permette la simulazione di \\&lMoglers\\&r"
    ],
    "quest.06F34439F284357B.quest_desc": [
        "Quando viene utilizzato in un sistema di fabbricazione, il \"Loot Fabricator\" produce gli oggetti di questi mostri."
    ],
    "quest.072452455ED47638.quest_desc": [
        "\\&Artigianali, pezzi in metallo"
    ],
    "quest.072ADEFA1BEA2599.quest_desc": [
        "Uno zaino semplice e funzionale, e un \"Mekanism Personal Barrel\" possono essere utilizzati in seguito per ottenere ancora più spazio!"
    ],
    "quest.0745AB834C47356A.quest_desc": [
        "Prodotto all'interno del dispositivo \\&lInscriber\\&r"
    ],
    "quest.074C320C2BAFEAAA.quest_desc": [
        "All'interno del dispositivo \"\\&lDimensional Infuser\\&r\", è possibile trasformare \"\\&lLunar Gas\\&r\" e \"\\&lMoon Stone\\&r\" in \"\\&lBlank Moon Ore\\&r\"."
    ],
    "quest.07ACC46AA884FC37.quest_desc": [
        "Permette di ottenere direttamente il \\&lZinc\\&r. Funziona solo in \\&lThe Nether\\&r"
    ],
    "quest.07C8351E6DCE3CBB.quest_desc": [
        "Prodotto all'interno del compressore \\&lTechnium\\&r"
    ],
    "quest.07E6B3BA5FC9E1D4.quest_desc": [
        "Realizzato con foglie"
    ],
    "quest.07FE6823ADD7A387.quest_desc": [
        "Trasporto di fluidi semplice"
    ],
    "quest.0823F549D6991801.quest_desc": [
        "Un blocco di mattoni"
    ],
    "quest.0823F549D6991801.quest_subtitle": "\\&6\\&oA Parte Tecnica",
    "quest.083CAE2D8111C611.quest_desc": [
        "La combustione dei legni produce carbone."
    ],
    "quest.08405BECD7E39C63.quest_desc": [
        "Questi si collegano ai blocchi di ricezione o di fornitura di energia."
    ],
    "quest.08693FE4B1E232EA.quest_desc": [
        "Permette l'inserimento di un singolo elemento."
    ],
    "quest.0890C86BAB7A4D5F.quest_desc": [
        "Illuminare la strada"
    ],
    "quest.08BC73B7535E3A35.quest_desc": [
        "Dall'alto verso il basso"
    ],
    "quest.08EA99E0B8085270.quest_desc": [
        "Utilizzato per creare e realizzare aggiornamenti per la \\&lCloche\\&r"
    ],
    "quest.08F4F99CC66A81C0.quest_desc": [
        "Prodotto all'interno della \\&lRock Washer\\&r"
    ],
    "quest.0904B8D5278992EA.quest_desc": [
        "Per avviare l'estrazione e la lavorazione delle \"Dimensionale Ores\", sono necessarie più macchine e risorse per ottenere il minerale."
    ],
    "quest.0923F0562473A387.quest_desc": [
        "Una struttura molto grande, composta da diversi blocchi, utilizzata per la creazione di lingotti di \"Ultimate Technium\".",
        "",
        "Ora richiede l'uso di sostanze chimiche nella fabbricazione e nell'utilizzo di \"Technium\""
    ],
    "quest.097D5C49B448F3B9.quest_desc": [
        "Riduce il tempo totale necessario per la coltivazione, consentendo di mettere fino a 3 piantine nella \\&lCloche\\&r."
    ],
    "quest.09827A07A75DF349.quest_desc": [
        "Una canna da pesca di buona qualità."
    ],
    "quest.09827A07A75DF349.quest_subtitle": "\\&l\\&a\\&oUltimate Technium Parte",
    "quest.09ABAFBB12D74469.quest_desc": [
        "Proveniente da \"\\&lRock Washer\\&r\""
    ],
    "quest.09D5E36EB0574F45.quest_desc": [
        "Così potente"
    ],
    "quest.09EF9B22F858DCE6.quest_desc": [
        "Permette al dispositivo \"Rock Enricher\" di creare \"Diorite\"."
    ],
    "quest.09FF97158E17565C.quest_desc": [
        "Conservare i propri oggetti"
    ],
    "quest.0A0237AE923A1D54.quest_desc": [
        "Credo di vedere che state lavorando lì."
    ],
    "quest.0A0237AE923A1D54.quest_subtitle": "blu",
    "quest.0A395A395EBDD868.quest_desc": [
        "SpaCy"
    ],
    "quest.0A3CB43A3D868208.quest_desc": [
        "\\&lOsmium\\&r e \\&lGlowstone\\&r"
    ],
    "quest.0A7C18B9B674C011.quest_desc": [
        "Telaio semplice per macchine semplici"
    ],
    "quest.0AC7CD4213D2CD1B.quest_desc": [
        "Realizzato con materie prime e processato tramite un macchinario di frantumazione."
    ],
    "quest.0AF6328452C21974.quest_desc": [
        "Posizionare quelle presse"
    ],
    "quest.0B1C5E41D5A8AE66.quest_desc": [
        "Una canna da pesca di buona qualità."
    ],
    "quest.0B1C5E41D5A8AE66.quest_subtitle": "\\&5\\&Parte finale di Technium\\&r\\&r",
    "quest.0B35DE200673A337.quest_desc": [
        "Uno strumento rudimentale utilizzato per abbattere alberi."
    ],
    "quest.0B592478EB281CBC.quest_desc": [
        "Prodotto all'interno del filtro industriale."
    ],
    "quest.0B68208E5E5CC71C.quest_desc": [
        "Più \"Cobblestone\""
    ],
    "quest.0B6CFA77F78F9359.quest_desc": [
        "Un sottoprodotto dell'utilizzo della \\&lCamera di simulazione\\&r. Può essere utilizzato per creare successivamente il \\&lEssenza di Mob fusa\\&r."
    ],
    "quest.0BC3D907EA723897.quest_desc": [
        "Elementi appresi\/salvati"
    ],
    "quest.0BE2D11B6AAFEC01.quest_desc": [
        "Un buon ingranaggio"
    ],
    "quest.0BE2D11B6AAFEC01.quest_subtitle": "\\&l\\&a\\&oUltimate Technium Parte",
    "quest.0BF0151D63C255BC.quest_desc": [
        "Polvere di fluorite arricchita"
    ],
    "quest.0BF0E529EDF45F6D.quest_desc": [
        "Può essere realizzato nell'\\&lDimensional Infuser\\&r"
    ],
    "quest.0C3BE3E8AEDD8515.quest_desc": [
        "Rende le vostre macchine più efficienti dal punto di vista energetico."
    ],
    "quest.0CABC38EA06FCA63.quest_desc": [
        "Utilizzato nella pressa per metalli"
    ],
    "quest.0CE0403325AA1864.quest_desc": [
        "Raddoppia l'effetto del precedente prodotto per la protezione dal calore."
    ],
    "quest.0CF51FE938E3830E.quest_desc": [
        "Un bel piatto"
    ],
    "quest.0CF51FE938E3830E.quest_subtitle": "\\&l\\&e\\&o Elite Technium Part",
    "quest.0CFF664526B7426C.quest_desc": [
        "Prodotto all'interno del compressore \\&lTechnium\\&r"
    ],
    "quest.0D5BD7BAE0512507.quest_desc": [
        "Un blocco di mattoni per forni di dimensioni 2x2x2 può essere trasformato in un forno per la fusione di leghe."
    ],
    "quest.0D8A03FDDAC4C99B.quest_desc": [
        "Utilizza i materiali ottenuti per costruire oggetti."
    ],
    "quest.0DBF58F1F7A297AF.quest_desc": [
        "Utilizza qualsiasi blocco disponibile nella tua interfaccia di creazione e copri quelle tubature; è molto utile."
    ],
    "quest.0DE9B2C6FE0A05CF.quest_desc": [
        "E i tavoli in legno possono essere trasformati in tavoli da lavoro."
    ],
    "quest.0DE9B2C6FE0A05CF.title": "Tavolo da lavoro",
    "quest.0E2AE31FA80CF621.quest_desc": [
        "Realizzato all'interno della \\&lMob Fabricator\\&r"
    ],
    "quest.0E2AE31FA80CF621.quest_subtitle": "\\&l\\&0Hellish Technium Part\\&r\\&r",
    "quest.0E9C01587AF28CF7.quest_desc": [
        "Questi blocchi, grazie a macchinari avanzati, possono essere rimossi utilizzando una chiave inglese."
    ],
    "quest.0EBD79868F379238.quest_desc": [
        "Un contenitore più utile: i liquidi caldi lo faranno rompere!"
    ],
    "quest.0ED198E1D3F5C6AB.quest_desc": [
        "Il sistema di evaporazione termica. Quando viene fornito con acqua e calore, produce una soluzione salina."
    ],
    "quest.0EFE2EA2AEE1E8FB.quest_desc": [
        "\\&lMercanti del villaggio\\&r sono disabilitati e \\&lMercanti erranti\\&r non appaiono!",
        "",
        "I mostri ostili non appaiono di notte. Continuate a costruire la vostra fabbrica!"
    ],
    "quest.0F0153682C016B95.quest_desc": [
        "Un ingranaggio prodotto da \\&lCopper\\&r, realizzato all'interno del \\&lSolidifier\\&r."
    ],
    "quest.0F45C5B8AA2F3554.quest_desc": [
        "\\&lUltimine\\&r non è disponibile immediatamente in questo pacchetto di mod. Tuttavia, \\&lHammers\\&r distruggono un'area di 3x3 di blocchi simili a pietra, mentre \\&lExcavators\\&r fanno lo stesso con blocchi simili a terra. Inoltre, gli asce distruggono tutti i tronchi connessi su un albero."
    ],
    "quest.0F4BDDB5BE283D54.quest_desc": [
        "E il vetro può essere prodotto all'interno di un forno a fusione."
    ],
    "quest.0F4BDDB5BE283D54.quest_subtitle": "\\&6\\&oA Parte Tecnica",
    "quest.0FAC56A475DB164F.quest_desc": [
        "Permette la creazione di \"Minatori Avanzati\", che producono il doppio rispetto ai \"Minatori Base\"."
    ],
    "quest.0FDC4D0B19E113B8.quest_desc": [
        "I barretti di controllo sono posizionati sopra i barretti contenenti il combustibile."
    ],
    "quest.1022FBAF8115651D.quest_desc": [
        "Può essere utilizzato per creare opzioni più avanzate per la tua rete. Può anche essere utilizzato per creare blocchi personalizzati."
    ],
    "quest.1025BFD3B7686103.quest_desc": [
        "Sembra piuttosto inutile. Inoltre, l'ordine \"Diamanti\" prima di \"oro\" mi sembra strano."
    ],
    "quest.106BD139F3CAB463.quest_desc": [
        "È possibile estrarre qualsiasi tipo di \"oro dimensionale\" che si inserisce nella struttura. La frequenza e il tempo di estrazione varieranno. L'unità \"Estrattore di oro dimensionale\" si occuperà solo di posizionare la struttura, ma sarà necessario inserire manualmente il materiale dimensionale scelto."
    ],
    "quest.1092DD1D298FA2C9.quest_desc": [
        "Attiva la ricarica wireless, che permette di caricare oggetti presenti nell'inventario del giocatore fino a 128 blocchi di distanza! Funziona anche con gli oggetti \"Curios\"."
    ],
    "quest.10A61FF7B8C47750.quest_desc": [
        "Grazie, immagino."
    ],
    "quest.10AFC37627A5BDD7.quest_desc": [
        "È qui che l'elemento liquido esce."
    ],
    "quest.10B32E1B6DDCDD69.quest_desc": [
        "Permette di raccogliere automaticamente le pietre del pavimentato."
    ],
    "quest.1132449608CC9B24.quest_desc": [
        "Prodotto all'interno della \\&lPowered Crusher\\&r"
    ],
    "quest.11374EF234EBD027.quest_desc": [
        "Permette di ordinare gli elementi; per maggiori informazioni su come utilizzarlo, consultare la guida."
    ],
    "quest.1149674B45943F10.quest_desc": [
        "Permette di riciclare alcuni oggetti inutilizzati."
    ],
    "quest.114DAE1A7C9139F1.quest_desc": [
        "Realizzato all'interno della \\&lCamera di Reazione a Pressione\\&r, a partire dal suo materiale di base, sia la versione \\&lNether\\&r che quella \\&lDimensionale\\&r funzionano."
    ],
