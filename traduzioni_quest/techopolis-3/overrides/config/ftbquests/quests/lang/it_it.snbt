    ],
    "quest.737F13286F75F8B3.quest_desc": [
        "Avrete bisogno di una grande quantità di mattoni neri e, forse, un minatore di mattoni potrebbe essere utile.",
        "",
        "Vedi la pagina successiva per un esempio di automazione.",
        "{@pagebreak}",
        "{image:techopolis:textures\/quests\/auto_coal.png width:210 height:127 align:center}"
    ],
    "quest.738D839420D4EB56.quest_desc": [
