[
    "{\r\n\tchapter.0344005D2050979A.title: \"Epreuves !\"\r\n\tchapter.4500B9354E465002.title: \"Sophisticated's !\"\r\n\tchapter.4A38C7A891A7D881.title: \"Energized Power\"\r\n\tchapter.56BFC39514FEA069.title: \"Minecraft Vanilla+\"\r\n\tchapter.6A4F4680299C5B01.title: \"Stockage d'objets\"\r\n\tchapter.78536B353AFA491C.title: \"Cobblemon\"\r\n\tchapter.7ED66C2ADFA3AAD1.title: \"Bienvenue !\"\r\n\tfile.0000000000000001.title: \"Pokéheros 2\"\r\n\tquest.001E4D0147EC6FD0.quest_desc: [\"La taille des piles devient presque absurde.\"]\r\n\tquest.001E4D0147EC6FD0.quest_subtitle: \"Les limites sont une illusion.\"\r\n\tquest.001E4D0147EC6FD0.title: \"Plus aucune limite\"\r\n\tquest.00B6A4B9721B7D9F.quest_desc: [\"Améliore progressivement la taille maximale des stacks dans ton sac.\"]\r\n\tquest.00B6A4B9721B7D9F.quest_subtitle: \"Encore… ENCORE…\"\r\n\tquest.00B6A4B9721B7D9F.title: \"Toujours plus\"\r\n\tquest.0321FA4F76EDA558.quest_desc: [\"Même les plus jeunes Pokémon peuvent devenir puissants. Entraîne un Pokémon jusqu’à atteindre son niveau maximal.\"]\r\n\tquest.0321FA4F76EDA558.quest_subtitle: \"Oui, même lui peut devenir fort. Toi aussi peut-être.\"\r\n\tquest.0321FA4F76EDA558.title: \"Darwin ? Keskecé ?\"\r\n\tquest.0473C7A540F3B9AE.quest_desc: [\"Fabrique un Construction Core et un Destruction Core. Parce que parfois, il faut casser pour mieux reconstruire. Un peu comme tes projets de redstone à 3h du mat’.\"]\r\n\tquest.0473C7A540F3B9AE.quest_subtitle: \"Créer et détruire : le cycle de la vie (version Minecraft)\"\r\n\tquest.0473C7A540F3B9AE.title: \"Le Construction Core\"\r\n\tquest.05215DF144ACE471.quest_desc: [\"Merci d'avoir parler au Doc !\"]\r\n\tquest.05215DF144ACE471.quest_subtitle: \"Doc. Follamour\"\r\n\tquest.05813F518717A015.quest_subtitle: \"De l’entrée de gamme au PC de gamer\"\r\n\tquest.05DD79310C662D63.quest_desc: [\r\n\t\t\"Trouvez le livre d’Energized Power pour commencer votre aventure électrique. \"\r\n\t\t\"\"\r\n\t\t\"Sans ça, vous allez juste brancher des câbles au hasard… et ça, c’est dangereux !\"\r\n\t\t\"\"\r\n\t\t\"@energized power\"\r\n\t]\r\n\tquest.05DD79310C662D63.quest_subtitle: \"Le manuel du savant fou\"\r\n\tquest.05DD79310C662D63.title: \"Le livre d’Energized Power\"\r\n\tquest.0672925E99EEA8AB.quest_desc: [\"Bienvenue dans le monde d’Energized Power, où les câbles s’emmêlent, les batteries explosent (enfin, presque), et où l’énergie est plus précieuse que le diamant. Préparez-vous à électriser votre aventure !\"]\r\n\tquest.0672925E99EEA8AB.quest_subtitle: \"Le câble qui ne vous électrocute pas (en théorie)\"\r\n\tquest.08931A50139CAFCF.quest_subtitle: \"C'est quoi ce pokémon la ?!\"\r\n\tquest.0909AE022245DC7D.quest_desc: [\"Apprends à récolter et multiplier les graines d’Apricorns pour assurer ton autonomie.\"]\r\n\tquest.0909AE022245DC7D.quest_subtitle: \"Enfin une plante qui sert vraiment.\"\r\n\tquest.0909AE022245DC7D.title: \"Cultiver les Apricorns\"\r\n\tquest.0A26BFAD834C2CD2.quest_desc: [\"Fabrique le contrôleur Refined Storage, cœur de ton réseau de stockage.\"]\r\n\tquest.0A26BFAD834C2CD2.quest_subtitle: \"Ne pas débrancher.\"\r\n\tquest.0AFF830D5DC31D0D.quest_desc: [\"Passe à l’âge du fer et améliore ton équipement pour explorer plus loin et plus profond.\"]\r\n\tquest.0AFF830D5DC31D0D.quest_subtitle: \"Le fer, c’est sérieux.\"\r\n\tquest.0AFF830D5DC31D0D.title: \"Outils en fer\"\r\n\tquest.0B77258DFC3CB6EF.quest_desc: [\"Les Apricorns sont la clé de tout bon équipement. Récolte-en pour apprendre les fondations de l’art du dressage Pokémon.\"]\r\n\tquest.0B77258DFC3CB6EF.quest_subtitle: \"Non, les Apricorns ne se mangent pas. Enfin… pas recommandé.\"\r\n\tquest.0B77258DFC3CB6EF.title: \"Les bases du Dresseur\"\r\n\tquest.0BAD7A291A9A8A1E.quest_desc: [\"Construisez un four à alliage pour créer des trucs plus solides que vos excuses quand vous oubliez d’éteindre la lumière.\"]\r\n\tquest.0BAD7A291A9A8A1E.quest_subtitle: \"Le four qui fait fondre les métaux… et les espoirs\"\r\n\tquest.0DFCEEFA6C8D42C2.quest_desc: [\"Créer un basic machine frame qui te permet de créer les machines basic de energized power.\"]\r\n\tquest.10CA76BD57AAAE41.quest_desc: [\r\n\t\t\"Cet étrange appareil semble réagir à l’énergie des dimensions.\"\r\n\t\t\"On raconte qu’il permet d’accéder à des mondes instables,\"\r\n\t\t\"peuplés de créatures hors du commun…\"\r\n\t]\r\n\tquest.10CA76BD57AAAE41.quest_subtitle: \"Un Téléphone magique ?\"\r\n\tquest.12065B782DF78FAB.quest_desc: [\"Fabrique une canne à pêche spéciale pour attirer de nouveaux Pokémon aquatiques.\"]\r\n\tquest.12065B782DF78FAB.quest_subtitle: \"Si ça mord pas, c’est la faute de l’eau. Toujours.\"\r\n\tquest.12065B782DF78FAB.title: \"équipé pour pécho !\"\r\n\tquest.14549DA7819C4FA8.quest_desc: [\"Plus de stockage, plus de solidité.\"]\r\n\tquest.14549DA7819C4FA8.quest_subtitle: \"Industriel, mais élégant.\"\r\n\tquest.14549DA7819C4FA8.title: \"Robuste et efficace\"\r\n\tquest.14E23527F4607E0A.quest_desc: [\"Fabrique ton premier sac à dos Sophisticated.\"]\r\n\tquest.14E23527F4607E0A.quest_subtitle: \"Un petit sac… mais de grandes ambitions.\"\r\n\tquest.14E23527F4607E0A.title: \"Le début du voyage\"\r\n\tquest.161E1309B3094706.quest_desc: [\"Fabrique un set complet d’outils en pierre. Plus solides, plus efficaces, indispensables pour avancer.\"]\r\n\tquest.161E1309B3094706.quest_subtitle: \"C’est moche, mais ça marche.\"\r\n\tquest.161E1309B3094706.title: \"Rammaser de la pierre\"\r\n\tquest.17CA68399A714BF2.quest_desc: [\"Ajouter de l'or et d'autres bouts de fragments pour fabriquer un lingot de netherite !\"]\r\n\tquest.182209C63CE27895.quest_subtitle: \"C'est fini ?!\"\r\n\tquest.182209C63CE27895.title: \"L'End ?!\"\r\n\tquest.1971331A95A974D6.quest_subtitle: \"C'est l'heure dudududu DUEL !\"\r\n\tquest.19D8E18A016CBB08.quest_desc: [\"Ce bloc une fois cuit donne des fragments de Netherite !\"]\r\n\tquest.1C19EA9E848E67B8.quest_desc: [\"En Aquali ? En Voltali ?  En Pyroli ? En salami ? En jean-Marie ? En Mentali ? En Noctali ? En Big-flo et Oli ? En Phylali ?  En Ferrari ? En Givrali ? En Nymphali ? En Sans-abri ?\"]\r\n\tquest.1C19EA9E848E67B8.quest_subtitle: \"Évoli hésite encore plus que toi devant Netflix.\"\r\n\tquest.1C19EA9E848E67B8.title: \"En quelle forme aimerais-tu qu'Evoli décide d'évoluer ?\"\r\n\tquest.1DC6D75172C7C4F6.quest_desc: [\"Fabriquez votre premier panneau solaire. Enfin, une source d’énergie qui ne dépend pas de votre capacité à pédaler !\"]\r\n\tquest.1DC6D75172C7C4F6.quest_subtitle: \"Le soleil, cette batterie géante gratuite !\"\r\n\tquest.1F8A72D31F6CFE2C.quest_desc: [\"Fabrique tes premiers outils pour miner plus vite et survivre plus longtemps.\"]\r\n\tquest.1F8A72D31F6CFE2C.quest_subtitle: \"Toujours oublier la pelle. Toujours.\"\r\n\tquest.1F8A72D31F6CFE2C.title: \"S’équiper correctement\"\r\n\tquest.20C346C424AE5F7E.quest_desc: [\"Fabrique une table de craft pour débloquer tout le potentiel de l’artisanat.\"]\r\n\tquest.20C346C424AE5F7E.quest_subtitle: \"Le vrai cerveau du jeu.\"\r\n\tquest.20C346C424AE5F7E.title: \"Table de craft\"\r\n\tquest.21AE86172DBCFE1C.quest_desc: [\"Augmente drastiquement la capacité de stockage des barils.\"]\r\n\tquest.21AE86172DBCFE1C.quest_subtitle: \"Ce baril avale tout.\"\r\n\tquest.21AE86172DBCFE1C.title: \"Organisation extrême\"\r\n\tquest.2334FD799765A2A4.quest_desc: [\r\n\t\t\"Permet de stocker des sacs dans ton sac.\"\r\n\t\t\"Oui. Vraiment.\"\r\n\t]\r\n\tquest.2334FD799765A2A4.quest_subtitle: \"On est toujours dans Minecraft, normalement.\"\r\n\tquest.2334FD799765A2A4.title: \"Le sac dans le sac\"\r\n\tquest.24306B7002FBBABC.quest_desc: [\"Le cœur du jeu : exploration, survie et créativité. Mine, construis, affronte la nuit et façonne ton monde bloc par bloc, à ton rythme.\"]\r\n\tquest.2752803357C03703.quest_desc: [\"Regarde le dresseur avec qui tu veux échanger et appuis sur R et choisi échange !\"]\r\n\tquest.2752803357C03703.quest_subtitle: \"Promis, il reviendra… peut-être.\"\r\n\tquest.2752803357C03703.title: \"L’échange\"\r\n\tquest.2A32CE8FBDAF81F7.quest_desc: [\"Chaque rencontre compte. Fabrique un Pokédex pour enregistrer les Pokémon que tu croiseras au fil de ton aventure.\"]\r\n\tquest.2A32CE8FBDAF81F7.quest_subtitle: \"Oui, ça compte même si tu cries « OH UN POKÉMON ».\"\r\n\tquest.2A32CE8FBDAF81F7.title: \"Le Pokédex\"\r\n\tquest.2B35E2877DB61AEE.quest_desc: [\"Augmente drastiquement la capacité de stockage des barils.\"]\r\n\tquest.2B35E2877DB61AEE.quest_subtitle: \"Ce baril avale tout.\"\r\n\tquest.2B35E2877DB61AEE.title: \"Organisation extrême\"\r\n\tquest.2B3F7C162CA1C29C.quest_desc: [\"Astuce : Si ton processeur surchauffe, ne le mets pas au frigo. Contrairement à ton PC, il n’aime pas le fromage.\"]\r\n\tquest.2B3F7C162CA1C29C.quest_subtitle: \"De l’entrée de gamme au PC de gamer\"\r\n\tquest.2B9BDA75DA778F84.quest_desc: [\"Améliore progressivement la taille maximale des stacks dans ton sac.\"]\r\n\tquest.2B9BDA75DA778F84.quest_subtitle: \"Encore… ENCORE…\"\r\n\tquest.2B9BDA75DA778F84.title: \"Toujours plus\"\r\n\tquest.2C71AC50F2609E7A.quest_desc: [\"Fabrique les trois types de processeurs. Parce qu’un bon système a besoin de puissance… et que ton PC IRL ne suffit clairement pas.\"]\r\n\tquest.2C71AC50F2609E7A.quest_subtitle: \"De l’entrée de gamme au PC de gamer\"\r\n\tquest.2D640F11EEDEC513.quest_subtitle: \"Gi GI GIRATINA ?\"\r\n\tquest.2D640F11EEDEC513.title: \"Le monde distorsion !\"\r\n\tquest.2DC1EE2C932C86C6.quest_desc: [\"Le sac en or offre encore plus d’espace pour ton loot.\"]\r\n\tquest.2DC1EE2C932C86C6.quest_subtitle: \"Le bling-bling du stockage.\"\r\n\tquest.2DC1EE2C932C86C6.title: \"Le confort avant tout\"\r\n\tquest.2ECD5F9ACF5BFAF0.quest_desc: [\"Coupe du bois et découvre les bases essentielles pour survivre dans Minecraft.\"]\r\n\tquest.2ECD5F9ACF5BFAF0.quest_subtitle: \"Frapper du bois à mains nues : totalement logique.\"\r\n\tquest.2ECD5F9ACF5BFAF0.title: \"Récolte primitive\"\r\n\tquest.2F5D549F05A473A1.quest_desc: [\"Ton aventure commence ici. Le monde est peuplé de créatures extraordinaires appelées Pokémon. Explore, observe… et prépare-toi à devenir un véritable Dresseur.\"]\r\n\tquest.2F5D549F05A473A1.quest_subtitle: \"Tu as récuper ton premier pokémon ? Regarde ton clavier et appuis sur virgule\"\r\n\tquest.2F5D549F05A473A1.title: \"Bienvenue dans le monde des Pokémon\"\r\n\tquest.2FC4E0FC2D265DB0.quest_subtitle: \"100% de capture !\"\r\n\tquest.2FC4E0FC2D265DB0.title: \"La Master Ball !\"\r\n\tquest.2FF3EFDE102858C1.quest_desc: [\"Certains Pokémon peuvent te porter. Monte un Pokémon et explore le monde d’une nouvelle façon.\"]\r\n\tquest.2FF3EFDE102858C1.quest_subtitle: \"La SNCF n'est pas prête à faire faillite !\"\r\n\tquest.2FF3EFDE102858C1.title: \"Voyager autrement\"\r\n\tquest.321E9A95B96378DF.quest_desc: [\"Le générateur qui transforme la chaleur en électricité… et vos espoirs en fumée\"]\r\n\tquest.321E9A95B96378DF.quest_subtitle: \"Un générateur, ou une leçon sur les incendies. À vous de jouer !\"\r\n\tquest.32B11A4623FBE561.quest_desc: [\"Créez une cellule solaire de base. Parce que même le soleil a besoin d’un peu d’aide pour vous éclairer.\"]\r\n\tquest.32B11A4623FBE561.quest_subtitle: \"La cellule qui capte les rayons… et les mauvaises blagues\"\r\n\tquest.33821BF1582F5349.quest_desc: [\"Un marteau en pierre ? Oui, c’est basique, mais c’est le début de votre carrière de bricoleur électrique. Attention aux doigts !\"]\r\n\tquest.33821BF1582F5349.quest_subtitle: \"Le marteau des cavernes 2.0\"\r\n\tquest.33BBAE47EC21F1D3.quest_desc: [\"Grâce à la technologie, fais renaître un Pokémon disparu depuis des millénaires.\"]\r\n\tquest.33BBAE47EC21F1D3.quest_subtitle: \"La science fait des miracles. Et parfois des cris.\"\r\n\tquest.33BBAE47EC21F1D3.title: \"Résurrection\"\r\n\tquest.3433D4F872FF3BBC.quest_desc: [\"Prends soin de tes Pokémon hors combat. Le pâturage est un lieu idéal pour les voir s’épanouir et vivre tranquillement.\"]\r\n\tquest.3433D4F872FF3BBC.quest_subtitle: \"Ils sont plus heureux ici que toi au spawn.\"\r\n\tquest.3433D4F872FF3BBC.title: \"Une vie paisible\"\r\n\tquest.3615A2D66DD1B68B.quest_subtitle: \"Sort ta la clé !!!\"\r\n\tquest.37133D01270DA00B.quest_desc: [\"Un générateur thermique qui utilise des fluides à haute température.\"]\r\n\tquest.39102312736F85CA.quest_desc: [\r\n\t\t\"Améliore ta Grid en Crafting Grid pour fabriquer directement depuis ton réseau.\"\r\n\t\t\"Ton inventaire devient secondaire.\"\r\n\t]\r\n\tquest.39102312736F85CA.quest_subtitle: \"Plus jamais ouvrir une table de craft.\"\r\n\tquest.3A9E4F993ABBDFB7.quest_desc: [\r\n\t\t\"Fabrique du Quartz Enriched Iron et du Quartz Enriched Copper. Parce que le quartz normal, c’est comme du pain sans beurre : ça manque de fun.\"\r\n\t\t\"\"\r\n\t\t\"Astuce : Si tu te demandes pourquoi on enrichit le quartz, c’est pour qu’il se sente important. Comme toi quand tu trouves un diamant.\"\r\n\t]\r\n\tquest.3A9E4F993ABBDFB7.quest_subtitle: \"Du quartz, mais en mieux\"\r\n\tquest.3AB9D98F236500E6.quest_subtitle: \"Bienvenue en enfer !\"\r\n\tquest.3AB9D98F236500E6.title: \"Le Nether !\"\r\n\tquest.3B126DE35ABDABE9.quest_desc: [\"C'est comme le bloc basic machine mais hardened !\"]\r\n\tquest.3B5EA3A7DC9ACF2B.quest_desc: [\"Créer de l'électricité avec du charbon.\"]\r\n\tquest.3C8EC56D27650520.quest_desc: [\"Explore les profondeurs et récolte tes premiers minerais.\"]\r\n\tquest.3C8EC56D27650520.quest_subtitle: \"Si ça brille, c’est sûrement utile.\"\r\n\tquest.3C8EC56D27650520.title: \"Premiers minerais\"\r\n\tquest.3CC6A443E03CEC52.quest_desc: [\r\n\t\t\"Fabrique un Disk Drive. Parce que stocker tes items dans des coffres, c’est comme garer sa voiture dans le salon : ça finit mal.\"\r\n\t\t\"\"\r\n\t\t\"PS : Si ton Disk Drive fait un bruit bizarre, c’est juste lui qui ronronne de bonheur. Ou alors c’est un bug. On ne sait jamais.\"\r\n\t]\r\n\tquest.3CC6A443E03CEC52.quest_subtitle: \"Le garage de tes items\"\r\n\tquest.3CC6A443E03CEC52.title: \"Le Disk Drive\"\r\n\tquest.3D62CDC15E48197F.quest_desc: [\"Capacité massive et compatibilité maximale avec les upgrades.\"]\r\n\tquest.3D62CDC15E48197F.quest_subtitle: \"Le rangement, mais premium.\"\r\n\tquest.3D62CDC15E48197F.title: \"Stockage d’élite\"\r\n\tquest.3DA0BFF7350984D0.quest_desc: [\r\n\t\t\"Le summum du stockage portable.\"\r\n\t\t\"Résistant, massif, terriblement efficace.\"\r\n\t]\r\n\tquest.3DA0BFF7350984D0.quest_subtitle: \"Ton inventaire a atteint sa forme finale.\"\r\n\tquest.3DA0BFF7350984D0.title: \"Le sac ultime\"\r\n\tquest.404206A4AAE792C4.quest_desc: [\"Améliore progressivement la taille maximale des stacks dans ton sac.\"]\r\n\tquest.404206A4AAE792C4.quest_subtitle: \"Encore… ENCORE…\"\r\n\tquest.404206A4AAE792C4.title: \"Toujours plus\"\r\n\tquest.404869211C34C933.quest_desc: [\"Augmente drastiquement la capacité de stockage des barils.\"]\r\n\tquest.404869211C34C933.quest_subtitle: \"Ce baril avale tout.\"\r\n\tquest.404869211C34C933.title: \"Organisation extrême\"\r\n\tquest.40ECC0A12366C91D.quest_desc: [\"Un sac à dos digne des plus grands explorateurs.\"]\r\n\tquest.40ECC0A12366C91D.quest_subtitle: \"Même les shulkers sont jaloux.\"\r\n\tquest.40ECC0A12366C91D.title: \"Le luxe du rangement\"\r\n\tquest.412753140DC71C80.quest_subtitle: \"C'est l'heure dudududu DUEL !\"\r\n\tquest.412753140DC71C80.title: \"Les bases du Dresseur\"\r\n\tquest.414F57F91D53AAA9.quest_desc: [\"Un four électrique, il faut l'alimenter en électricité et hop ça cuit !\"]\r\n\tquest.41DF62A5CD78AA34.quest_desc: [\"Les Pokémon chromatiques sont extrêmement rares. Capture-en un et entre dans le cercle des Dresseurs chanceux.\"]\r\n\tquest.41DF62A5CD78AA34.quest_subtitle: \"Probabilité : faible. Cri quand tu le vois : très élevé.\"\r\n\tquest.41DF62A5CD78AA34.title: \"Une rencontre particulière !\"\r\n\tquest.41F15FB208A103F7.quest_desc: [\"Récupère de la lave dans un seau. Utile… mais extrêmement dangereux.\"]\r\n\tquest.41F15FB208A103F7.quest_subtitle: \"Ne clique pas par erreur. Vraiment.\"\r\n\tquest.41F15FB208A103F7.title: \"Le seau de lave\"\r\n\tquest.42981868576B51B4.quest_subtitle: \"Un PC sans fil ?\"\r\n\tquest.42EC19A099C9F526.quest_desc: [\r\n\t\t\"Téléphone créer par Arceus lui même !!!\"\r\n\t\t\"\"\r\n\t\t\"Il te sera utile si tu veux trouver des pokémon légendaires !\"\r\n\t\t\"\"\r\n\t\t\"Il y a des options qui sont assez sympa aussi mais je te laisse découvrir !\"\r\n\t]\r\n\tquest.42EC19A099C9F526.quest_subtitle: \"Attends c'est un téléphone ça ?\"\r\n\tquest.42F75E79F53EE7EB.quest_subtitle: \"De l’entrée de gamme au PC de gamer\"\r\n\tquest.44D9D53400D42DB2.title: \"C'est quoi ces trucs la ?\"\r\n\tquest.4887211FF106BF32.quest_desc: [\"Augmente drastiquement la capacité de stockage des barils.\"]\r\n\tquest.4887211FF106BF32.quest_subtitle: \"Ce baril avale tout.\"\r\n\tquest.4887211FF106BF32.title: \"Organisation extrême\"\r\n\tquest.4D62DC9773FD8979.quest_desc: [\"Améliore progressivement la taille maximale des stacks dans ton sac.\"]\r\n\tquest.4D62DC9773FD8979.quest_subtitle: \"Encore… ENCORE…\"\r\n\tquest.4D62DC9773FD8979.title: \"Toujours plus\"\r\n\tquest.4DF5C7AF1885F405.quest_desc: [\"Augmente légèrement la taille des piles.\"]\r\n\tquest.4DF5C7AF1885F405.quest_subtitle: \"C’est déjà mieux que rien.\"\r\n\tquest.4DF5C7AF1885F405.title: \"Un peu plus haut\"\r\n\tquest.4F1545E081283981.quest_desc: [\"Connecte tous les blocs Refined Storage entre eux grâce aux câbles.\"]\r\n\tquest.4F1545E081283981.quest_subtitle: \"Oui, ça passe par là.\"\r\n\tquest.4F4E0B659AF8E5BE.quest_desc: [\"Le moment est arrivé. Capture ton premier Pokémon et crée un lien qui marquera le début de ton équipe.\"]\r\n\tquest.4F4E0B659AF8E5BE.quest_subtitle: \"Attention : ce Pokémon te jugera si tu rates le lancer.\"\r\n\tquest.4F4E0B659AF8E5BE.title: \"Premier compagnon\"\r\n\tquest.4F8D10888AACD4D9.quest_desc: [\"Le bloc qui aspire les fluides !\"]\r\n\tquest.4FD1B81C301DB1CE.quest_desc: [\"La version ultime des barils Sophisticated.\"]\r\n\tquest.4FD1B81C301DB1CE.quest_subtitle: \"Même le Nether respecte ce baril.\"\r\n\tquest.4FD1B81C301DB1CE.title: \"Le stockage absolu\"\r\n\tquest.4FDB72E7786C71F3.quest_desc: [\"Parce que stocker tes items dans une seule dimension, c’est tellement 2020. Passe à l’interdimensionnel et impressionne tes amis (ou terrifie-les).\"]\r\n\tquest.4FDB72E7786C71F3.title: \"L’Interdimensional Wireless Transmitter\"\r\n\tquest.5013AFE214AF6446.quest_desc: [\"Certains Pokémon n’évoluent que grâce à l’échange. Découvre ce phénomène rare et fascinant.\"]\r\n\tquest.5013AFE214AF6446.quest_subtitle: \"Ils ont juste besoin de… se croiser. Socialisation niveau Pokémon.\"\r\n\tquest.5013AFE214AF6446.title: \"Une évolution particulière\"\r\n\tquest.501494E61A37B2D8.quest_desc: [\"Relie tes barils avec des contrôleurs, IO et outils Sophisticated.\"]\r\n\tquest.501494E61A37B2D8.quest_subtitle: \"Bienvenue dans le stockage intelligent.\"\r\n\tquest.501494E61A37B2D8.title: \"Le cerveau du stockage\"\r\n\tquest.50DEA0D81345BDBA.quest_subtitle: \"Snake ?\"\r\n\tquest.50F135C0B070D889.quest_subtitle: \"Ramasse de la netherrack \"\r\n\tquest.52AC24A5F5149B3F.quest_desc: [\"Fabrique les trois types de processeurs. Parce qu’un bon système a besoin de puissance… et que ton PC IRL ne suffit clairement pas.\"]\r\n\tquest.52AC24A5F5149B3F.quest_subtitle: \"De l’entrée de gamme au PC de gamer\"\r\n\tquest.53ABFE05D11D5E53.quest_desc: [\r\n\t\t\"Fabrique une Grid pour accéder à ton stockage numérique.\"\r\n\t\t\"Recherche, trie et récupère tes objets instantanément.\"\r\n\t]\r\n\tquest.53ABFE05D11D5E53.quest_subtitle: \"Ctrl + F, mais en vrai.\"\r\n\tquest.541CAED36CF7A67A.quest_desc: [\"Bah une batterie...Comment tu veux que je t'explique le but de ce bloc autrement !\"]\r\n\tquest.548E55ED20F0E106.title: \"Epreuves !\"\r\n\tquest.559AE8A7F68768A3.quest_desc: [\"Améliore tes outils en netherite et atteins le sommet de la puissance.\"]\r\n\tquest.559AE8A7F68768A3.quest_subtitle: \"Tu n’as plus d’excuses maintenant.\"\r\n\tquest.559AE8A7F68768A3.title: \"Outils en netherite\"\r\n\tquest.561D11457EECF855.quest_desc: [\"Le vide vous appelle !?\"]\r\n\tquest.561D11457EECF855.quest_subtitle: \"Trouver un portail vers les chimères !\"\r\n\tquest.561D11457EECF855.title: \"Un portail ?!\"\r\n\tquest.56F9AB9B08E39C5E.quest_desc: [\"Utilise la lave et l’obsidienne pour créer et activer un portail vers le Nether.\"]\r\n\tquest.56F9AB9B08E39C5E.quest_subtitle: \"Mauvaise idée ? Oui. Nécessaire ? Aussi.\"\r\n\tquest.56F9AB9B08E39C5E.title: \"Allumer le portail\"\r\n\tquest.57332CF3804E37D3.quest_desc: [\r\n\t\t\"Fabrique un Machine Casing. Parce qu’un système de stockage sans boîtier, c’est comme un PC sans tour : ça marche, mais tout le monde te juge.\"\r\n\t\t\"\"\r\n\t\t\"Astuce : Si tu entends des bruits étranges en le fabriquant, ne t’inquiète pas, c’est juste le son de l’efficacité qui s’installe.\"\r\n\t]\r\n\tquest.57332CF3804E37D3.quest_subtitle: \"Un boîtier pour les gouverner tous\"\r\n\tquest.57332CF3804E37D3.title: \"Le Boîtier de Machine\"\r\n\tquest.57FB86404B048366.quest_subtitle: \"Sky is the limit !\"\r\n\tquest.587464890BE705A2.quest_subtitle: \"Les mystérieuses cités d'ooooooooooor !\"\r\n\tquest.5900CEF50B1F43EA.quest_desc: [\"Toutes les améliorations commencent ici.\"]\r\n\tquest.5900CEF50B1F43EA.quest_subtitle: \"Sans base, pas d’upgrade.\"\r\n\tquest.5900CEF50B1F43EA.title: \"La base de tout\"\r\n\tquest.594728F6B7F72938.quest_desc: [\r\n\t\t\"Crée un Wireless Transmitter. Parce que les câbles, c’est comme les fils de laine : ça s’emmêle toujours au pire moment.\"\r\n\t\t\"\"\r\n\t\t\"PS : Si ton signal est faible, vérifie que tu n’es pas dans une grotte. Ou alors, c’est juste la faute à Notch.\"\r\n\t]\r\n\tquest.594728F6B7F72938.quest_subtitle: \"La liberté, enfin !\"\r\n\tquest.5B4CCD39C2F62DC6.quest_desc: [\"Fabrique des outils en diamant, symbole de puissance et de réussite.\"]\r\n\tquest.5B4CCD39C2F62DC6.quest_subtitle: \"Screenshot. Sinon ça n’existe pas.\"\r\n\tquest.5B4CCD39C2F62DC6.title: \"Outils en diamant\"\r\n\tquest.5BDF03C702E49D12.quest_desc: [\"Le stockage atteint un niveau complètement déraisonnable.\"]\r\n\tquest.5BDF03C702E49D12.quest_subtitle: \"On arrête de compter.\"\r\n\tquest.5BDF03C702E49D12.title: \"Plus rien n’a de sens\"\r\n\tquest.5C518B44F5FE2942.quest_desc: [\"L'upgrade du alloy furnace et avec de l'électricité.\"]\r\n\tquest.5FB4592A5CE47A85.quest_desc: [\"Réunis les différentes couleurs d’Apricorns, indispensables pour fabriquer des Poké Balls variées.\"]\r\n\tquest.5FB4592A5CE47A85.quest_subtitle: \"Les Poké Balls aussi ont droit à du style.\"\r\n\tquest.5FB4592A5CE47A85.title: \"L’arc-en-ciel d’Apricorns\"\r\n\tquest.5FC8CAA124F24D23.quest_desc: [\"Un Dresseur sans Poké Ball n’est rien. Assemble tes premières Ball et prépare-toi à capturer ton tout premier Pokémon.\"]\r\n\tquest.5FC8CAA124F24D23.quest_subtitle: \"Taux de réussite : 100% si tu vises bien. 0% si tu paniques.\"\r\n\tquest.5FC8CAA124F24D23.title: \"Fabriquer sa première Poké Ball\"\r\n\tquest.604464A52FA18356.quest_desc: [\r\n\t\t\"Automatise l’entrée des objets dans ton réseau.\"\r\n\t\t\"\"\r\n\t\t\"\"\r\n\t\t\"Fais sortir automatiquement des objets spécifiques de ton réseau.\"\r\n\t]\r\n\tquest.604464A52FA18356.quest_subtitle: \"Un objet à la fois. Ou pas.\"\r\n\tquest.604464A52FA18356.title: \"Importeur et Exporteur\"\r\n\tquest.61B5D07FC3563D77.quest_desc: [\"Construisez un chargeur. Parce que même les batteries ont besoin d’amour (et d’électricité).\"]\r\n\tquest.61B5D07FC3563D77.quest_subtitle: \"Le chargeur qui recharge tout… sauf votre motivation\"\r\n\tquest.61ED53786C46D151.quest_desc: [\"Un outil avancé pour les Dresseurs expérimentés. Obtiens le PokéNav et améliore ta navigation.\"]\r\n\tquest.61ED53786C46D151.quest_subtitle: \"GPS Pokémon > sens de l’orientation humain.\"\r\n\tquest.61ED53786C46D151.title: \"Le PokéNav\"\r\n\tquest.63942A23C87B0347.quest_subtitle: \"Pour créer les outils en Netherite !\"\r\n\tquest.63EA1D6EAC894808.quest_desc: [\r\n\t\t\"Ton inventaire déborde et tes coffres sont partout. Il est temps de passer à une solution plus intelligente.\"\r\n\t\t\"\"\r\n\t\t\"Le stockage numérique à l’état pur. Centralise tous tes items dans un réseau fluide, triable et automatisable. Fini les coffres en pagaille.\"\r\n\t]\r\n\tquest.63EA1D6EAC894808.quest_subtitle: \"Ce coffre était là hier, promis.\"\r\n\tquest.63EA1D6EAC894808.title: \"Stockage d'objet\"\r\n\tquest.63F9F5EC21750A81.quest_desc: [\"Augmente drastiquement la capacité de stockage des barils.\"]\r\n\tquest.63F9F5EC21750A81.quest_subtitle: \"Ce baril avale tout.\"\r\n\tquest.63F9F5EC21750A81.title: \"Organisation extrême\"\r\n\tquest.6430902A996E0DA5.quest_desc: [\"Traverse le portail et découvre le Nether, un monde hostile rempli de dangers et de ressources uniques.\"]\r\n\tquest.6430902A996E0DA5.quest_subtitle: \"Bienvenue en enfer. Littéralement.\"\r\n\tquest.649854BC2006E999.quest_desc: [\"Utilise un appât Pokémon pour augmenter tes chances de rencontre lors de la pêche.\"]\r\n\tquest.649854BC2006E999.quest_subtitle: \"Appât ≠ toi dans l’eau. Important.\"\r\n\tquest.649854BC2006E999.title: \"Appât stratégique\"\r\n\tquest.684D5F6F7C201552.quest_desc: [\"Pour commencer, il te faut du silicium et des bindings. Parce qu’un système de stockage sans silicium, c’est comme un sandwich sans pain : techniquement possible, mais franchement triste.\"]\r\n\tquest.684D5F6F7C201552.quest_subtitle: \"Silicon Valley, version Minecraft\"\r\n\tquest.684D5F6F7C201552.title: \"Les Fondamentaux du Silicon\"\r\n\tquest.6B0A6E988A8C0311.quest_desc: [\"Découvre les barils Sophisticated : plus pratiques, plus modulaires.\"]\r\n\tquest.6B0A6E988A8C0311.quest_subtitle: \"Le coffre 2.0.\"\r\n\tquest.6B0A6E988A8C0311.title: \"Une alternative aux coffres\"\r\n\tquest.6C350A1B822C9552.quest_desc: [\r\n\t\t\"Crée une Wrench. Parce qu’un bon artisan a toujours sa clé à molette… et un marteau pour les cas désespérés.\"\r\n\t\t\"\"\r\n\t\t\"PS : Cette clé ne sert pas à monter des meubles IKEA. Dommage, hein ?\"\r\n\t]\r\n\tquest.6C350A1B822C9552.quest_subtitle: \"L’outil magique (ou presque)\"\r\n\tquest.6C350A1B822C9552.title: \"La Clé à Molette\"\r\n\tquest.6C8C157F9913E73E.quest_desc: [\"Une meilleure capacité et plus de possibilités.\"]\r\n\tquest.6C8C157F9913E73E.quest_subtitle: \"Le cuivre sert enfin à quelque chose.\"\r\n\tquest.6C8C157F9913E73E.title: \"Première amélioration\"\r\n\tquest.6EB386C81EE9B04B.quest_desc: [\"Passe au sac à dos en fer pour augmenter ta capacité de stockage.\"]\r\n\tquest.6EB386C81EE9B04B.quest_subtitle: \"Ton dos commence à apprécier.\"\r\n\tquest.6EB386C81EE9B04B.title: \"Plus solide, plus utile\"\r\n\tquest.6EDB5E8D88458230.quest_desc: [\"Fabriquez une batterie de niveau 1. Parce que stocker l’énergie, c’est comme stocker des snacks : on en a toujours besoin au pire moment !\"]\r\n\tquest.6EDB5E8D88458230.quest_subtitle: \"La batterie qui ne dure jamais assez longtemps\"\r\n\tquest.6EE70DA752182D83.quest_desc: [\"Avec de l’expérience et de la patience, certains Pokémon évoluent. Assiste à ta première évolution.\"]\r\n\tquest.6EE70DA752182D83.quest_subtitle: \"Il grandit si vite… \"\r\n\tquest.6EE70DA752182D83.title: \"L’évolution naturelle\"\r\n\tquest.6F5D04DC6DBDD027.quest_desc: [\"Des fossiles anciens renferment des Pokémon disparus. Mets la main sur l’un d’eux.\"]\r\n\tquest.6F5D04DC6DBDD027.quest_subtitle: \"Un Pokémon antique… plus vieux que ton PC.\"\r\n\tquest.6F5D04DC6DBDD027.title: \"Vestiges du passé\"\r\n\tquest.6FEF21B99B05DEFC.quest_desc: [\"Augmente drastiquement la capacité de stockage des barils.\"]\r\n\tquest.6FEF21B99B05DEFC.quest_subtitle: \"Ce baril avale tout.\"\r\n\tquest.6FEF21B99B05DEFC.title: \"Organisation extrême\"\r\n\tquest.72511D0743654C3F.quest_desc: [\"Des sacs à dos et coffres améliorés, modulables et élégants. Tu voyages léger, sans jamais manquer de place.\"]\r\n\tquest.72511D0743654C3F.title: \"Sophisticated Series\"\r\n\tquest.74869FF761E30417.quest_desc: [\"Fabriquez 10 isolants pour câbles. Parce que personne n’aime les étincelles… sauf les pyromanes.\"]\r\n\tquest.74869FF761E30417.quest_subtitle: \"Isoler, c’est protéger (et éviter les courts-circuits !)\"\r\n\tquest.74869FF761E30417.title: \"L’isolant de câble\"\r\n\tquest.75D88B16012FDEDF.quest_subtitle: \"Ramasser de la pierre !\"\r\n\tquest.7694A2A4312FC289.quest_desc: [\"Installe un chaudron de campement pour préparer des plats utiles à tes Pokémon durant l’aventure.\"]\r\n\tquest.7694A2A4312FC289.quest_subtitle: \"Cuisine de Dresseur\"\r\n\tquest.77193D10E263D772.quest_desc: [\r\n\t\t\"Trouve des débris antiques dans le Nether pour commencer le chemin vers la netherite.\"\r\n\t\t\"\"\r\n\t\t\"Trouve un modèle de forge pour améliorer ton équipement en netherite.\"\r\n\t\t\"\"\r\n\t\t\"Utilise une table de forge pour améliorer tes équipements vers la netherite.\"\r\n\t]\r\n\tquest.77193D10E263D772.quest_subtitle: \"Boom contrôlé… normalement.\"\r\n\tquest.77193D10E263D772.title: \"Lingots de netherite\"\r\n\tquest.77F18EE5BE07C165.quest_desc: [\"Grâce aux Capsules Ball, transforme chaque apparition en spectacle.\"]\r\n\tquest.77F18EE5BE07C165.quest_subtitle: \"Ton Pokémon entre en scène.\"\r\n\tquest.787F25EA2D9BA294.quest_desc: [\"Un stockage avancé pour bases bien rangées.\"]\r\n\tquest.787F25EA2D9BA294.quest_subtitle: \"Riche en slots.\"\r\n\tquest.787F25EA2D9BA294.title: \"Le luxe organisé\"\r\n\tquest.79510B2EAD8DA293.quest_desc: [\"Explore le monde à la recherche de Pokémon à capturer, entraîner et faire combattre. Le tout, intégré naturellement à l’univers Minecraft.\"]\r\n\tquest.7A3898B3DF6802E0.quest_desc: [\"Fabriquez un lingot d’étain. Oui, c’est moins glamour que l’or, mais sans ça, pas de câbles, pas d’électricité, et pas de fun !\"]\r\n\tquest.7A3898B3DF6802E0.quest_subtitle: \"L’étain, ce métal qui ne brille pas… mais qui sert !\"\r\n\tquest.7BCE95A761092F41.quest_subtitle: \"Non par contre t'abuse la !\"\r\n\tquest.7D5EA22F6179D03C.quest_subtitle: \"De l’entrée de gamme au PC de gamer\"\r\n\tquest.7DC992A32387E13C.quest_desc: [\r\n\t\t\"Merci à toutes les personnes qui ont patienté et soutenu le projet pendant son développement.\"\r\n\t\t\"\"\r\n\t\t\"Le serveur est enfin ouvert : amusez-vous, explorez et profitez de l’aventure !\"\r\n\t\t\"\"\r\n\t\t\"Vous pouvez valider la quêtes au dessus en cliquant sur le check ;)\"\r\n\t]\r\n\tquest.7DC992A32387E13C.quest_subtitle: \"Merci et bienvenue sur pokéheros 2 !\"\r\n\tquest.7DC992A32387E13C.title: \"Bienvenue sur PokéHeros 2 !\"\r\n\tquest.7EF5AD572A6D9AFA.quest_desc: [\"Un Dresseur ne voyage jamais seul. Constitue une équipe complète de Pokémon prêts à combattre et à progresser ensemble.\"]\r\n\tquest.7EF5AD572A6D9AFA.quest_subtitle: \"Six Pokémon. Zéro place pour les excuses.\"\r\n\tquest.7EF5AD572A6D9AFA.title: \"Une équipe complète\"\r\n\treward_table.091CACD354754AFC.title: \"Master Loot table\"\r\n\treward_table.09890663668C284D.title: \"Normal Cobblemon loottable\"\r\n\ttask.14B6F8E1CB39F1A1.title: \"Sophisticated\"\r\n\ttask.2512E0487C4CAF52.title: \"L’autre côté\"\r\n\ttask.303A241570D411A0.title: \"Cobblemon\"\r\n\ttask.37ADDE057FA583EF.title: \"Minecraft Vanilla\"\r\n\ttask.38FD65BD5BE00415.title: \"Finito Minecraft Vanilla +\"\r\n\ttask.45ED3B829663B335.title: \"Energized power\"\r\n\ttask.4714CD0936B09365.title: \"Bienvenue !\"\r\n\ttask.4B9A890EB2D74B94.title: \"Refined Storage\"\r\n\ttask.556E16141A56CE76.title: \"Dimensions\"\r\n\ttask.58FBD46CD01BF319.title: \"Outils en fer !\"\r\n\ttask.59A44410655F5D3F.title: \"Vanilla\"\r\n\ttask.6BB00AEBEE55A69A.title: \"Parler au Doc. Follamour\"\r\n}\r\n",
    "{\n    \"chapter.0344005D2050979A.title\": \"Epreuves !\",\n    \"chapter.4500B9354E465002.title\": \"Sophisticated's !\",\n    \"chapter.4A38C7A891A7D881.title\": \"Energized Power\",\n    \"chapter.56BFC39514FEA069.title\": \"Minecraft Vanilla+\",\n    \"chapter.6A4F4680299C5B01.title\": \"Stockage d'objets\",\n    \"chapter.78536B353AFA491C.title\": \"Cobblemon\",\n    \"chapter.7ED66C2ADFA3AAD1.title\": \"Bienvenue !\",\n    \"file.0000000000000001.title\": \"Pokéheros 2\",\n    \"quest.001E4D0147EC6FD0.quest_desc\": [\n        \"La taille des piles devient presque absurde.\"\n    ],\n    \"quest.001E4D0147EC6FD0.quest_subtitle\": \"Les limites sont une illusion.\",\n    \"quest.001E4D0147EC6FD0.title\": \"Plus aucune limite\",\n    \"quest.00B6A4B9721B7D9F.quest_desc\": [\n        \"Améliore progressivement la taille maximale des stacks dans ton sac.\"\n    ],\n    \"quest.00B6A4B9721B7D9F.quest_subtitle\": \"Encore… ENCORE…\",\n    \"quest.00B6A4B9721B7D9F.title\": \"Toujours plus\",\n    \"quest.0321FA4F76EDA558.quest_desc\": [\n        \"Même les plus jeunes Pokémon peuvent devenir puissants. Entraîne un Pokémon jusqu’à atteindre son niveau maximal.\"\n    ],\n    \"quest.0321FA4F76EDA558.quest_subtitle\": \"Oui, même lui peut devenir fort. Toi aussi peut-être.\",\n    \"quest.0321FA4F76EDA558.title\": \"Darwin ? Keskecé ?\",\n    \"quest.0473C7A540F3B9AE.quest_desc\": [\n        \"Fabrique un Construction Core et un Destruction Core. Parce que parfois, il faut casser pour mieux reconstruire. Un peu comme tes projets de redstone à 3h du mat’.\"\n    ],\n    \"quest.0473C7A540F3B9AE.quest_subtitle\": \"Créer et détruire : le cycle de la vie (version Minecraft)\",\n    \"quest.0473C7A540F3B9AE.title\": \"Le Construction Core\",\n    \"quest.05215DF144ACE471.quest_desc\": [\n        \"Merci d'avoir parler au Doc !\"\n    ],\n    \"quest.05215DF144ACE471.quest_subtitle\": \"Doc. Follamour\",\n    \"quest.05813F518717A015.quest_subtitle\": \"De l’entrée de gamme au PC de gamer\",\n    \"quest.05DD79310C662D63.quest_desc\": [\n        \"Trouvez le livre d’Energized Power pour commencer votre aventure électrique. \",\n        \"\",\n        \"Sans ça, vous allez juste brancher des câbles au hasard… et ça, c’est dangereux !\",\n        \"\",\n        \"@energized power\"\n    ],\n    \"quest.05DD79310C662D63.quest_subtitle\": \"Le manuel du savant fou\",\n    \"quest.05DD79310C662D63.title\": \"Le livre d’Energized Power\",\n    \"quest.0672925E99EEA8AB.quest_desc\": [\n        \"Bienvenue dans le monde d’Energized Power, où les câbles s’emmêlent, les batteries explosent (enfin, presque), et où l’énergie est plus précieuse que le diamant. Préparez-vous à électriser votre aventure !\"\n    ],\n    \"quest.0672925E99EEA8AB.quest_subtitle\": \"Le câble qui ne vous électrocute pas (en théorie)\",\n    \"quest.08931A50139CAFCF.quest_subtitle\": \"C'est quoi ce pokémon la ?!\",\n    \"quest.0909AE022245DC7D.quest_desc\": [\n        \"Apprends à récolter et multiplier les graines d’Apricorns pour assurer ton autonomie.\"\n    ],\n    \"quest.0909AE022245DC7D.quest_subtitle\": \"Enfin une plante qui sert vraiment.\",\n    \"quest.0909AE022245DC7D.title\": \"Cultiver les Apricorns\",\n    \"quest.0A26BFAD834C2CD2.quest_desc\": [\n        \"Fabrique le contrôleur Refined Storage, cœur de ton réseau de stockage.\"\n    ],\n    \"quest.0A26BFAD834C2CD2.quest_subtitle\": \"Ne pas débrancher.\",\n    \"quest.0AFF830D5DC31D0D.quest_desc\": [\n        \"Passe à l’âge du fer et améliore ton équipement pour explorer plus loin et plus profond.\"\n    ],\n    \"quest.0AFF830D5DC31D0D.quest_subtitle\": \"Le fer, c’est sérieux.\",\n    \"quest.0AFF830D5DC31D0D.title\": \"Outils en fer\",\n    \"quest.0B77258DFC3CB6EF.quest_desc\": [\n        \"Les Apricorns sont la clé de tout bon équipement. Récolte-en pour apprendre les fondations de l’art du dressage Pokémon.\"\n    ],\n    \"quest.0B77258DFC3CB6EF.quest_subtitle\": \"Non, les Apricorns ne se mangent pas. Enfin… pas recommandé.\",\n    \"quest.0B77258DFC3CB6EF.title\": \"Les bases du Dresseur\",\n    \"quest.0BAD7A291A9A8A1E.quest_desc\": [\n        \"Construisez un four à alliage pour créer des trucs plus solides que vos excuses quand vous oubliez d’éteindre la lumière.\"\n    ],\n    \"quest.0BAD7A291A9A8A1E.quest_subtitle\": \"Le four qui fait fondre les métaux… et les espoirs\",\n    \"quest.0DFCEEFA6C8D42C2.quest_desc\": [\n        \"Créer un basic machine frame qui te permet de créer les machines basic de energized power.\"\n    ],\n    \"quest.10CA76BD57AAAE41.quest_desc\": [\n        \"Cet étrange appareil semble réagir à l’énergie des dimensions.\",\n        \"On raconte qu’il permet d’accéder à des mondes instables,\",\n        \"peuplés de créatures hors du commun…\"\n    ],\n    \"quest.10CA76BD57AAAE41.quest_subtitle\": \"Un Téléphone magique ?\",\n    \"quest.12065B782DF78FAB.quest_desc\": [\n        \"Fabrique une canne à pêche spéciale pour attirer de nouveaux Pokémon aquatiques.\"\n    ],\n    \"quest.12065B782DF78FAB.quest_subtitle\": \"Si ça mord pas, c’est la faute de l’eau. Toujours.\",\n    \"quest.12065B782DF78FAB.title\": \"équipé pour pécho !\",\n    \"quest.14549DA7819C4FA8.quest_desc\": [\n        \"Plus de stockage, plus de solidité.\"\n    ],\n    \"quest.14549DA7819C4FA8.quest_subtitle\": \"Industriel, mais élégant.\",\n    \"quest.14549DA7819C4FA8.title\": \"Robuste et efficace\",\n    \"quest.14E23527F4607E0A.quest_desc\": [\n        \"Fabrique ton premier sac à dos Sophisticated.\"\n    ],\n    \"quest.14E23527F4607E0A.quest_subtitle\": \"Un petit sac… mais de grandes ambitions.\",\n    \"quest.14E23527F4607E0A.title\": \"Le début du voyage\",\n    \"quest.161E1309B3094706.quest_desc\": [\n        \"Fabrique un set complet d’outils en pierre. Plus solides, plus efficaces, indispensables pour avancer.\"\n    ],\n    \"quest.161E1309B3094706.quest_subtitle\": \"C’est moche, mais ça marche.\",\n    \"quest.161E1309B3094706.title\": \"Rammaser de la pierre\",\n    \"quest.17CA68399A714BF2.quest_desc\": [\n        \"Ajouter de l'or et d'autres bouts de fragments pour fabriquer un lingot de netherite !\"\n    ],\n    \"quest.182209C63CE27895.quest_subtitle\": \"C'est fini ?!\",\n    \"quest.182209C63CE27895.title\": \"L'End ?!\",\n    \"quest.1971331A95A974D6.quest_subtitle\": \"C'est l'heure dudududu DUEL !\",\n    \"quest.19D8E18A016CBB08.quest_desc\": [\n        \"Ce bloc une fois cuit donne des fragments de Netherite !\"\n    ],\n    \"quest.1C19EA9E848E67B8.quest_desc\": [\n        \"En Aquali ? En Voltali ?  En Pyroli ? En salami ? En jean-Marie ? En Mentali ? En Noctali ? En Big-flo et Oli ? En Phylali ?  En Ferrari ? En Givrali ? En Nymphali ? En Sans-abri ?\"\n    ],\n    \"quest.1C19EA9E848E67B8.quest_subtitle\": \"Évoli hésite encore plus que toi devant Netflix.\",\n    \"quest.1C19EA9E848E67B8.title\": \"En quelle forme aimerais-tu qu'Evoli décide d'évoluer ?\",\n    \"quest.1DC6D75172C7C4F6.quest_desc\": [\n        \"Fabriquez votre premier panneau solaire. Enfin, une source d’énergie qui ne dépend pas de votre capacité à pédaler !\"\n    ],\n    \"quest.1DC6D75172C7C4F6.quest_subtitle\": \"Le soleil, cette batterie géante gratuite !\",\n    \"quest.1F8A72D31F6CFE2C.quest_desc\": [\n        \"Fabrique tes premiers outils pour miner plus vite et survivre plus longtemps.\"\n    ],\n    \"quest.1F8A72D31F6CFE2C.quest_subtitle\": \"Toujours oublier la pelle. Toujours.\",\n    \"quest.1F8A72D31F6CFE2C.title\": \"S’équiper correctement\",\n    \"quest.20C346C424AE5F7E.quest_desc\": [\n        \"Fabrique une table de craft pour débloquer tout le potentiel de l’artisanat.\"\n    ],\n    \"quest.20C346C424AE5F7E.quest_subtitle\": \"Le vrai cerveau du jeu.\",\n    \"quest.20C346C424AE5F7E.title\": \"Table de craft\",\n    \"quest.21AE86172DBCFE1C.quest_desc\": [\n        \"Augmente drastiquement la capacité de stockage des barils.\"\n    ],\n    \"quest.21AE86172DBCFE1C.quest_subtitle\": \"Ce baril avale tout.\",\n    \"quest.21AE86172DBCFE1C.title\": \"Organisation extrême\",\n    \"quest.2334FD799765A2A4.quest_desc\": [\n        \"Permet de stocker des sacs dans ton sac.\",\n        \"Oui. Vraiment.\"\n    ],\n    \"quest.2334FD799765A2A4.quest_subtitle\": \"On est toujours dans Minecraft, normalement.\",\n    \"quest.2334FD799765A2A4.title\": \"Le sac dans le sac\",\n    \"quest.24306B7002FBBABC.quest_desc\": [\n        \"Le cœur du jeu : exploration, survie et créativité. Mine, construis, affronte la nuit et façonne ton monde bloc par bloc, à ton rythme.\"\n    ],\n    \"quest.2752803357C03703.quest_desc\": [\n        \"Regarde le dresseur avec qui tu veux échanger et appuis sur R et choisi échange !\"\n    ],\n    \"quest.2752803357C03703.quest_subtitle\": \"Promis, il reviendra… peut-être.\",\n    \"quest.2752803357C03703.title\": \"L’échange\",\n    \"quest.2A32CE8FBDAF81F7.quest_desc\": [\n        \"Chaque rencontre compte. Fabrique un Pokédex pour enregistrer les Pokémon que tu croiseras au fil de ton aventure.\"\n    ],\n    \"quest.2A32CE8FBDAF81F7.quest_subtitle\": \"Oui, ça compte même si tu cries « OH UN POKÉMON ».\",\n    \"quest.2A32CE8FBDAF81F7.title\": \"Le Pokédex\",\n    \"quest.2B35E2877DB61AEE.quest_desc\": [\n        \"Augmente drastiquement la capacité de stockage des barils.\"\n    ],\n    \"quest.2B35E2877DB61AEE.quest_subtitle\": \"Ce baril avale tout.\",\n    \"quest.2B35E2877DB61AEE.title\": \"Organisation extrême\",\n    \"quest.2B3F7C162CA1C29C.quest_desc\": [\n        \"Astuce : Si ton processeur surchauffe, ne le mets pas au frigo. Contrairement à ton PC, il n’aime pas le fromage.\"\n    ],\n    \"quest.2B3F7C162CA1C29C.quest_subtitle\": \"De l’entrée de gamme au PC de gamer\",\n    \"quest.2B9BDA75DA778F84.quest_desc\": [\n        \"Améliore progressivement la taille maximale des stacks dans ton sac.\"\n    ],\n    \"quest.2B9BDA75DA778F84.quest_subtitle\": \"Encore… ENCORE…\",\n    \"quest.2B9BDA75DA778F84.title\": \"Toujours plus\",\n    \"quest.2C71AC50F2609E7A.quest_desc\": [\n        \"Fabrique les trois types de processeurs. Parce qu’un bon système a besoin de puissance… et que ton PC IRL ne suffit clairement pas.\"\n    ],\n    \"quest.2C71AC50F2609E7A.quest_subtitle\": \"De l’entrée de gamme au PC de gamer\",\n    \"quest.2D640F11EEDEC513.quest_subtitle\": \"Gi GI GIRATINA ?\",\n    \"quest.2D640F11EEDEC513.title\": \"Le monde distorsion !\",\n    \"quest.2DC1EE2C932C86C6.quest_desc\": [\n        \"Le sac en or offre encore plus d’espace pour ton loot.\"\n    ],\n    \"quest.2DC1EE2C932C86C6.quest_subtitle\": \"Le bling-bling du stockage.\",\n    \"quest.2DC1EE2C932C86C6.title\": \"Le confort avant tout\",\n    \"quest.2ECD5F9ACF5BFAF0.quest_desc\": [\n        \"Coupe du bois et découvre les bases essentielles pour survivre dans Minecraft.\"\n    ],\n    \"quest.2ECD5F9ACF5BFAF0.quest_subtitle\": \"Frapper du bois à mains nues : totalement logique.\",\n    \"quest.2ECD5F9ACF5BFAF0.title\": \"Récolte primitive\",\n    \"quest.2F5D549F05A473A1.quest_desc\": [\n        \"Ton aventure commence ici. Le monde est peuplé de créatures extraordinaires appelées Pokémon. Explore, observe… et prépare-toi à devenir un véritable Dresseur.\"\n    ],\n    \"quest.2F5D549F05A473A1.quest_subtitle\": \"Tu as récuper ton premier pokémon ? Regarde ton clavier et appuis sur virgule\",\n    \"quest.2F5D549F05A473A1.title\": \"Bienvenue dans le monde des Pokémon\",\n    \"quest.2FC4E0FC2D265DB0.quest_subtitle\": \"100% de capture !\",\n    \"quest.2FC4E0FC2D265DB0.title\": \"La Master Ball !\",\n    \"quest.2FF3EFDE102858C1.quest_desc\": [\n        \"Certains Pokémon peuvent te porter. Monte un Pokémon et explore le monde d’une nouvelle façon.\"\n    ],\n    \"quest.2FF3EFDE102858C1.quest_subtitle\": \"La SNCF n'est pas prête à faire faillite !\",\n    \"quest.2FF3EFDE102858C1.title\": \"Voyager autrement\",\n    \"quest.321E9A95B96378DF.quest_desc\": [\n        \"Le générateur qui transforme la chaleur en électricité… et vos espoirs en fumée\"\n    ],\n    \"quest.321E9A95B96378DF.quest_subtitle\": \"Un générateur, ou une leçon sur les incendies. À vous de jouer !\",\n    \"quest.32B11A4623FBE561.quest_desc\": [\n        \"Créez une cellule solaire de base. Parce que même le soleil a besoin d’un peu d’aide pour vous éclairer.\"\n    ],\n    \"quest.32B11A4623FBE561.quest_subtitle\": \"La cellule qui capte les rayons… et les mauvaises blagues\",\n    \"quest.33821BF1582F5349.quest_desc\": [\n        \"Un marteau en pierre ? Oui, c’est basique, mais c’est le début de votre carrière de bricoleur électrique. Attention aux doigts !\"\n    ],\n    \"quest.33821BF1582F5349.quest_subtitle\": \"Le marteau des cavernes 2.0\",\n    \"quest.33BBAE47EC21F1D3.quest_desc\": [\n        \"Grâce à la technologie, fais renaître un Pokémon disparu depuis des millénaires.\"\n    ],\n    \"quest.33BBAE47EC21F1D3.quest_subtitle\": \"La science fait des miracles. Et parfois des cris.\",\n    \"quest.33BBAE47EC21F1D3.title\": \"Résurrection\",\n    \"quest.3433D4F872FF3BBC.quest_desc\": [\n        \"Prends soin de tes Pokémon hors combat. Le pâturage est un lieu idéal pour les voir s’épanouir et vivre tranquillement.\"\n    ],\n    \"quest.3433D4F872FF3BBC.quest_subtitle\": \"Ils sont plus heureux ici que toi au spawn.\",\n    \"quest.3433D4F872FF3BBC.title\": \"Une vie paisible\",\n    \"quest.3615A2D66DD1B68B.quest_subtitle\": \"Sort ta la clé !!!\",\n    \"quest.37133D01270DA00B.quest_desc\": [\n        \"Un générateur thermique qui utilise des fluides à haute température.\"\n    ],\n    \"quest.39102312736F85CA.quest_desc\": [\n        \"Améliore ta Grid en Crafting Grid pour fabriquer directement depuis ton réseau.\",\n        \"Ton inventaire devient secondaire.\"\n    ],\n    \"quest.39102312736F85CA.quest_subtitle\": \"Plus jamais ouvrir une table de craft.\",\n    \"quest.3A9E4F993ABBDFB7.quest_desc\": [\n        \"Fabrique du Quartz Enriched Iron et du Quartz Enriched Copper. Parce que le quartz normal, c’est comme du pain sans beurre : ça manque de fun.\",\n        \"\",\n        \"Astuce : Si tu te demandes pourquoi on enrichit le quartz, c’est pour qu’il se sente important. Comme toi quand tu trouves un diamant.\"\n    ],\n    \"quest.3A9E4F993ABBDFB7.quest_subtitle\": \"Du quartz, mais en mieux\",\n    \"quest.3AB9D98F236500E6.quest_subtitle\": \"Bienvenue en enfer !\",\n    \"quest.3AB9D98F236500E6.title\": \"Le Nether !\",\n    \"quest.3B126DE35ABDABE9.quest_desc\": [\n        \"C'est comme le bloc basic machine mais hardened !\"\n    ],\n    \"quest.3B5EA3A7DC9ACF2B.quest_desc\": [\n        \"Créer de l'électricité avec du charbon.\"\n    ],\n    \"quest.3C8EC56D27650520.quest_desc\": [\n        \"Explore les profondeurs et récolte tes premiers minerais.\"\n    ],\n    \"quest.3C8EC56D27650520.quest_subtitle\": \"Si ça brille, c’est sûrement utile.\",\n    \"quest.3C8EC56D27650520.title\": \"Premiers minerais\",\n    \"quest.3CC6A443E03CEC52.quest_desc\": [\n        \"Fabrique un Disk Drive. Parce que stocker tes items dans des coffres, c’est comme garer sa voiture dans le salon : ça finit mal.\",\n        \"\",\n        \"PS : Si ton Disk Drive fait un bruit bizarre, c’est juste lui qui ronronne de bonheur. Ou alors c’est un bug. On ne sait jamais.\"\n    ],\n    \"quest.3CC6A443E03CEC52.quest_subtitle\": \"Le garage de tes items\",\n    \"quest.3CC6A443E03CEC52.title\": \"Le Disk Drive\",\n    \"quest.3D62CDC15E48197F.quest_desc\": [\n        \"Capacité massive et compatibilité maximale avec les upgrades.\"\n    ],\n    \"quest.3D62CDC15E48197F.quest_subtitle\": \"Le rangement, mais premium.\",\n    \"quest.3D62CDC15E48197F.title\": \"Stockage d’élite\",\n    \"quest.3DA0BFF7350984D0.quest_desc\": [\n        \"Le summum du stockage portable.\",\n        \"Résistant, massif, terriblement efficace.\"\n    ],\n    \"quest.3DA0BFF7350984D0.quest_subtitle\": \"Ton inventaire a atteint sa forme finale.\",\n    \"quest.3DA0BFF7350984D0.title\": \"Le sac ultime\",\n    \"quest.404206A4AAE792C4.quest_desc\": [\n        \"Améliore progressivement la taille maximale des stacks dans ton sac.\"\n    ],\n    \"quest.404206A4AAE792C4.quest_subtitle\": \"Encore… ENCORE…\",\n    \"quest.404206A4AAE792C4.title\": \"Toujours plus\",\n    \"quest.404869211C34C933.quest_desc\": [\n        \"Augmente drastiquement la capacité de stockage des barils.\"\n    ],\n    \"quest.404869211C34C933.quest_subtitle\": \"Ce baril avale tout.\",\n    \"quest.404869211C34C933.title\": \"Organisation extrême\",\n    \"quest.40ECC0A12366C91D.quest_desc\": [\n        \"Un sac à dos digne des plus grands explorateurs.\"\n    ],\n    \"quest.40ECC0A12366C91D.quest_subtitle\": \"Même les shulkers sont jaloux.\",\n    \"quest.40ECC0A12366C91D.title\": \"Le luxe du rangement\",\n    \"quest.412753140DC71C80.quest_subtitle\": \"C'est l'heure dudududu DUEL !\",\n    \"quest.412753140DC71C80.title\": \"Les bases du Dresseur\",\n    \"quest.414F57F91D53AAA9.quest_desc\": [\n        \"Un four électrique, il faut l'alimenter en électricité et hop ça cuit !\"\n    ],\n    \"quest.41DF62A5CD78AA34.quest_desc\": [\n        \"Les Pokémon chromatiques sont extrêmement rares. Capture-en un et entre dans le cercle des Dresseurs chanceux.\"\n    ],\n    \"quest.41DF62A5CD78AA34.quest_subtitle\": \"Probabilité : faible. Cri quand tu le vois : très élevé.\",\n    \"quest.41DF62A5CD78AA34.title\": \"Une rencontre particulière !\",\n    \"quest.41F15FB208A103F7.quest_desc\": [\n        \"Récupère de la lave dans un seau. Utile… mais extrêmement dangereux.\"\n    ],\n    \"quest.41F15FB208A103F7.quest_subtitle\": \"Ne clique pas par erreur. Vraiment.\",\n    \"quest.41F15FB208A103F7.title\": \"Le seau de lave\",\n    \"quest.42981868576B51B4.quest_subtitle\": \"Un PC sans fil ?\",\n    \"quest.42EC19A099C9F526.quest_desc\": [\n        \"Téléphone créer par Arceus lui même !!!\",\n        \"\",\n        \"Il te sera utile si tu veux trouver des pokémon légendaires !\",\n        \"\",\n        \"Il y a des options qui sont assez sympa aussi mais je te laisse découvrir !\"\n    ],\n    \"quest.42EC19A099C9F526.quest_subtitle\": \"Attends c'est un téléphone ça ?\",\n    \"quest.42F75E79F53EE7EB.quest_subtitle\": \"De l’entrée de gamme au PC de gamer\",\n    \"quest.44D9D53400D42DB2.title\": \"C'est quoi ces trucs la ?\",\n    \"quest.4887211FF106BF32.quest_desc\": [\n        \"Augmente drastiquement la capacité de stockage des barils.\"\n    ],\n    \"quest.4887211FF106BF32.quest_subtitle\": \"Ce baril avale tout.\",\n    \"quest.4887211FF106BF32.title\": \"Organisation extrême\",\n    \"quest.4D62DC9773FD8979.quest_desc\": [\n        \"Améliore progressivement la taille maximale des stacks dans ton sac.\"\n    ],\n    \"quest.4D62DC9773FD8979.quest_subtitle\": \"Encore… ENCORE…\",\n    \"quest.4D62DC9773FD8979.title\": \"Toujours plus\",\n    \"quest.4DF5C7AF1885F405.quest_desc\": [\n        \"Augmente légèrement la taille des piles.\"\n    ],\n    \"quest.4DF5C7AF1885F405.quest_subtitle\": \"C’est déjà mieux que rien.\",\n    \"quest.4DF5C7AF1885F405.title\": \"Un peu plus haut\",\n    \"quest.4F1545E081283981.quest_desc\": [\n        \"Connecte tous les blocs Refined Storage entre eux grâce aux câbles.\"\n    ],\n    \"quest.4F1545E081283981.quest_subtitle\": \"Oui, ça passe par là.\",\n    \"quest.4F4E0B659AF8E5BE.quest_desc\": [\n        \"Le moment est arrivé. Capture ton premier Pokémon et crée un lien qui marquera le début de ton équipe.\"\n    ],\n    \"quest.4F4E0B659AF8E5BE.quest_subtitle\": \"Attention : ce Pokémon te jugera si tu rates le lancer.\",\n    \"quest.4F4E0B659AF8E5BE.title\": \"Premier compagnon\",\n    \"quest.4F8D10888AACD4D9.quest_desc\": [\n        \"Le bloc qui aspire les fluides !\"\n    ],\n    \"quest.4FD1B81C301DB1CE.quest_desc\": [\n        \"La version ultime des barils Sophisticated.\"\n    ],\n    \"quest.4FD1B81C301DB1CE.quest_subtitle\": \"Même le Nether respecte ce baril.\",\n    \"quest.4FD1B81C301DB1CE.title\": \"Le stockage absolu\",\n    \"quest.4FDB72E7786C71F3.quest_desc\": [\n        \"Parce que stocker tes items dans une seule dimension, c’est tellement 2020. Passe à l’interdimensionnel et impressionne tes amis (ou terrifie-les).\"\n    ],\n    \"quest.4FDB72E7786C71F3.title\": \"L’Interdimensional Wireless Transmitter\",\n    \"quest.5013AFE214AF6446.quest_desc\": [\n        \"Certains Pokémon n’évoluent que grâce à l’échange. Découvre ce phénomène rare et fascinant.\"\n    ],\n    \"quest.5013AFE214AF6446.quest_subtitle\": \"Ils ont juste besoin de… se croiser. Socialisation niveau Pokémon.\",\n    \"quest.5013AFE214AF6446.title\": \"Une évolution particulière\",\n    \"quest.501494E61A37B2D8.quest_desc\": [\n        \"Relie tes barils avec des contrôleurs, IO et outils Sophisticated.\"\n    ],\n    \"quest.501494E61A37B2D8.quest_subtitle\": \"Bienvenue dans le stockage intelligent.\",\n    \"quest.501494E61A37B2D8.title\": \"Le cerveau du stockage\",\n    \"quest.50DEA0D81345BDBA.quest_subtitle\": \"Snake ?\",\n    \"quest.50F135C0B070D889.quest_subtitle\": \"Ramasse de la netherrack \",\n    \"quest.52AC24A5F5149B3F.quest_desc\": [\n        \"Fabrique les trois types de processeurs. Parce qu’un bon système a besoin de puissance… et que ton PC IRL ne suffit clairement pas.\"\n    ],\n    \"quest.52AC24A5F5149B3F.quest_subtitle\": \"De l’entrée de gamme au PC de gamer\",\n    \"quest.53ABFE05D11D5E53.quest_desc\": [\n        \"Fabrique une Grid pour accéder à ton stockage numérique.\",\n        \"Recherche, trie et récupère tes objets instantanément.\"\n    ],\n    \"quest.53ABFE05D11D5E53.quest_subtitle\": \"Ctrl + F, mais en vrai.\",\n    \"quest.541CAED36CF7A67A.quest_desc\": [\n        \"Bah une batterie...Comment tu veux que je t'explique le but de ce bloc autrement !\"\n    ],\n    \"quest.548E55ED20F0E106.title\": \"Epreuves !\",\n    \"quest.559AE8A7F68768A3.quest_desc\": [\n        \"Améliore tes outils en netherite et atteins le sommet de la puissance.\"\n    ],\n    \"quest.559AE8A7F68768A3.quest_subtitle\": \"Tu n’as plus d’excuses maintenant.\",\n    \"quest.559AE8A7F68768A3.title\": \"Outils en netherite\",\n    \"quest.561D11457EECF855.quest_desc\": [\n        \"Le vide vous appelle !?\"\n    ],\n    \"quest.561D11457EECF855.quest_subtitle\": \"Trouver un portail vers les chimères !\",\n    \"quest.561D11457EECF855.title\": \"Un portail ?!\",\n    \"quest.56F9AB9B08E39C5E.quest_desc\": [\n        \"Utilise la lave et l’obsidienne pour créer et activer un portail vers le Nether.\"\n    ],\n    \"quest.56F9AB9B08E39C5E.quest_subtitle\": \"Mauvaise idée ? Oui. Nécessaire ? Aussi.\",\n    \"quest.56F9AB9B08E39C5E.title\": \"Allumer le portail\",\n    \"quest.57332CF3804E37D3.quest_desc\": [\n        \"Fabrique un Machine Casing. Parce qu’un système de stockage sans boîtier, c’est comme un PC sans tour : ça marche, mais tout le monde te juge.\",\n        \"\",\n        \"Astuce : Si tu entends des bruits étranges en le fabriquant, ne t’inquiète pas, c’est juste le son de l’efficacité qui s’installe.\"\n    ],\n    \"quest.57332CF3804E37D3.quest_subtitle\": \"Un boîtier pour les gouverner tous\",\n    \"quest.57332CF3804E37D3.title\": \"Le Boîtier de Machine\",\n    \"quest.57FB86404B048366.quest_subtitle\": \"Sky is the limit !\",\n    \"quest.587464890BE705A2.quest_subtitle\": \"Les mystérieuses cités d'ooooooooooor !\",\n    \"quest.5900CEF50B1F43EA.quest_desc\": [\n        \"Toutes les améliorations commencent ici.\"\n    ],\n    \"quest.5900CEF50B1F43EA.quest_subtitle\": \"Sans base, pas d’upgrade.\",\n    \"quest.5900CEF50B1F43EA.title\": \"La base de tout\",\n    \"quest.594728F6B7F72938.quest_desc\": [\n        \"Crée un Wireless Transmitter. Parce que les câbles, c’est comme les fils de laine : ça s’emmêle toujours au pire moment.\",\n        \"\",\n        \"PS : Si ton signal est faible, vérifie que tu n’es pas dans une grotte. Ou alors, c’est juste la faute à Notch.\"\n    ],\n    \"quest.594728F6B7F72938.quest_subtitle\": \"La liberté, enfin !\",\n    \"quest.5B4CCD39C2F62DC6.quest_desc\": [\n        \"Fabrique des outils en diamant, symbole de puissance et de réussite.\"\n    ],\n    \"quest.5B4CCD39C2F62DC6.quest_subtitle\": \"Screenshot. Sinon ça n’existe pas.\",\n    \"quest.5B4CCD39C2F62DC6.title\": \"Outils en diamant\",\n    \"quest.5BDF03C702E49D12.quest_desc\": [\n        \"Le stockage atteint un niveau complètement déraisonnable.\"\n    ],\n    \"quest.5BDF03C702E49D12.quest_subtitle\": \"On arrête de compter.\",\n    \"quest.5BDF03C702E49D12.title\": \"Plus rien n’a de sens\",\n    \"quest.5C518B44F5FE2942.quest_desc\": [\n        \"L'upgrade du alloy furnace et avec de l'électricité.\"\n    ],\n    \"quest.5FB4592A5CE47A85.quest_desc\": [\n        \"Réunis les différentes couleurs d’Apricorns, indispensables pour fabriquer des Poké Balls variées.\"\n    ],\n    \"quest.5FB4592A5CE47A85.quest_subtitle\": \"Les Poké Balls aussi ont droit à du style.\",\n    \"quest.5FB4592A5CE47A85.title\": \"L’arc-en-ciel d’Apricorns\",\n    \"quest.5FC8CAA124F24D23.quest_desc\": [\n        \"Un Dresseur sans Poké Ball n’est rien. Assemble tes premières Ball et prépare-toi à capturer ton tout premier Pokémon.\"\n    ],\n    \"quest.5FC8CAA124F24D23.quest_subtitle\": \"Taux de réussite : 100% si tu vises bien. 0% si tu paniques.\",\n    \"quest.5FC8CAA124F24D23.title\": \"Fabriquer sa première Poké Ball\",\n    \"quest.604464A52FA18356.quest_desc\": [\n        \"Automatise l’entrée des objets dans ton réseau.\",\n        \"\",\n        \"\",\n        \"Fais sortir automatiquement des objets spécifiques de ton réseau.\"\n    ],\n    \"quest.604464A52FA18356.quest_subtitle\": \"Un objet à la fois. Ou pas.\",\n    \"quest.604464A52FA18356.title\": \"Importeur et Exporteur\",\n    \"quest.61B5D07FC3563D77.quest_desc\": [\n        \"Construisez un chargeur. Parce que même les batteries ont besoin d’amour (et d’électricité).\"\n    ],\n    \"quest.61B5D07FC3563D77.quest_subtitle\": \"Le chargeur qui recharge tout… sauf votre motivation\",\n    \"quest.61ED53786C46D151.quest_desc\": [\n        \"Un outil avancé pour les Dresseurs expérimentés. Obtiens le PokéNav et améliore ta navigation.\"\n    ],\n    \"quest.61ED53786C46D151.quest_subtitle\": \"GPS Pokémon > sens de l’orientation humain.\",\n    \"quest.61ED53786C46D151.title\": \"Le PokéNav\",\n    \"quest.63942A23C87B0347.quest_subtitle\": \"Pour créer les outils en Netherite !\",\n    \"quest.63EA1D6EAC894808.quest_desc\": [\n        \"Ton inventaire déborde et tes coffres sont partout. Il est temps de passer à une solution plus intelligente.\",\n        \"\",\n        \"Le stockage numérique à l’état pur. Centralise tous tes items dans un réseau fluide, triable et automatisable. Fini les coffres en pagaille.\"\n    ],\n    \"quest.63EA1D6EAC894808.quest_subtitle\": \"Ce coffre était là hier, promis.\",\n    \"quest.63EA1D6EAC894808.title\": \"Stockage d'objet\",\n    \"quest.63F9F5EC21750A81.quest_desc\": [\n        \"Augmente drastiquement la capacité de stockage des barils.\"\n    ],\n    \"quest.63F9F5EC21750A81.quest_subtitle\": \"Ce baril avale tout.\",\n    \"quest.63F9F5EC21750A81.title\": \"Organisation extrême\",\n    \"quest.6430902A996E0DA5.quest_desc\": [\n        \"Traverse le portail et découvre le Nether, un monde hostile rempli de dangers et de ressources uniques.\"\n    ],\n    \"quest.6430902A996E0DA5.quest_subtitle\": \"Bienvenue en enfer. Littéralement.\",\n    \"quest.649854BC2006E999.quest_desc\": [\n        \"Utilise un appât Pokémon pour augmenter tes chances de rencontre lors de la pêche.\"\n    ],\n    \"quest.649854BC2006E999.quest_subtitle\": \"Appât ≠ toi dans l’eau. Important.\",\n    \"quest.649854BC2006E999.title\": \"Appât stratégique\",\n    \"quest.684D5F6F7C201552.quest_desc\": [\n        \"Pour commencer, il te faut du silicium et des bindings. Parce qu’un système de stockage sans silicium, c’est comme un sandwich sans pain : techniquement possible, mais franchement triste.\"\n    ],\n    \"quest.684D5F6F7C201552.quest_subtitle\": \"Silicon Valley, version Minecraft\",\n    \"quest.684D5F6F7C201552.title\": \"Les Fondamentaux du Silicon\",\n    \"quest.6B0A6E988A8C0311.quest_desc\": [\n        \"Découvre les barils Sophisticated : plus pratiques, plus modulaires.\"\n    ],\n    \"quest.6B0A6E988A8C0311.quest_subtitle\": \"Le coffre 2.0.\",\n    \"quest.6B0A6E988A8C0311.title\": \"Une alternative aux coffres\",\n    \"quest.6C350A1B822C9552.quest_desc\": [\n        \"Crée une Wrench. Parce qu’un bon artisan a toujours sa clé à molette… et un marteau pour les cas désespérés.\",\n        \"\",\n        \"PS : Cette clé ne sert pas à monter des meubles IKEA. Dommage, hein ?\"\n    ],\n    \"quest.6C350A1B822C9552.quest_subtitle\": \"L’outil magique (ou presque)\",\n    \"quest.6C350A1B822C9552.title\": \"La Clé à Molette\",\n    \"quest.6C8C157F9913E73E.quest_desc\": [\n        \"Une meilleure capacité et plus de possibilités.\"\n    ],\n    \"quest.6C8C157F9913E73E.quest_subtitle\": \"Le cuivre sert enfin à quelque chose.\",\n    \"quest.6C8C157F9913E73E.title\": \"Première amélioration\",\n    \"quest.6EB386C81EE9B04B.quest_desc\": [\n        \"Passe au sac à dos en fer pour augmenter ta capacité de stockage.\"\n    ],\n    \"quest.6EB386C81EE9B04B.quest_subtitle\": \"Ton dos commence à apprécier.\",\n    \"quest.6EB386C81EE9B04B.title\": \"Plus solide, plus utile\",\n    \"quest.6EDB5E8D88458230.quest_desc\": [\n        \"Fabriquez une batterie de niveau 1. Parce que stocker l’énergie, c’est comme stocker des snacks : on en a toujours besoin au pire moment !\"\n    ],\n    \"quest.6EDB5E8D88458230.quest_subtitle\": \"La batterie qui ne dure jamais assez longtemps\",\n    \"quest.6EE70DA752182D83.quest_desc\": [\n        \"Avec de l’expérience et de la patience, certains Pokémon évoluent. Assiste à ta première évolution.\"\n    ],\n    \"quest.6EE70DA752182D83.quest_subtitle\": \"Il grandit si vite… \",\n    \"quest.6EE70DA752182D83.title\": \"L’évolution naturelle\",\n    \"quest.6F5D04DC6DBDD027.quest_desc\": [\n        \"Des fossiles anciens renferment des Pokémon disparus. Mets la main sur l’un d’eux.\"\n    ],\n    \"quest.6F5D04DC6DBDD027.quest_subtitle\": \"Un Pokémon antique… plus vieux que ton PC.\",\n    \"quest.6F5D04DC6DBDD027.title\": \"Vestiges du passé\",\n    \"quest.6FEF21B99B05DEFC.quest_desc\": [\n        \"Augmente drastiquement la capacité de stockage des barils.\"\n    ],\n    \"quest.6FEF21B99B05DEFC.quest_subtitle\": \"Ce baril avale tout.\",\n    \"quest.6FEF21B99B05DEFC.title\": \"Organisation extrême\",\n    \"quest.72511D0743654C3F.quest_desc\": [\n        \"Des sacs à dos et coffres améliorés, modulables et élégants. Tu voyages léger, sans jamais manquer de place.\"\n    ],\n    \"quest.72511D0743654C3F.title\": \"Sophisticated Series\",\n    \"quest.74869FF761E30417.quest_desc\": [\n        \"Fabriquez 10 isolants pour câbles. Parce que personne n’aime les étincelles… sauf les pyromanes.\"\n    ],\n    \"quest.74869FF761E30417.quest_subtitle\": \"Isoler, c’est protéger (et éviter les courts-circuits !)\",\n    \"quest.74869FF761E30417.title\": \"L’isolant de câble\",\n    \"quest.75D88B16012FDEDF.quest_subtitle\": \"Ramasser de la pierre !\",\n    \"quest.7694A2A4312FC289.quest_desc\": [\n        \"Installe un chaudron de campement pour préparer des plats utiles à tes Pokémon durant l’aventure.\"\n    ],\n    \"quest.7694A2A4312FC289.quest_subtitle\": \"Cuisine de Dresseur\",\n    \"quest.77193D10E263D772.quest_desc\": [\n        \"Trouve des débris antiques dans le Nether pour commencer le chemin vers la netherite.\",\n        \"\",\n        \"Trouve un modèle de forge pour améliorer ton équipement en netherite.\",\n        \"\",\n        \"Utilise une table de forge pour améliorer tes équipements vers la netherite.\"\n    ],\n    \"quest.77193D10E263D772.quest_subtitle\": \"Boom contrôlé… normalement.\",\n    \"quest.77193D10E263D772.title\": \"Lingots de netherite\",\n    \"quest.77F18EE5BE07C165.quest_desc\": [\n        \"Grâce aux Capsules Ball, transforme chaque apparition en spectacle.\"\n    ],\n    \"quest.77F18EE5BE07C165.quest_subtitle\": \"Ton Pokémon entre en scène.\",\n    \"quest.787F25EA2D9BA294.quest_desc\": [\n        \"Un stockage avancé pour bases bien rangées.\"\n    ],\n    \"quest.787F25EA2D9BA294.quest_subtitle\": \"Riche en slots.\",\n    \"quest.787F25EA2D9BA294.title\": \"Le luxe organisé\",\n    \"quest.79510B2EAD8DA293.quest_desc\": [\n        \"Explore le monde à la recherche de Pokémon à capturer, entraîner et faire combattre. Le tout, intégré naturellement à l’univers Minecraft.\"\n    ],\n    \"quest.7A3898B3DF6802E0.quest_desc\": [\n        \"Fabriquez un lingot d’étain. Oui, c’est moins glamour que l’or, mais sans ça, pas de câbles, pas d’électricité, et pas de fun !\"\n    ],\n    \"quest.7A3898B3DF6802E0.quest_subtitle\": \"L’étain, ce métal qui ne brille pas… mais qui sert !\",\n    \"quest.7BCE95A761092F41.quest_subtitle\": \"Non par contre t'abuse la !\",\n    \"quest.7D5EA22F6179D03C.quest_subtitle\": \"De l’entrée de gamme au PC de gamer\",\n    \"quest.7DC992A32387E13C.quest_desc\": [\n        \"Merci à toutes les personnes qui ont patienté et soutenu le projet pendant son développement.\",\n        \"\",\n        \"Le serveur est enfin ouvert : amusez-vous, explorez et profitez de l’aventure !\",\n        \"\",\n        \"Vous pouvez valider la quêtes au dessus en cliquant sur le check ;)\"\n    ],\n    \"quest.7DC992A32387E13C.quest_subtitle\": \"Merci et bienvenue sur pokéheros 2 !\",\n    \"quest.7DC992A32387E13C.title\": \"Bienvenue sur PokéHeros 2 !\",\n    \"quest.7EF5AD572A6D9AFA.quest_desc\": [\n        \"Un Dresseur ne voyage jamais seul. Constitue une équipe complète de Pokémon prêts à combattre et à progresser ensemble.\"\n    ],\n    \"quest.7EF5AD572A6D9AFA.quest_subtitle\": \"Six Pokémon. Zéro place pour les excuses.\",\n    \"quest.7EF5AD572A6D9AFA.title\": \"Une équipe complète\",\n    \"reward_table.091CACD354754AFC.title\": \"Master Loot table\",\n    \"reward_table.09890663668C284D.title\": \"Normal Cobblemon loottable\",\n    \"task.14B6F8E1CB39F1A1.title\": \"Sophisticated\",\n    \"task.2512E0487C4CAF52.title\": \"L’autre côté\",\n    \"task.303A241570D411A0.title\": \"Cobblemon\",\n    \"task.37ADDE057FA583EF.title\": \"Minecraft Vanilla\",\n    \"task.38FD65BD5BE00415.title\": \"Finito Minecraft Vanilla +\",\n    \"task.45ED3B829663B335.title\": \"Energized power\",\n    \"task.4714CD0936B09365.title\": \"Bienvenue !\",\n    \"task.4B9A890EB2D74B94.title\": \"Refined Storage\",\n    \"task.556E16141A56CE76.title\": \"Dimensions\",\n    \"task.58FBD46CD01BF319.title\": \"Outils en fer !\",\n    \"task.59A44410655F5D3F.title\": \"Vanilla\",\n    \"task.6BB00AEBEE55A69A.title\": \"Parler au Doc. Follamour\"\n}"
]